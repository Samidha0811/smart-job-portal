<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — Smart Job Portal</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="dashboard-page">

  <!-- ===== NAVBAR ===== -->
  <nav class="navbar navbar-expand-lg navbar-premium">
    <div class="container-fluid px-4">
      <a class="navbar-brand" href="/">
        <i class="fas fa-briefcase me-2" style="color:#818cf8;"></i>SmartJobPortal
      </a>
      <div class="collapse navbar-collapse">
        <ul class="navbar-nav ms-auto align-items-center gap-1">
          <li class="nav-item"><a class="nav-link" href="/jobs"><i class="fas fa-search me-1"></i>Browse Jobs</a></li>
          <li class="nav-item"><a class="nav-link active" href="/seeker/dashboard"><i class="fas fa-th-large me-1"></i>My Applications</a></li>
          <li class="nav-item ms-2">
            <a class="btn-nav-danger" href="#" id="logoutLink"><i class="fas fa-sign-out-alt me-1"></i>Logout</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="dashboard-container">
    <!-- Page Header -->
    <div class="d-flex align-items-center gap-3 mb-4">
      <div>
        <h1 class="page-title" style="font-size:1.6rem;">My Dashboard</h1>
        <p style="color:var(--gray);font-size:0.85rem;margin:0;">Welcome back, <%= user.fullname %>!</p>
      </div>
    </div>

    <div class="row g-4">
      <!-- ===== SIDEBAR ===== -->
      <div class="col-lg-3">
        <div class="sidebar-card">
          <div class="sidebar-header">
            <div class="avatar-circle">
              <i class="fas fa-user"></i>
            </div>
            <div class="sidebar-name"><%= user.fullname %></div>
            <div class="sidebar-email"><%= user.email %></div>
            <div class="mt-2">
              <span class="status-badge status-approved">
                <i class="fas fa-check-circle" style="font-size:0.7rem;"></i> Verified Seeker
              </span>
            </div>
          </div>
          <div class="sidebar-body">
            <div class="sidebar-info-row">
              <div class="sidebar-info-item">
                <div class="sidebar-info-icon icon-purple">
                  <i class="fas fa-graduation-cap"></i>
                </div>
                <div>
                  <div style="font-size:0.72rem;color:var(--gray);text-transform:uppercase;letter-spacing:0.05em;font-weight:600;margin-bottom:0.15rem;">Education</div>
                  <div style="font-size:0.85rem;color:var(--dark);font-weight:500;"><%= profile.education || 'Not set' %></div>
                </div>
              </div>
              <div class="sidebar-info-item">
                <div class="sidebar-info-icon icon-cyan">
                  <i class="fas fa-history"></i>
                </div>
                <div>
                  <div style="font-size:0.72rem;color:var(--gray);text-transform:uppercase;letter-spacing:0.05em;font-weight:600;margin-bottom:0.15rem;">Experience</div>
                  <div style="font-size:0.85rem;color:var(--dark);font-weight:500;"><%= profile.experience_years || '0' %> Years</div>
                </div>
              </div>
              <div class="sidebar-info-item">
                <div class="sidebar-info-icon icon-amber">
                  <i class="fas fa-tools"></i>
                </div>
                <div>
                  <div style="font-size:0.72rem;color:var(--gray);text-transform:uppercase;letter-spacing:0.05em;font-weight:600;margin-bottom:0.15rem;">Skills</div>
                  <div style="font-size:0.82rem;color:var(--dark);font-weight:500;line-height:1.4;"><%= profile.skills || 'Not set' %></div>
                </div>
              </div>

              <% if (profile.bio) { %>
              <div class="sidebar-info-item">
                <div class="sidebar-info-icon icon-emerald">
                  <i class="fas fa-align-left"></i>
                </div>
                <div>
                  <div style="font-size:0.72rem;color:var(--gray);text-transform:uppercase;letter-spacing:0.05em;font-weight:600;margin-bottom:0.15rem;">About</div>
                  <div style="font-size:0.82rem;color:var(--dark);font-weight:400;line-height:1.4;"><%= profile.bio.substring(0, 80) %><%= profile.bio.length > 80 ? '...' : '' %></div>
                </div>
              </div>
              <% } %>
            </div>

            <div class="mt-4 d-grid gap-2">
              <a href="/jobs" class="btn btn-primary w-100 fw-bold" style="border-radius:10px;font-size:0.875rem;">
                <i class="fas fa-search me-2"></i>Browse Jobs
              </a>
              <a href="/api/seeker/resume" target="_blank"
                class="btn btn-outline-secondary w-100 fw-bold" style="border-radius:10px;font-size:0.875rem;border-color:var(--border);color:var(--gray);">
                <i class="fas fa-file-pdf me-2"></i>View My Resume
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- ===== APPLICATIONS ===== -->
      <div class="col-lg-9">
        <!-- Stats Row -->
        <div class="row g-3 mb-4" id="statsRow">
          <div class="col-6 col-md-3">
            <div style="background:var(--white);border:1px solid var(--border);border-radius:var(--radius-lg);padding:1.25rem;text-align:center;">
              <div style="font-size:1.75rem;font-weight:800;color:var(--dark);" id="statTotal">—</div>
              <div style="font-size:0.75rem;color:var(--gray);font-weight:600;text-transform:uppercase;letter-spacing:0.05em;">Total Applied</div>
            </div>
          </div>
          <div class="col-6 col-md-3">
            <div style="background:var(--white);border:1px solid var(--border);border-radius:var(--radius-lg);padding:1.25rem;text-align:center;">
              <div style="font-size:1.75rem;font-weight:800;color:#059669;" id="statShortlisted">—</div>
              <div style="font-size:0.75rem;color:var(--gray);font-weight:600;text-transform:uppercase;letter-spacing:0.05em;">Shortlisted</div>
            </div>
          </div>
          <div class="col-6 col-md-3">
            <div style="background:var(--white);border:1px solid var(--border);border-radius:var(--radius-lg);padding:1.25rem;text-align:center;">
              <div style="font-size:1.75rem;font-weight:800;color:#2563eb;" id="statProcessing">—</div>
              <div style="font-size:0.75rem;color:var(--gray);font-weight:600;text-transform:uppercase;letter-spacing:0.05em;">In Process</div>
            </div>
          </div>
          <div class="col-6 col-md-3">
            <div style="background:var(--white);border:1px solid var(--border);border-radius:var(--radius-lg);padding:1.25rem;text-align:center;">
              <div style="font-size:1.75rem;font-weight:800;color:#b45309;" id="statPending">—</div>
              <div style="font-size:0.75rem;color:var(--gray);font-weight:600;text-transform:uppercase;letter-spacing:0.05em;">Pending</div>
            </div>
          </div>
        </div>

        <!-- Applications Table -->
        <div class="main-card">
          <div class="main-card-header">
            <h2 class="page-title" style="font-size:1.15rem;">My Applications</h2>
            <span class="status-badge status-checking" id="appCount">Loading...</span>
          </div>
          <div class="table-responsive">
            <table class="app-table w-100">
              <thead>
                <tr>
                  <th>Job Title</th>
                  <th>Company</th>
                  <th>Applied</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody id="applicationList">
                <tr>
                  <td colspan="4">
                    <div class="loading-overlay">
                      <div class="spinner-border spinner-border-sm text-primary"></div>
                      <span>Loading applications...</span>
                    </div>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ===== LOGOUT MODAL ===== -->
  <div class="modal fade modal-premium" id="logoutModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header header-danger border-0">
          <h5 class="modal-title fw-bold text-white"><i class="fas fa-sign-out-alt me-2"></i>Confirm Logout</h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body text-center py-4">
          <div style="width:70px;height:70px;background:rgba(239,68,68,0.1);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1.25rem;font-size:1.75rem;color:#ef4444;">
            <i class="fas fa-exclamation-triangle"></i>
          </div>
          <h5 class="fw-bold mb-2">Are you sure?</h5>
          <p class="text-muted mb-0" style="font-size:0.9rem;">You will be signed out of your session.</p>
        </div>
        <div class="modal-footer justify-content-center border-0 bg-white pb-4">
          <button class="btn btn-light px-4 fw-bold" data-bs-dismiss="modal">Cancel</button>
          <a href="/api/auth/logout" class="btn btn-danger px-4 fw-bold">
            <i class="fas fa-sign-out-alt me-2"></i>Logout Now
          </a>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/apiService.js"></script>
  <script>
    // Logout
    document.getElementById('logoutLink').addEventListener('click', function(e) {
      e.preventDefault();
      new bootstrap.Modal(document.getElementById('logoutModal')).show();
    });

    // BFCache prevention
    window.addEventListener('pageshow', (e) => { if (e.persisted) window.location.reload(); });

    document.addEventListener('DOMContentLoaded', async () => {
      try {
        const response = await fetch('/api/seeker/my-applications');
        const apps = await response.json();

        const appList = document.getElementById('applicationList');
        const appCount = document.getElementById('appCount');

        // Stats
        const shortlisted = apps.filter(a => a.status === 'shortlisted').length;
        const processing = apps.filter(a => a.status === 'under process').length;
        const pending = apps.filter(a => a.status === 'pending').length;

        document.getElementById('statTotal').textContent = apps.length;
        document.getElementById('statShortlisted').textContent = shortlisted;
        document.getElementById('statProcessing').textContent = processing;
        document.getElementById('statPending').textContent = pending;

        appCount.textContent = `${apps.length} Application${apps.length !== 1 ? 's' : ''}`;
        appCount.className = 'status-badge status-checking';

        if (apps.length === 0) {
          appList.innerHTML = `
            <tr><td colspan="4">
              <div class="empty-state">
                <div class="empty-state-icon"><i class="fas fa-briefcase"></i></div>
                <div class="empty-state-title">No Applications Yet</div>
                <div class="empty-state-text">Start applying to jobs and your applications will appear here.</div>
                <a href="/jobs" class="btn btn-primary mt-3 fw-bold" style="border-radius:10px;">Browse Jobs</a>
              </div>
            </td></tr>`;
          return;
        }

        appList.innerHTML = apps.map(app => `
          <tr>
            <td>
              <div class="fw-bold" style="color:var(--dark);font-size:0.9rem;">${app.job_title}</div>
            </td>
            <td>
              <div class="d-flex align-items-center gap-2">
                <div style="width:28px;height:28px;background:rgba(79,70,229,0.08);border-radius:6px;display:flex;align-items:center;justify-content:center;color:var(--primary);font-size:0.75rem;flex-shrink:0;">
                  <i class="fas fa-building"></i>
                </div>
                <span style="font-size:0.875rem;">${app.company_name}</span>
              </div>
            </td>
            <td style="font-size:0.85rem;color:var(--gray);">${new Date(app.applied_at).toLocaleDateString('en-IN', {day:'numeric',month:'short',year:'numeric'})}</td>
            <td><span class="${getStatusPill(app.status)}">${getStatusDot(app.status)}${capitalize(app.status)}</span></td>
          </tr>
        `).join('');

      } catch (err) {
        console.error('Error:', err);
        document.getElementById('applicationList').innerHTML = `
          <tr><td colspan="4" class="text-center text-danger py-4">Error loading applications.</td></tr>`;
      }
    });

    function getStatusPill(status) {
      const map = { shortlisted: 'pill pill-success', rejected: 'pill pill-danger', hold: 'pill pill-secondary', 'under process': 'pill pill-info' };
      return map[status] || 'pill pill-warning';
    }

    function getStatusDot(status) {
      return '<span class="pill-dot"></span>';
    }

    function capitalize(s) { return s.charAt(0).toUpperCase() + s.slice(1); }
  </script>
</body>
</html>
