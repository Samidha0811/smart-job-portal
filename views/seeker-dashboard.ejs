<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-light">
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
        <div class="container">
          <a class="navbar-brand fw-bold" href="/">Smart Job Portal</a>
          <div class="collapse navbar-collapse">
            <ul class="navbar-nav ms-auto">
                <li class="nav-item"><a class="nav-link" href="/jobs">Browse Jobs</a></li>
                <li class="nav-item"><a class="nav-link active" href="/seeker/dashboard">My Applications</a></li>
                <li class="nav-item"><a class="nav-link text-white-50" href="#" id="logoutLink">Logout</a></li>
            </ul>
          </div>
        </div>
    </nav>

    <div class="container py-5">
        <div class="row">
            <!-- Profile Summary Card -->
            <div class="col-md-4 mb-4">
                <div class="card shadow border-0 rounded-4 overflow-hidden">
                    <div class="card-header bg-primary text-white p-3 border-0">
                        <h5 class="fw-bold mb-0 text-center"><i class="fas fa-user-circle me-2"></i>My Profile</h5>
                    </div>
                    <div class="card-body p-4">
                        <div class="text-center mb-4">
                            <div class="avatar bg-light text-primary rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px; font-size: 2rem;">
                                <i class="fas fa-user"></i>
                            </div>
                            <h4 class="fw-bold text-dark mb-1"><%= user.fullname %></h4>
                            <p class="text-muted small mb-0"><%= user.email %></p>
                            <span class="badge bg-success rounded-pill mt-2">Verified Seeker</span>
                        </div>
                        
                        <div class="mb-4">
                            <h6 class="fw-bold text-primary mb-2 small uppercase">About Me</h6>
                            <p class="text-secondary small mb-0"><%= profile.bio %></p>
                        </div>

                        <div class="mb-4">
                            <h6 class="fw-bold text-primary mb-2 small uppercase">Professional Details</h6>
                            <div class="small mb-1"><strong><i class="fas fa-graduation-cap me-1"></i> Education:</strong> <%= profile.education %></div>
                            <div class="small mb-1"><strong><i class="fas fa-history me-1"></i> Experience:</strong> <%= profile.experience_years %> Years</div>
                            <div class="small"><strong><i class="fas fa-tools me-1"></i> Skills:</strong> <%= profile.skills %></div>
                        </div>

                        <div class="d-grid mt-3">
                            <a href="#" class="btn btn-outline-primary btn-sm fw-bold rounded-pill">
                                <i class="fas fa-file-pdf me-1"></i> View Resume
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Applications Section -->
            <div class="col-md-8">
                <div class="card shadow border-0 rounded-4">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h2 class="fw-bold text-primary mb-0">My Applications</h2>
                            <span class="badge bg-primary fs-6" id="appCount">0 Applications</span>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Job Title</th>
                                        <th>Company</th>
                                        <th>Applied Date</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody id="applicationList">
                                    <tr>
                                        <td colspan="4" class="text-center py-4">
                                            <div class="spinner-border text-primary" role="status">
                                                <span class="visually-hidden">Loading...</span>
                                            </div>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Logout Confirmation Modal -->
    <div class="modal fade" id="logoutModal" tabindex="-1" aria-labelledby="logoutModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow-lg border-0" style="border-radius: 1rem;">
                <div class="modal-header bg-danger text-white border-0 py-3">
                    <h5 class="modal-title fw-bold" id="logoutModalLabel">
                        <i class="fas fa-sign-out-alt me-2"></i>Confirm Logout
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-5 text-center">
                    <div class="mb-3 text-danger">
                        <i class="fas fa-exclamation-circle fa-4x"></i>
                    </div>
                    <h4 class="fw-bold">Are you sure?</h4>
                    <p class="text-muted mb-0">You will be signed out of your session.</p>
                </div>
                <div class="modal-footer border-0 p-3 bg-light justify-content-center">
                    <button type="button" class="btn btn-light px-4 fw-bold text-muted" data-bs-dismiss="modal">Cancel</button>
                    <a href="/api/auth/logout" class="btn btn-danger px-4 fw-bold shadow-sm">Logout Now</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/apiService.js"></script>
    <script>
        // Handle Logout Popup
        document.addEventListener('DOMContentLoaded', () => {
            const logoutLink = document.getElementById('logoutLink');
            if (logoutLink) {
                logoutLink.addEventListener('click', function(e) {
                    e.preventDefault();
                    const modalEl = document.getElementById('logoutModal');
                    const logoutModal = new bootstrap.Modal(modalEl);
                    logoutModal.show();
                });
            }
        });

        // Prevent Back-Forward Cache (bfcache)
        window.addEventListener('pageshow', (event) => {
            if (event.persisted) {
                window.location.reload();
            }
        });

        document.addEventListener('DOMContentLoaded', async () => {
            try {
                const response = await fetch('/api/seeker/my-applications');
                const apps = await response.json();
                
                const appList = document.getElementById('applicationList');
                const appCount = document.getElementById('appCount');
                
                if (apps.length === 0) {
                    appList.innerHTML = '<tr><td colspan="4" class="text-center py-4 text-muted">You haven\'t applied to any jobs yet. <a href="/jobs">Browse Jobs</a></td></tr>';
                    appCount.textContent = '0 Applications';
                    return;
                }

                appCount.textContent = `${apps.length} Application${apps.length > 1 ? 's' : ''}`;
                appList.innerHTML = apps.map(app => `
                    <tr>
                        <td class="fw-bold">${app.job_title}</td>
                        <td>${app.company_name}</td>
                        <td class="text-muted">${new Date(app.applied_at).toLocaleDateString()}</td>
                        <td>
                            <span class="badge ${getStatusBadge(app.status)} px-3 py-2 rounded-pill">
                                ${app.status.charAt(0).toUpperCase() + app.status.slice(1)}
                            </span>
                        </td>
                    </tr>
                `).join('');

            } catch (err) {
                console.error('Error:', err);
                document.getElementById('applicationList').innerHTML = '<tr><td colspan="4" class="text-center text-danger">Error loading applications.</td></tr>';
            }
        });

        function getStatusBadge(status) {
            switch(status) {
                case 'shortlisted': return 'bg-success';
                case 'rejected': return 'bg-danger';
                case 'hold': return 'bg-secondary text-white';
                case 'under process': return 'bg-info text-dark';
                default: return 'bg-warning text-dark';
            }
        }
    </script>
</body>
</html>
