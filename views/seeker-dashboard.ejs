<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= title %> — Smart Job Portal
  </title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/chatbot.css?v=1.1">
</head>

<body class="dashboard-page">

  <!-- ===== NAVBAR ===== -->
  <nav class="navbar navbar-expand-lg navbar-premium">
    <div class="container-fluid px-4">
      <a class="navbar-brand" href="/">
        <i class="fas fa-briefcase me-2" style="color:#818cf8;"></i>SmartJobPortal
      </a>
      <div class="collapse navbar-collapse">
        <ul class="navbar-nav ms-auto align-items-center gap-1">
          <li class="nav-item"><a class="nav-link" href="/jobs"><i class="fas fa-search me-1"></i>Browse Jobs</a></li>
          <li class="nav-item"><a class="nav-link active" href="/seeker/dashboard"><i
                class="fas fa-th-large me-1"></i>My Applications</a></li>
          <li class="nav-item ms-2">
            <a class="btn-nav-danger" href="#" id="logoutLink"><i class="fas fa-sign-out-alt me-1"></i>Logout</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="dashboard-container">
    <!-- Page Header -->
    <div class="d-flex align-items-center gap-3 mb-4">
    </div>

    <div class="row g-4">
      <!-- ===== SIDEBAR ===== -->
      <div class="col-lg-3">
        <div class="sidebar-card">
          <div class="sidebar-header">
            <div class="avatar-circle">
              <i class="fas fa-user"></i>
            </div>
            <div class="sidebar-name">
              <%= profile.full_name || user.fullname %>
            </div>
            <div class="sidebar-email">
              <%= profile.email || user.email %>
            </div>
            <div class="mt-2">
              <span class="status-badge status-approved">
                <i class="fas fa-check-circle" style="font-size:0.7rem;"></i> Verified Seeker
              </span>
            </div>
          </div>
          <div class="sidebar-body">
            <div class="sidebar-info-row">
              <div class="sidebar-info-item">
                <div class="sidebar-info-icon icon-purple">
                  <i class="fas fa-briefcase"></i>
                </div>
                <div>
                  <div style="font-size:0.72rem;color:var(--gray);text-transform:uppercase;letter-spacing:0.05em;font-weight:600;margin-bottom:0.15rem;">Current Role</div>
                  <div style="font-size:0.85rem;color:var(--dark);font-weight:500;">
                    <%= profile.current_job_title || 'N/A' %>
                  </div>
                </div>
              </div>
              <div class="sidebar-info-item">
                <div class="sidebar-info-icon icon-cyan">
                  <i class="fas fa-history"></i>
                </div>
                <div>
                  <div style="font-size:0.72rem;color:var(--gray);text-transform:uppercase;letter-spacing:0.05em;font-weight:600;margin-bottom:0.15rem;">Experience</div>
                  <div style="font-size:0.85rem;color:var(--dark);font-weight:500;">
                    <%= profile.total_experience_years || '0' %>y <%= profile.total_experience_months || '0' %>m
                  </div>
                </div>
              </div>
              <div class="sidebar-info-item">
                <div class="sidebar-info-icon icon-amber">
                  <i class="fas fa-map-marker-alt"></i>
                </div>
                <div>
                  <div style="font-size:0.72rem;color:var(--gray);text-transform:uppercase;letter-spacing:0.05em;font-weight:600;margin-bottom:0.15rem;">Location</div>
                  <div style="font-size:0.85rem;color:var(--dark);font-weight:500;">
                    <%= profile.location || 'Not set' %>
                  </div>
                </div>
              </div>
            </div>

            <div class="mt-4 d-grid gap-2">
              <a href="/seeker/profile-setup" class="btn btn-primary w-100 fw-bold" style="border-radius:10px;font-size:0.875rem;">
                <i class="fas fa-user-edit me-2"></i>Edit My Profile
              </a>
              <a href="/jobs" class="btn btn-outline-primary w-100 fw-bold" style="border-radius:10px;font-size:0.875rem;">
                <i class="fas fa-search me-2"></i>Browse Jobs
              </a>
            </div>
          </div>
        </div>
      </div>


      <!-- ===== APPLICATIONS ===== -->
      <div class="col-lg-9">
        <!-- Stats Row -->
        <div class="row g-3 mb-4" id="statsRow">
          <div class="col-6 col-md-3">
            <div
              style="background:var(--white);border:1px solid var(--border);border-radius:var(--radius-lg);padding:1.25rem;text-align:center;">
              <div style="font-size:1.75rem;font-weight:800;color:var(--dark);" id="statTotal">—</div>
              <div
                style="font-size:0.75rem;color:var(--gray);font-weight:600;text-transform:uppercase;letter-spacing:0.05em;">
                Total Applied</div>
            </div>
          </div>
          <div class="col-6 col-md-3">
            <div
              style="background:var(--white);border:1px solid var(--border);border-radius:var(--radius-lg);padding:1.25rem;text-align:center;">
              <div style="font-size:1.75rem;font-weight:800;color:#059669;" id="statShortlisted">—</div>
              <div
                style="font-size:0.75rem;color:var(--gray);font-weight:600;text-transform:uppercase;letter-spacing:0.05em;">
                Shortlisted</div>
            </div>
          </div>
          <div class="col-6 col-md-3">
            <div
              style="background:var(--white);border:1px solid var(--border);border-radius:var(--radius-lg);padding:1.25rem;text-align:center;">
              <div style="font-size:1.75rem;font-weight:800;color:#2563eb;" id="statProcessing">—</div>
              <div
                style="font-size:0.75rem;color:var(--gray);font-weight:600;text-transform:uppercase;letter-spacing:0.05em;">
                In Process</div>
            </div>
          </div>
          <div class="col-6 col-md-3">
            <div
              style="background:var(--white);border:1px solid var(--border);border-radius:var(--radius-lg);padding:1.25rem;text-align:center;">
              <div style="font-size:1.75rem;font-weight:800;color:#b45309;" id="statPending">—</div>
              <div
                style="font-size:0.75rem;color:var(--gray);font-weight:600;text-transform:uppercase;letter-spacing:0.05em;">
                Pending</div>
            </div>
          </div>
        </div>

        <!-- ===== RECOMMENDED JOBS ===== -->
        <div class="mb-5" id="recommendationSection" style="display:none;">
          <div class="d-flex align-items-center justify-content-between mb-3">
            <h2 class="page-title" style="font-size:1.25rem;margin:0;">🔥 Recommended Jobs For You</h2>
            <a href="/jobs" class="text-primary fw-bold" style="font-size:0.85rem;text-decoration:none;">View All <i class="fas fa-arrow-right ms-1"></i></a>
          </div>
          <div id="recommendationList" class="row g-3 flex-nowrap overflow-auto pb-2" style="scrollbar-width: thin;">
            <!-- Recommended jobs will be injected here -->
          </div>
        </div>

        <!-- Applications Table -->
        <div class="main-card">
          <div class="main-card-header">
            <h2 class="page-title" style="font-size:1.15rem;">My Applications</h2>
            <span class="status-badge status-checking" id="appCount">Loading...</span>
          </div>
          <div class="table-responsive">
            <table class="app-table w-100">
              <thead>
                <tr>
                  <th>Job Title</th>
                  <th>Company</th>
                  <th>Applied</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody id="applicationList">
                <tr>
                  <td colspan="4">
                    <div class="loading-overlay">
                      <div class="spinner-border spinner-border-sm text-primary"></div>
                      <span>Loading applications...</span>
                    </div>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ===== AI CAREER MENTOR CHATBOT ===== -->
  <button id="chatbot-toggle-btn" class="chatbot-toggle-btn">
    <i class="fas fa-robot"></i> Ask Career Mentor
  </button>

  <div id="chatbot-container" class="chatbot-container d-none">
    <div class="chatbot-header">
      <div class="d-flex align-items-center gap-2">
        <div class="chatbot-avatar"><i class="fas fa-robot"></i></div>
        <div>
          <h5 class="mb-0 text-white" style="font-size:1rem;font-weight:600;">AI Mentor</h5>
          <small style="color:rgba(255,255,255,0.8);font-size:0.75rem;">Online</small>
        </div>
      </div>
      <button id="chatbot-close-btn" class="btn-close btn-close-white"></button>
    </div>
    
    <div class="chatbot-messages" id="chatbot-messages">
      <div class="message bot-message">
        Hi there! I'm your AI Career Mentor. I've reviewed your profile and I'm ready to help. What would you like to know?
      </div>
    </div>

    <div class="chatbot-suggestions">
      <button class="chat-suggestion-btn">What skills should I learn?</button>
      <button class="chat-suggestion-btn">Am I ready for my desired role?</button>
      <button class="chat-suggestion-btn">Improve my resume</button>
    </div>

    <div class="chatbot-input-area">
      <input type="text" id="chatbot-input" placeholder="Type your message..." autocomplete="off">
      <button id="chatbot-send-btn"><i class="fas fa-paper-plane"></i></button>
    </div>
  </div>

  <!-- ===== LOGOUT MODAL ===== -->
  <div class="modal fade modal-premium" id="logoutModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header header-danger border-0">
          <h5 class="modal-title fw-bold text-white"><i class="fas fa-sign-out-alt me-2"></i>Confirm Logout</h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body text-center py-4">
          <div
            style="width:70px;height:70px;background:rgba(239,68,68,0.1);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1.25rem;font-size:1.75rem;color:#ef4444;">
            <i class="fas fa-exclamation-triangle"></i>
          </div>
          <h5 class="fw-bold mb-2">Are you sure?</h5>
          <p class="text-muted mb-0" style="font-size:0.9rem;">You will be signed out of your session.</p>
        </div>
        <div class="modal-footer justify-content-center border-0 bg-white pb-4">
          <button class="btn btn-light px-4 fw-bold" data-bs-dismiss="modal">Cancel</button>
          <a href="/api/auth/logout" class="btn btn-danger px-4 fw-bold">
            <i class="fas fa-sign-out-alt me-2"></i>Logout Now
          </a>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/apiService.js"></script>
  <script src="/js/chatbot.js?v=1.1"></script>
  <script>
    // Logout
    document.getElementById('logoutLink').addEventListener('click', function (e) {
      e.preventDefault();
      new bootstrap.Modal(document.getElementById('logoutModal')).show();
    });

    // BFCache prevention
    window.addEventListener('pageshow', (e) => { if (e.persisted) window.location.reload(); });

    document.addEventListener('DOMContentLoaded', async () => {
      try {
        const response = await fetch('/api/seeker/my-applications');
        const apps = await response.json();

        const appList = document.getElementById('applicationList');
        const appCount = document.getElementById('appCount');

        // Stats
        const shortlisted = apps.filter(a => a.status === 'shortlisted').length;
        const processing = apps.filter(a => a.status === 'under process').length;
        const pending = apps.filter(a => a.status === 'pending').length;

        document.getElementById('statTotal').textContent = apps.length;
        document.getElementById('statShortlisted').textContent = shortlisted;
        document.getElementById('statProcessing').textContent = processing;
        document.getElementById('statPending').textContent = pending;

        appCount.textContent = `${apps.length} Application${apps.length !== 1 ? 's' : ''}`;
        appCount.className = 'status-badge status-checking';

        if (apps.length === 0) {
          appList.innerHTML = `
            <tr><td colspan="4">
              <div class="empty-state">
                <div class="empty-state-icon"><i class="fas fa-briefcase"></i></div>
                <div class="empty-state-title">No Applications Yet</div>
                <div class="empty-state-text">Start applying to jobs and your applications will appear here.</div>
                <a href="/jobs" class="btn btn-primary mt-3 fw-bold" style="border-radius:10px;">Browse Jobs</a>
              </div>
            </td></tr>`;
          return;
        }

        appList.innerHTML = apps.map(app => `
          <tr>
            <td>
              <div class="fw-bold" style="color:var(--dark);font-size:0.9rem;">${app.job_title}</div>
            </td>
            <td>
              <div class="d-flex align-items-center gap-2">
                <div style="width:28px;height:28px;background:rgba(79,70,229,0.08);border-radius:6px;display:flex;align-items:center;justify-content:center;color:var(--primary);font-size:0.75rem;flex-shrink:0;">
                  <i class="fas fa-building"></i>
                </div>
                <span style="font-size:0.875rem;">${app.company_name}</span>
              </div>
            </td>
            <td style="font-size:0.85rem;color:var(--gray);">${new Date(app.applied_at).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' })}</td>
            <td><span class="${getStatusPill(app.status)}">${getStatusDot(app.status)}${capitalize(app.status)}</span></td>
          </tr>
        `).join('');

      } catch (err) {
        console.error('Error:', err);
        document.getElementById('applicationList').innerHTML = `
          <tr><td colspan="4" class="text-center text-danger py-4">Error loading applications.</td></tr>`;
      }

      // Fetch Recommendations
      try {
        const recResponse = await fetch('/api/recommendations');
        const recs = await recResponse.json();
        
        const recSection = document.getElementById('recommendationSection');
        const recList = document.getElementById('recommendationList');

        if (recs && recs.length > 0) {
          recSection.style.display = 'block';
          recList.innerHTML = recs.map(job => `
            <div class="col-12 col-md-6 col-lg-4" style="flex: 0 0 auto;">
              <div class="job-card-premium h-100 p-3" style="background:var(--white); border:1px solid var(--border); border-radius:var(--radius-lg); transition:all 0.3s ease; position:relative; overflow:hidden;">
                <div class="d-flex justify-content-between align-items-start mb-2">
                  <div class="match-badge" style="background:rgba(129,140,248,0.1); color:var(--primary); padding:4px 10px; border-radius:20px; font-size:0.75rem; font-weight:700;">
                    <i class="fas fa-bolt me-1"></i> ${job.match_score}% Match
                  </div>
                  <div style="font-size:0.85rem; font-weight:600; color:var(--dark);">${job.salary || 'Competitive'}</div>
                </div>
                <h3 style="font-size:1rem; font-weight:700; color:var(--dark); margin-bottom:0.25rem; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">${job.title}</h3>
                <div class="d-flex align-items-center gap-2 mb-3" style="font-size:0.85rem; color:var(--gray);">
                   <i class="fas fa-building" style="font-size:0.75rem;"></i> ${job.company}
                   <span class="mx-1">•</span>
                   <i class="fas fa-map-marker-alt" style="font-size:0.75rem;"></i> ${job.location}
                </div>
                <div class="matched-skills mb-3 d-flex flex-wrap gap-1">
                  ${job.matched_skills.map(skill => `<span style="font-size:0.65rem; background:#f3f4f6; color:#4b5563; padding:2px 8px; border-radius:4px; font-weight:500;">${skill}</span>`).join('')}
                </div>
                <button onclick="applyNow(${job.job_id})" class="btn btn-primary w-100 py-2 fw-bold" style="border-radius:10px; font-size:0.85rem;">Apply Now</button>
              </div>
            </div>
          `).join('');
        }
      } catch (err) {
        console.error('Error fetching recommendations:', err);
      }
    });

    async function applyNow(jobId) {
      if(!confirm('Apply for this job?')) return;
      try {
        const res = await fetch(`/api/seeker/apply/${jobId}`, { method: 'POST' });
        const data = await res.json();
        if(data.statusCount > 0 || data.success) { // match_score is returned but success is standard
          alert('Applied successfully!');
          window.location.reload();
        } else {
          alert(data.message || 'Error applying');
        }
      } catch (err) {
        console.error(err);
        alert('Failed to apply.');
      }
    }

    function getStatusPill(status) {
      const map = { shortlisted: 'pill pill-success', rejected: 'pill pill-danger', hold: 'pill pill-secondary', 'under process': 'pill pill-info' };
      return map[status] || 'pill pill-warning';
    }

    function getStatusDot(status) {
      return '<span class="pill-dot"></span>';
    }

    function capitalize(s) { return s.charAt(0).toUpperCase() + s.slice(1); }
  </script>
</body>

</html>