<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= title %> — Smart Job Portal
  </title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/chatbot.css?v=1.1">
</head>

<body class="dashboard-page">

  <!-- ===== NAVBAR ===== -->
  <nav class="navbar navbar-expand-lg navbar-premium">
    <div class="container-fluid px-4">
      <span class="navbar-brand">
        <i class="fas fa-briefcase me-2" style="color:#818cf8;"></i>SmartJobPortal
      </span>
      <div class="collapse navbar-collapse">
        <ul class="navbar-nav ms-auto align-items-center gap-1">
          <li class="nav-item"><a class="nav-link" href="/jobs"><i class="fas fa-search me-1"></i>Browse Jobs</a></li>
          <li class="nav-item"><a class="nav-link active" href="/seeker/dashboard"><i
                class="fas fa-th-large me-1"></i>My Applications</a></li>
          <li class="nav-item"><a class="nav-link" href="#" data-bs-toggle="offcanvas"
              data-bs-target="#profileOffcanvas"><i class="fas fa-user-circle me-1"></i>Profile</a></li>
          <li class="nav-item ms-2">
            <a class="btn-nav-danger" href="#" id="logoutLink"><i class="fas fa-sign-out-alt me-1"></i>Logout</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="dashboard-container px-3 py-3 px-md-4">
    <!-- Welcome Header -->
    <div class="dashboard-welcome-banner mb-3 p-3 px-4" style="background: linear-gradient(135deg, rgba(79, 70, 229, 0.08) 0%, rgba(6, 182, 212, 0.08) 100%); border-radius: 16px; border: 1px solid rgba(79, 70, 229, 0.15);">
      <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
        <div>
          <h1 class="fw-bold mb-1" style="font-size:1.4rem; color: var(--dark-2);">Welcome back, <%= profile.full_name || user.fullname %>! 👋</h1>
          <p class="mb-0 text-muted" style="font-size:0.85rem;">Here is what's happening with your job search today.</p>
        </div>
        <a href="/jobs" class="btn btn-primary-premium py-2 px-3" style="font-size: 0.85rem; border-radius: 8px;"><i class="fas fa-search me-2"></i>Find Jobs</a>
      </div>
    </div>

    <div class="row g-3">
      <div class="col-12">
        <!-- Stats Row -->
        <div class="row g-2 mb-3" id="statsRow">
          <div class="col-6 col-md-3">
            <div class="stat-card premium-stat-card">
              <div class="d-flex justify-content-between align-items-start">
                <div>
                  <div class="stat-value" id="statTotal">—</div>
                  <div class="stat-label">Total Applied</div>
                </div>
                <div class="stat-icon icon-purple"><i class="fas fa-paper-plane"></i></div>
              </div>
            </div>
          </div>
          <div class="col-6 col-md-3">
            <div class="stat-card premium-stat-card">
              <div class="d-flex justify-content-between align-items-start">
                <div>
                  <div class="stat-value text-success" id="statShortlisted">—</div>
                  <div class="stat-label">Shortlisted</div>
                </div>
                <div class="stat-icon icon-emerald"><i class="fas fa-check-circle"></i></div>
              </div>
            </div>
          </div>
          <div class="col-6 col-md-3">
            <div class="stat-card premium-stat-card">
              <div class="d-flex justify-content-between align-items-start">
                <div>
                  <div class="stat-value text-primary" id="statProcessing">—</div>
                  <div class="stat-label">In Process</div>
                </div>
                <div class="stat-icon icon-cyan"><i class="fas fa-hourglass-half"></i></div>
              </div>
            </div>
          </div>
          <div class="col-6 col-md-3">
            <div class="stat-card premium-stat-card">
              <div class="d-flex justify-content-between align-items-start">
                <div>
                  <div class="stat-value text-warning" id="statPending">—</div>
                  <div class="stat-label">Pending</div>
                </div>
                <div class="stat-icon icon-amber"><i class="fas fa-clock"></i></div>
              </div>
            </div>
          </div>
        </div>



        <!-- Applications Table -->
        <div class="main-card border-0 shadow-sm" style="border-radius: 16px;">
          <div class="main-card-header bg-white py-3 px-3 d-flex justify-content-between align-items-center">
            <h2 class="page-title" style="font-size:1.1rem; margin:0;"><i class="fas fa-list-ul me-2 text-primary"></i>My Applications</h2>
            <span class="status-badge status-checking" id="appCount" style="padding: 0.3rem 0.75rem;">Loading...</span>
          </div>
          <div class="table-responsive bg-white" style="border-radius: 0 0 16px 16px;">
            <table class="app-table table-hover mb-0 w-100">
              <thead class="bg-light">
                <tr>
                  <th style="font-size:0.75rem; padding: 0.75rem 1rem;">Job Details</th>
                  <th style="font-size:0.75rem; padding: 0.75rem 1rem;">Company</th>
                  <th style="font-size:0.75rem; padding: 0.75rem 1rem;">Applied Date</th>
                  <th style="font-size:0.75rem; padding: 0.75rem 1rem;">Status</th>
                </tr>
              </thead>
              <tbody id="applicationList">
                <tr>
                  <td colspan="4" class="text-center py-4">
                    <div class="loading-overlay d-flex flex-column align-items-center justify-content-center">
                      <div class="spinner-border text-primary mb-2" role="status"></div>
                      <span class="text-muted" style="font-size:0.85rem;">Loading applications...</span>
                    </div>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ===== PROFILE OFFCANVAS ===== -->
  <div class="offcanvas offcanvas-end" tabindex="-1" id="profileOffcanvas" aria-labelledby="profileOffcanvasLabel"
    style="width: 350px;">
    <div class="offcanvas-header bg-light border-bottom p-3">
      <h5 class="offcanvas-title fw-bold" id="profileOffcanvasLabel" style="font-size:1.15rem;"><i
          class="fas fa-user-circle me-2 text-primary"></i>My Profile</h5>
      <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body p-4 bg-light">
      <div class="sidebar-card m-0 w-100 shadow-none border-0" style="background:transparent;">
        <div class="sidebar-header pb-3 mb-3 border-bottom">
          <div class="avatar-circle mx-auto mb-3" style="width:70px;height:70px;font-size:2rem;">
            <i class="fas fa-user"></i>
          </div>
          <div class="sidebar-name fs-5">
            <%= profile.full_name || user.fullname %>
          </div>
          <div class="sidebar-email text-muted">
            <%= profile.email || user.email %>
          </div>
          <div class="mt-3">
            <span class="status-badge status-approved px-3 py-2">
              <i class="fas fa-check-circle" style="font-size:0.8rem;"></i> Verified Seeker
            </span>
          </div>
        </div>
        <div class="sidebar-body px-0">
          <div class="sidebar-info-row flex-column gap-3 mb-4">
            <div class="sidebar-info-item w-100">
              <div class="sidebar-info-icon icon-purple">
                <i class="fas fa-briefcase"></i>
              </div>
              <div>
                <div
                  style="font-size:0.75rem;color:var(--gray);text-transform:uppercase;letter-spacing:0.05em;font-weight:600;margin-bottom:0.15rem;">
                  Current Role</div>
                <div style="font-size:0.95rem;color:var(--dark);font-weight:600;">
                  <%= profile.current_job_title || 'N/A' %>
                </div>
              </div>
            </div>
            <div class="sidebar-info-item w-100">
              <div class="sidebar-info-icon icon-cyan">
                <i class="fas fa-history"></i>
              </div>
              <div>
                <div
                  style="font-size:0.75rem;color:var(--gray);text-transform:uppercase;letter-spacing:0.05em;font-weight:600;margin-bottom:0.15rem;">
                  Experience</div>
                <div style="font-size:0.95rem;color:var(--dark);font-weight:600;">
                  <%= profile.total_experience_years || '0' %>y <%= profile.total_experience_months || '0' %>m
                </div>
              </div>
            </div>
            <div class="sidebar-info-item w-100">
              <div class="sidebar-info-icon icon-amber">
                <i class="fas fa-map-marker-alt"></i>
              </div>
              <div>
                <div
                  style="font-size:0.75rem;color:var(--gray);text-transform:uppercase;letter-spacing:0.05em;font-weight:600;margin-bottom:0.15rem;">
                  Location</div>
                <div style="font-size:0.95rem;color:var(--dark);font-weight:600;">
                  <%= profile.location || 'Not set' %>
                </div>
              </div>
            </div>
          </div>

          <div class="mt-2 d-grid gap-2">
            <a href="/seeker/profile-setup" class="btn btn-primary w-100 fw-bold py-2 btn-lg"
              style="border-radius:10px;font-size:0.95rem;">
              <i class="fas fa-user-edit me-2"></i>Edit My Profile
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ===== AI CAREER MENTOR CHATBOT ===== -->
  <button id="chatbot-toggle-btn" class="chatbot-toggle-btn">
    <i class="fas fa-robot"></i> Ask Career Mentor
  </button>

  <div id="chatbot-container" class="chatbot-container d-none">
    <div class="chatbot-header">
      <div class="d-flex align-items-center gap-2">
        <div class="chatbot-avatar"><i class="fas fa-robot"></i></div>
        <div>
          <h5 class="mb-0 text-white" style="font-size:1rem;font-weight:600;">AI Mentor</h5>
          <small style="color:rgba(255,255,255,0.8);font-size:0.75rem;">Online</small>
        </div>
      </div>
      <button id="chatbot-close-btn" class="btn-close btn-close-white"></button>
    </div>

    <div class="chatbot-messages" id="chatbot-messages">
      <div class="message bot-message">
        Hi there! I'm your AI Career Mentor. I've reviewed your profile and I'm ready to help. What would you like to
        know?
      </div>
    </div>

    <div class="chatbot-suggestions">
      <button class="chat-suggestion-btn">What skills should I learn?</button>
      <button class="chat-suggestion-btn">Am I ready for my desired role?</button>
      <button class="chat-suggestion-btn">Improve my resume</button>
    </div>

    <div class="chatbot-input-area">
      <input type="text" id="chatbot-input" placeholder="Type your message..." autocomplete="off">
      <button id="chatbot-send-btn"><i class="fas fa-paper-plane"></i></button>
    </div>
  </div>

  <!-- ===== LOGOUT MODAL ===== -->
  <div class="modal fade modal-premium" id="logoutModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header header-danger border-0">
          <h5 class="modal-title fw-bold text-white"><i class="fas fa-sign-out-alt me-2"></i>Confirm Logout</h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body text-center py-4">
          <div
            style="width:70px;height:70px;background:rgba(239,68,68,0.1);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1.25rem;font-size:1.75rem;color:#ef4444;">
            <i class="fas fa-exclamation-triangle"></i>
          </div>
          <h5 class="fw-bold mb-2">Are you sure?</h5>
          <p class="text-muted mb-0" style="font-size:0.9rem;">You will be signed out of your session.</p>
        </div>
        <div class="modal-footer justify-content-center border-0 bg-white pb-4">
          <button class="btn btn-light px-4 fw-bold" data-bs-dismiss="modal">Cancel</button>
          <a href="/api/auth/logout" class="btn btn-danger px-4 fw-bold">
            <i class="fas fa-sign-out-alt me-2"></i>Logout Now
          </a>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/apiService.js"></script>
  <script src="/js/chatbot.js?v=1.1"></script>
  <script>
    // Logout
    document.getElementById('logoutLink').addEventListener('click', function (e) {
      e.preventDefault();
      new bootstrap.Modal(document.getElementById('logoutModal')).show();
    });

    // BFCache prevention
    window.addEventListener('pageshow', (e) => { if (e.persisted) window.location.reload(); });

    document.addEventListener('DOMContentLoaded', async () => {
      try {
        const response = await fetch('/api/seeker/my-applications');
        const apps = await response.json();

        const appList = document.getElementById('applicationList');
        const appCount = document.getElementById('appCount');

        // Stats
        const shortlisted = apps.filter(a => a.status === 'shortlisted').length;
        const processing = apps.filter(a => a.status === 'under process').length;
        const pending = apps.filter(a => a.status === 'pending').length;

        document.getElementById('statTotal').textContent = apps.length;
        document.getElementById('statShortlisted').textContent = shortlisted;
        document.getElementById('statProcessing').textContent = processing;
        document.getElementById('statPending').textContent = pending;

        appCount.textContent = `${apps.length} Application${apps.length !== 1 ? 's' : ''}`;
        appCount.className = 'status-badge status-checking';

        if (apps.length === 0) {
          appList.innerHTML = `
            <tr><td colspan="4">
              <div class="empty-state">
                <div class="empty-state-icon"><i class="fas fa-briefcase"></i></div>
                <div class="empty-state-title">No Applications Yet</div>
                <div class="empty-state-text">Start applying to jobs and your applications will appear here.</div>
                <a href="/jobs" class="btn btn-primary mt-3 fw-bold" style="border-radius:10px;">Browse Jobs</a>
              </div>
            </td></tr>`;
          return;
        }

        appList.innerHTML = apps.map(app => `
          <tr style="cursor: pointer; transition: background 0.2s;">
            <td style="padding: 0.85rem 1rem;">
              <div class="fw-bold" style="color:var(--dark);font-size:0.9rem;">${app.job_title}</div>
            </td>
            <td style="padding: 0.85rem 1rem;">
              <div class="d-flex align-items-center gap-2">
                <div style="width:24px;height:24px;background:rgba(79,70,229,0.08);border-radius:4px;display:flex;align-items:center;justify-content:center;color:var(--primary);font-size:0.65rem;flex-shrink:0;">
                  <i class="fas fa-building"></i>
                </div>
                <span style="font-size:0.85rem;">${app.company_name}</span>
              </div>
            </td>
            <td style="font-size:0.8rem;color:var(--gray); padding: 0.85rem 1rem;">${new Date(app.applied_at).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' })}</td>
            <td style="padding: 0.85rem 1rem;"><span class="${getStatusPill(app.status)} px-2 py-1" style="font-size:0.7rem; border-radius:12px;">${getStatusDot(app.status)}${capitalize(app.status)}</span></td>
          </tr>
        `).join('');

      } catch (err) {
        console.error('Error:', err);
        document.getElementById('applicationList').innerHTML = `
          <tr><td colspan="4" class="text-center text-danger py-4">Error loading applications.</td></tr>`;
      }


    });

    async function applyNow(jobId) {
      if (!confirm('Apply for this job?')) return;
      try {
        const res = await fetch(`/api/seeker/apply/${jobId}`, { method: 'POST' });
        const data = await res.json();
        if (data.success) {
          alert('Applied successfully!');
          if (data.redirectTo) {
            window.location.href = data.redirectTo;
          } else {
            window.location.reload();
          }
        } else {
          alert(data.message || 'Error applying');
        }
      } catch (err) {
        console.error(err);
        alert('Failed to apply.');
      }
    }

    function getStatusPill(status) {
      const map = { shortlisted: 'pill pill-success', rejected: 'pill pill-danger', hold: 'pill pill-secondary', 'under process': 'pill pill-info' };
      return map[status] || 'pill pill-warning';
    }

    function getStatusDot(status) {
      return '<span class="pill-dot"></span>';
    }

    function capitalize(s) { return s.charAt(0).toUpperCase() + s.slice(1); }
  </script>
</body>

</html>