<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — Smart Job Portal</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="dashboard-page">

  <!-- ===== NAVBAR ===== -->
  <nav class="navbar navbar-expand-lg navbar-premium">
    <div class="container">
      <span class="navbar-brand">
        <i class="fas fa-briefcase me-2" style="color:#818cf8;"></i>SmartJobPortal
      </span>
      <div class="ms-auto">
        <a href="/api/auth/logout" class="btn-nav-danger">
          <i class="fas fa-sign-out-alt me-1"></i>Logout
        </a>
      </div>
    </div>
  </nav>

  <div class="dashboard-container" style="max-width:860px;">
    <!-- Step indicator -->
    <div class="text-center mb-4">
      <div class="section-label mx-auto" style="display:inline-flex;">
        <i class="fas fa-shield-alt me-1"></i> Recruiter Verification
      </div>
      <h1 class="page-title mt-2" style="font-size:2rem;">Complete Your Company Profile</h1>
      <p style="color:var(--gray);font-size:0.9rem;margin-top:0.5rem;">Provide accurate company details for admin verification. You can post jobs once approved.</p>
    </div>

    <!-- Progress Steps -->
    <div class="d-flex align-items-center justify-content-center gap-2 mb-5 flex-wrap">
      <div class="d-flex align-items-center gap-2">
        <div style="width:32px;height:32px;background:var(--primary);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:0.8rem;font-weight:700;">1</div>
        <span style="font-size:0.82rem;font-weight:600;color:var(--primary);">Company Info</span>
      </div>
      <div style="width:40px;height:2px;background:var(--border);"></div>
      <div class="d-flex align-items-center gap-2">
        <div style="width:32px;height:32px;background:var(--border);color:var(--gray);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:0.8rem;font-weight:700;">2</div>
        <span style="font-size:0.82rem;font-weight:600;color:var(--gray);">Address</span>
      </div>
      <div style="width:40px;height:2px;background:var(--border);"></div>
      <div class="d-flex align-items-center gap-2">
        <div style="width:32px;height:32px;background:var(--border);color:var(--gray);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:0.8rem;font-weight:700;">3</div>
        <span style="font-size:0.82rem;font-weight:600;color:var(--gray);">Personal Info</span>
      </div>
      <div style="width:40px;height:2px;background:var(--border);"></div>
      <div class="d-flex align-items-center gap-2">
        <div style="width:32px;height:32px;background:var(--border);color:var(--gray);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:0.8rem;font-weight:700;">4</div>
        <span style="font-size:0.82rem;font-weight:600;color:var(--gray);">Documents</span>
      </div>
    </div>

    <form id="recruiterDetailsForm" enctype="multipart/form-data">

      <!-- Section 1: Company Info -->
      <div class="form-section-card">
        <div class="form-section-title">
          <span class="section-icon"><i class="fas fa-building"></i></span>
          1. Company Information
        </div>
        <div class="row g-3">
          <div class="col-md-6">
            <label class="form-label fw-bold" style="font-size:0.85rem;">Company Name <span class="text-danger">*</span></label>
            <input type="text" class="form-control" name="company_name" required placeholder="Acme Corp" style="padding:0.75rem;">
          </div>
          <div class="col-md-6">
            <label class="form-label fw-bold" style="font-size:0.85rem;">Official Company Email <span class="text-danger">*</span></label>
            <input type="email" class="form-control" name="company_email" placeholder="hr@company.com" required style="padding:0.75rem;">
          </div>
          <div class="col-md-6">
            <label class="form-label fw-bold" style="font-size:0.85rem;">Company Website</label>
            <input type="url" class="form-control" name="company_website" placeholder="https://company.com" style="padding:0.75rem;">
          </div>
          <div class="col-md-6">
            <label class="form-label fw-bold" style="font-size:0.85rem;">Industry <span class="text-danger">*</span></label>
            <select class="form-select" name="industry" required style="padding:0.75rem;">
              <option value="">Select Industry</option>
              <option value="IT">Information Technology</option>
              <option value="Finance">Finance & Banking</option>
              <option value="Healthcare">Healthcare</option>
              <option value="Education">Education</option>
              <option value="Manufacturing">Manufacturing</option>
              <option value="Retail">Retail & E-commerce</option>
              <option value="Consulting">Consulting</option>
              <option value="Other">Other</option>
            </select>
          </div>
          <div class="col-12">
            <label class="form-label fw-bold" style="font-size:0.85rem;">Company Description</label>
            <textarea class="form-control" name="company_description" rows="3" style="padding:0.75rem;"
              placeholder="Brief overview of your company, culture, and what you do..."></textarea>
          </div>
        </div>
      </div>

      <!-- Section 2: Address -->
      <div class="form-section-card">
        <div class="form-section-title">
          <span class="section-icon"><i class="fas fa-map-marker-alt"></i></span>
          2. Company Address
        </div>
        <div class="row g-3">
          <div class="col-12">
            <label class="form-label fw-bold" style="font-size:0.85rem;">Address Line <span class="text-danger">*</span></label>
            <input type="text" class="form-control" name="address_line" required placeholder="Building/Street/Area" style="padding:0.75rem;">
          </div>
          <div class="col-md-6">
            <label class="form-label fw-bold" style="font-size:0.85rem;">City <span class="text-danger">*</span></label>
            <input type="text" class="form-control" name="city" required placeholder="Mumbai" style="padding:0.75rem;">
          </div>
          <div class="col-md-6">
            <label class="form-label fw-bold" style="font-size:0.85rem;">State <span class="text-danger">*</span></label>
            <input type="text" class="form-control" name="state" required placeholder="Maharashtra" style="padding:0.75rem;">
          </div>
          <div class="col-md-6">
            <label class="form-label fw-bold" style="font-size:0.85rem;">Country <span class="text-danger">*</span></label>
            <input type="text" class="form-control" name="country" required placeholder="India" style="padding:0.75rem;">
          </div>
          <div class="col-md-6">
            <label class="form-label fw-bold" style="font-size:0.85rem;">Pincode <span class="text-danger">*</span></label>
            <input type="text" class="form-control" name="pincode" required placeholder="400001" style="padding:0.75rem;">
          </div>
        </div>
      </div>

      <!-- Section 3: Personal Info -->
      <div class="form-section-card">
        <div class="form-section-title">
          <span class="section-icon"><i class="fas fa-user-tie"></i></span>
          3. Recruiter Personal Info
        </div>
        <div class="row g-3">
          <div class="col-md-6">
            <label class="form-label fw-bold" style="font-size:0.85rem;">Full Name <span class="text-danger">*</span></label>
            <input type="text" class="form-control" name="full_name" required placeholder="John Doe" style="padding:0.75rem;">
          </div>
          <div class="col-md-6">
            <label class="form-label fw-bold" style="font-size:0.85rem;">Contact Number <span class="text-danger">*</span></label>
            <input type="tel" class="form-control" name="contact_number" required placeholder="+91 9876543210" style="padding:0.75rem;">
          </div>
          <div class="col-12">
            <label class="form-label fw-bold" style="font-size:0.85rem;">Your Designation <span class="text-danger">*</span></label>
            <input type="text" class="form-control" name="designation" required placeholder="e.g. HR Manager, Talent Acquisition Lead" style="padding:0.75rem;">
          </div>
        </div>
      </div>

      <!-- Section 4: Documents -->
      <div class="form-section-card">
        <div class="form-section-title">
          <span class="section-icon"><i class="fas fa-file-invoice"></i></span>
          4. Verification Documents
        </div>

        <!-- Registration Cert -->
        <div class="mb-4 p-3" style="background:var(--bg);border-radius:12px;border:1px solid var(--border);">
          <div class="d-flex align-items-center gap-2 mb-3">
            <div style="width:28px;height:28px;background:rgba(79,70,229,0.1);border-radius:8px;display:flex;align-items:center;justify-content:center;color:var(--primary);font-size:0.8rem;">
              <i class="fas fa-certificate"></i>
            </div>
            <span class="fw-bold" style="font-size:0.9rem;">Company Registration Certificate <span class="text-danger">*</span></span>
          </div>
          <div class="row g-3">
            <div class="col-md-6">
              <input type="text" class="form-control" name="registration_cert_no" placeholder="Certificate Number" required style="padding:0.75rem;">
            </div>
            <div class="col-md-6">
              <input type="file" class="form-control" name="registration_cert" accept=".pdf,.jpg,.jpeg,.png" required style="padding:0.6rem;">
            </div>
          </div>
        </div>

        <!-- GST -->
        <div class="mb-4 p-3" style="background:var(--bg);border-radius:12px;border:1px solid var(--border);">
          <div class="d-flex align-items-center gap-2 mb-3">
            <div style="width:28px;height:28px;background:rgba(6,182,212,0.1);border-radius:8px;display:flex;align-items:center;justify-content:center;color:#06b6d4;font-size:0.8rem;">
              <i class="fas fa-receipt"></i>
            </div>
            <span class="fw-bold" style="font-size:0.9rem;">GST Number <span style="color:var(--gray);font-weight:400;">(Optional)</span></span>
          </div>
          <div class="row g-3">
            <div class="col-md-6">
              <input type="text" class="form-control" name="gst_number" placeholder="GSTN Number" style="padding:0.75rem;">
            </div>
            <div class="col-md-6">
              <input type="file" class="form-control" name="gst_doc" accept=".pdf,.jpg,.jpeg,.png" style="padding:0.6rem;">
            </div>
          </div>
        </div>

        <!-- PAN -->
        <div class="p-3" style="background:var(--bg);border-radius:12px;border:1px solid var(--border);">
          <div class="d-flex align-items-center gap-2 mb-3">
            <div style="width:28px;height:28px;background:rgba(245,158,11,0.1);border-radius:8px;display:flex;align-items:center;justify-content:center;color:#f59e0b;font-size:0.8rem;">
              <i class="fas fa-id-card"></i>
            </div>
            <span class="fw-bold" style="font-size:0.9rem;">PAN Card <span class="text-danger">*</span></span>
          </div>
          <div class="row g-3">
            <div class="col-md-6">
              <input type="text" class="form-control" name="pan_number" placeholder="PAN Number" required style="padding:0.75rem;">
            </div>
            <div class="col-md-6">
              <input type="file" class="form-control" name="pan_doc" accept=".pdf,.jpg,.jpeg,.png" required style="padding:0.6rem;">
            </div>
          </div>
        </div>
      </div>

      <!-- Section 5: Additional Info -->
      <div class="form-section-card">
        <div class="form-section-title">
          <span class="section-icon"><i class="fas fa-chart-bar"></i></span>
          5. Additional Company Info
        </div>
        <div class="row g-3">
          <div class="col-md-6">
            <label class="form-label fw-bold" style="font-size:0.85rem;">Company Size</label>
            <select class="form-select" name="company_size" style="padding:0.75rem;">
              <option value="1-10">1–10 Employees</option>
              <option value="10-50">10–50 Employees</option>
              <option value="50-200">50–200 Employees</option>
              <option value="200-500">200–500 Employees</option>
              <option value="500+">500+ Employees</option>
            </select>
          </div>
          <div class="col-md-6">
            <label class="form-label fw-bold" style="font-size:0.85rem;">Years in Business</label>
            <input type="number" class="form-control" name="years_in_business" placeholder="e.g. 5" min="0" style="padding:0.75rem;">
          </div>
          <div class="col-12">
            <label class="form-label fw-bold" style="font-size:0.85rem;">LinkedIn Company Page</label>
            <input type="url" class="form-control" name="linkedin_profile" placeholder="https://linkedin.com/company/..." style="padding:0.75rem;">
          </div>
        </div>
      </div>

      <!-- Submit -->
      <div class="d-grid mb-5">
        <button type="submit" class="btn-submit-premium" id="submitBtn">
          Submit for Verification <i class="fas fa-arrow-right ms-2"></i>
        </button>
        <p class="text-center mt-3" style="font-size:0.8rem;color:var(--gray);">
          <i class="fas fa-shield-alt me-1"></i>Your documents are securely stored and only accessible to admin.
        </p>
      </div>

    </form>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    document.getElementById('recruiterDetailsForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const userId = sessionStorage.getItem('pendingRecruiterId');
      if (!userId) {
        alert('Session expired or invalid. Please register again.');
        window.location.href = '/register';
        return;
      }
      const formData = new FormData(e.target);
      formData.append('user_id', userId);

      const btn = document.getElementById('submitBtn');
      btn.disabled = true;
      btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Submitting...';

      try {
        const res = await fetch('/api/recruiter/register-details', { method: 'POST', body: formData });
        const result = await res.json();
        if (res.ok) {
          sessionStorage.removeItem('pendingRecruiterId');
          document.body.innerHTML = `
            <div style="min-height:100vh;background:linear-gradient(135deg,#0f172a,#1e293b);display:flex;align-items:center;justify-content:center;padding:2rem;">
              <div style="background:#fff;border-radius:24px;padding:3.5rem;max-width:480px;width:100%;text-align:center;box-shadow:0 20px 60px rgba(0,0,0,0.25);">
                <div style="width:80px;height:80px;background:rgba(16,185,129,0.1);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1.5rem;font-size:2.25rem;color:#10b981;">
                  <i class="fas fa-check-circle"></i>
                </div>
                <h2 style="font-family:Inter,sans-serif;font-weight:800;font-size:1.75rem;color:#0f172a;margin-bottom:0.75rem;">Submission Successful!</h2>
                <p style="color:#64748b;font-size:0.95rem;margin-bottom:2rem;">${result.message}</p>
                <a href="/login" style="display:inline-block;background:linear-gradient(135deg,#4f46e5,#3730a3);color:#fff;padding:0.85rem 2.5rem;border-radius:12px;font-family:Inter,sans-serif;font-weight:700;text-decoration:none;">
                  <i class="fas fa-sign-in-alt" style="margin-right:0.5rem;"></i>Back to Login
                </a>
              </div>
            </div>`;
        } else {
          alert('Submission failed: ' + (result.message || 'Unknown error'));
          btn.disabled = false;
          btn.innerHTML = 'Submit for Verification <i class="fas fa-arrow-right ms-2"></i>';
        }
      } catch (err) {
        alert('An error occurred.');
        btn.disabled = false;
        btn.innerHTML = 'Submit for Verification <i class="fas fa-arrow-right ms-2"></i>';
      }
    });
  </script>
</body>
</html>
