<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — Smart Job Portal</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
    <link rel="icon" type="image/png" href="/uploads/image.png">
</head>
<body class="dashboard-page">

  <!-- ===== NAVBAR ===== -->
  <nav class="navbar navbar-expand-lg navbar-premium">
    <div class="container-fluid px-4">
      <a class="navbar-brand" href="/recruiter/dashboard">
        <i class="fas fa-briefcase me-2" style="color:#818cf8;"></i>SmartJobPortal
      </a>
      <div class="collapse navbar-collapse">
        <ul class="navbar-nav ms-auto align-items-center gap-1">
          <li class="nav-item"><a class="nav-link" href="/recruiter/dashboard"><i class="fas fa-th-large me-1"></i>Dashboard</a></li>
          <li class="nav-item"><a class="nav-link" href="/recruiter/applications"><i class="fas fa-users me-1"></i>All Applications</a></li>
          <li class="nav-item"><a class="nav-link" href="/recruiter/my-jobs"><i class="fas fa-list me-1"></i>Posted Jobs</a></li>
          <li class="nav-item ms-2">
            <a class="btn-nav-danger" href="#" id="logoutLink"><i class="fas fa-sign-out-alt me-1"></i>Logout</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="dashboard-container">
    <!-- Back Button -->
    <div class="mb-3">
        <a href="/recruiter/my-jobs" class="text-primary text-decoration-none fw-bold" style="font-size:0.9rem;">
          <i class="fas fa-arrow-left me-1"></i> Back to Posted Jobs
        </a>
    </div>

    <!-- Page header + Filters + Search -->
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3 mb-4">
      <div>
        <h1 class="page-title" style="font-size:1.6rem; margin:0;">Applicants for <%= job.title %></h1>
        <p style="color:var(--gray);font-size:0.8rem;margin:0;">Job ID: <%= job.job_id %> | <%= job.location %></p>
      </div>

      <div class="d-flex align-items-center gap-3 flex-wrap">
        <!-- Status Filters -->
        <div class="d-flex flex-wrap gap-2">
          <label class="filter-btn active" for="filterAll">
            <input type="radio" name="statusFilter" id="filterAll" value="all" checked style="display:none;">
            All
          </label>
          <label class="filter-btn" for="filterPending">
            <input type="radio" name="statusFilter" id="filterPending" value="pending" style="display:none;">
            Pending
          </label>
          <label class="filter-btn" for="filterShortlisted">
            <input type="radio" name="statusFilter" id="filterShortlisted" value="shortlisted" style="display:none;">
            Shortlisted
          </label>
          <label class="filter-btn" for="filterProcess">
            <input type="radio" name="statusFilter" id="filterProcess" value="under process" style="display:none;">
            Processing
          </label>
          <label class="filter-btn" for="filterHold">
            <input type="radio" name="statusFilter" id="filterHold" value="hold" style="display:none;">
            Hold
          </label>
          <label class="filter-btn" for="filterRejected">
            <input type="radio" name="statusFilter" id="filterRejected" value="rejected" style="display:none;">
            Rejected
          </label>
        </div>

        <!-- Search -->
        <div class="search-bar" style="width:240px; margin:0;">
          <i class="fas fa-search search-bar-icon"></i>
          <input type="text" id="searchInput" placeholder="Search applicants...">
        </div>
      </div>
    </div>

    <!-- Applications Table -->
    <div class="main-card">
      <div class="table-responsive">
        <table class="app-table w-100">
          <thead>
            <tr>
              <th>Applicant</th>
              <th>Applied Date</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="jobApplicationsList">
            <tr>
              <td colspan="4">
                <div class="loading-overlay">
                  <div class="spinner-border spinner-border-sm text-primary"></div>
                  <span>Loading applications...</span>
                </div>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- ===== PROFILE MODAL ===== -->
  <div class="modal fade modal-premium" id="profileModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
      <div class="modal-content">
        <div class="modal-header header-primary border-0">
          <h5 class="modal-title fw-bold text-white"><i class="fas fa-id-card me-2"></i>Applicant Profile</h5>
          <button class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body p-4">
            <!-- Modal content dynamically loaded here -->
        </div>
        <div class="modal-footer border-top d-flex justify-content-between align-items-center bg-white p-3">
          <a id="profResumeLink" href="#" target="_blank" class="btn btn-primary fw-bold px-4" style="border-radius:50px;">
            <i class="fas fa-file-pdf me-2"></i>Download Resume
          </a>
          <button class="btn btn-light fw-bold px-4" data-bs-dismiss="modal">Close</button>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script src="/js/apiService.js"></script>

  <style>
    .filter-btn {
      display: inline-flex;
      align-items: center;
      padding: 0.4rem 0.9rem;
      border-radius: 50px;
      font-size: 0.8rem;
      font-weight: 600;
      cursor: pointer;
      border: 1.5px solid var(--border);
      color: var(--gray);
      background: var(--white);
      transition: var(--transition);
      user-select: none;
    }
    .filter-btn:hover { border-color: var(--primary); color: var(--primary); }
    .filter-btn.active { background: var(--primary); color: #fff; border-color: var(--primary); }

    .section-label-sm {
      font-size: 0.72rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--gray);
      margin-bottom: 0.6rem;
      border-bottom: 1.5px solid var(--border);
      padding-bottom: 4px;
      display: inline-block;
    }
  </style>

  <script>
    const jobId = "<%= job.id %>";

    document.getElementById('logoutLink').addEventListener('click', function(e) {
      e.preventDefault();
      Swal.fire({
        title: 'Confirm Logout',
        text: 'Are you sure you want to log out?',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#ef4444',
        cancelButtonColor: '#64748b',
        confirmButtonText: 'Yes, logout'
      }).then((result) => {
        if (result.isConfirmed) {
          window.location.href = '/api/auth/logout';
        }
      });
    });

    window.addEventListener('pageshow', (e) => { if (e.persisted) window.location.reload(); });

    // Filter logic
    document.querySelectorAll('input[name="statusFilter"]').forEach(radio => {
      radio.addEventListener('change', function() {
        document.querySelectorAll('.filter-btn').forEach(l => l.classList.remove('active'));
        this.parentElement.classList.add('active');
        applyFilters();
      });
    });

    document.getElementById('searchInput').addEventListener('input', applyFilters);

    function showNotification(title, message, type = 'success', callback = null) {
      Swal.fire({
        title: title,
        text: message,
        icon: type,
        confirmButtonColor: '#4f46e5'
      }).then(() => { if (callback) callback(); });
    }

    function showConfirm(title, message, onConfirm) {
      Swal.fire({
        title: title,
        text: message,
        icon: 'question',
        showCancelButton: true,
        confirmButtonColor: '#4f46e5',
        cancelButtonColor: '#64748b',
        confirmButtonText: 'Confirm'
      }).then((result) => { if (result.isConfirmed) onConfirm(); });
    }

    let allApplicants = [];

    async function loadApplicants() {
      try {
        allApplicants = await window.apiService.getJobApplicants(jobId);
        renderApplicants(allApplicants);
      } catch (err) {
        console.error('Error:', err);
        document.getElementById('jobApplicationsList').innerHTML = '<tr><td colspan="4" class="text-center text-danger py-4">Error loading applicants.</td></tr>';
      }
    }

    function renderApplicants(apps) {
      const list = document.getElementById('jobApplicationsList');
      if (!apps || apps.length === 0) {
        list.innerHTML = `<tr><td colspan="4">
          <div class="empty-state">
            <div class="empty-state-icon"><i class="fas fa-inbox"></i></div>
            <div class="empty-state-title">No Applicants Yet</div>
            <div class="empty-state-text">No one has applied for this job listing yet.</div>
          </div>
        </td></tr>`;
        return;
      }
      list.innerHTML = apps.map(app => `
        <tr>
          <td>
            <div class="d-flex align-items-center gap-3">
              <div style="width:38px;height:38px;background:rgba(79,70,229,0.1);border-radius:50%;display:flex;align-items:center;justify-content:center;color:var(--primary);flex-shrink:0;">
                <i class="fas fa-user" style="font-size:0.85rem;"></i>
              </div>
              <div>
                <div class="fw-bold" style="font-size:0.875rem;color:var(--dark);">${app.seeker_name}</div>
                <div style="font-size:0.78rem;color:var(--gray);">${app.seeker_email}</div>
              </div>
            </div>
          </td>
          <td style="font-size:0.82rem;color:var(--gray);">${new Date(app.applied_at).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'})}</td>
          <td><span class="${getStatusPill(app.status)}"><span class="pill-dot"></span>${capitalize(app.status)}</span></td>
          <td>
            <div class="d-flex gap-2">
              <button class="btn btn-sm fw-bold" onclick="viewProfile(${app.id})"
                style="background:rgba(79,70,229,0.08);color:var(--primary);border:1px solid rgba(79,70,229,0.2);border-radius:8px;font-size:0.8rem;padding:0.3rem 0.75rem;">
                <i class="fas fa-eye me-1"></i>Profile
              </button>
              ${(app.status !== 'shortlisted' && app.status !== 'rejected') ? `
              <div class="dropdown">
                <button class="btn btn-sm dropdown-toggle fw-bold"
                  style="background:var(--bg);color:var(--gray);border:1px solid var(--border);border-radius:8px;font-size:0.8rem;padding:0.3rem 0.75rem;"
                  type="button" data-bs-toggle="dropdown">
                  Action
                </button>
                <ul class="dropdown-menu shadow border-0 mt-1" style="border-radius:12px;font-size:0.875rem;">
                  <li><a class="dropdown-item py-2 fw-medium text-success" href="#" onclick="updateStatus(${app.id},'shortlisted')"><i class="fas fa-check me-2"></i>Shortlist</a></li>
                  <li><a class="dropdown-item py-2 fw-medium text-info" href="#" onclick="updateStatus(${app.id},'under process')"><i class="fas fa-spinner me-2"></i>Under Process</a></li>
                  <li><a class="dropdown-item py-2 fw-medium text-secondary" href="#" onclick="updateStatus(${app.id},'hold')"><i class="fas fa-pause me-2"></i>On Hold</a></li>
                  <li><hr class="dropdown-divider"></li>
                  <li><a class="dropdown-item py-2 fw-medium text-danger" href="#" onclick="updateStatus(${app.id},'rejected')"><i class="fas fa-times me-2"></i>Reject</a></li>
                </ul>
              </div>
              ` : ''}
            </div>
          </td>
        </tr>
      `).join('');
    }

    async function viewProfile(appId) {
      const app = allApplicants.find(a => a.id === appId);
      if (!app) return;
      
      const modalEl = document.getElementById('profileModal');
      const modalBody = modalEl.querySelector('.modal-body');
      
      modalBody.innerHTML = '<div class="text-center py-5"><div class="spinner-border text-primary"></div><p class="mt-2">Fetching full profile...</p></div>';
      new bootstrap.Modal(modalEl).show();

      try {
        const response = await fetch(`/api/recruiter/seeker-profile/${app.seeker_id}`);
        const data = await response.json();
        
        if (!data.success || !data.profile) {
          modalBody.innerHTML = '<div class="alert alert-warning">' + (data.message || 'Could not fetch full profile details.') + '</div>';
          return;
        }

        const p = data.profile;
        let html = `
          <div class="row g-4">
            <div class="col-md-4 border-end">
              <div class="text-center mb-4">
                <div style="width:100px;height:100px;background:rgba(79,70,229,0.1);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;font-size:3rem;color:var(--primary);">
                  <i class="fas fa-user"></i>
                </div>
                <h4 class="fw-bold mb-1">${p.full_name || app.seeker_name}</h4>
                <p class="text-muted mb-3">${p.current_job_title || 'Job Seeker'}</p>
                <div class="d-flex flex-column gap-2 text-start px-3">
                  <div style="font-size:0.85rem;"><i class="fas fa-envelope me-2 text-primary"></i>${p.email}</div>
                  <div style="font-size:0.85rem;"><i class="fas fa-phone me-2 text-primary"></i>${p.phone || 'N/A'}</div>
                  <div style="font-size:0.85rem;"><i class="fas fa-map-marker-alt me-2 text-primary"></i>${p.location || 'N/A'}</div>
                </div>
              </div>
              <div class="px-3">
                <h6 class="fw-bold mb-2" style="font-size:0.8rem; text-transform:uppercase; color:var(--gray);">Preferences</h6>
                <div style="font-size:0.85rem;" class="mb-2"><strong>Role:</strong> ${p.desired_role || 'N/A'}</div>
                <div style="font-size:0.85rem;" class="mb-2"><strong>Location:</strong> ${p.preferred_location || 'N/A'}</div>
                <div style="font-size:0.85rem;" class="mb-2"><strong>Type:</strong> ${p.job_type}</div>
                <div style="font-size:0.85rem;"><strong>Salary:</strong> ${p.expected_salary || 'N/A'}</div>
              </div>
            </div>
            <div class="col-md-8" style="max-height: 600px; overflow-y: auto;">
              <div class="mb-4">
                <h6 class="fw-bold section-label-sm mb-3">Work Experience</h6>
                ${p.experience && p.experience.length > 0 ? p.experience.map(exp => `
                  <div class="mb-3 pb-3 border-bottom">
                    <div class="fw-bold" style="font-size:0.95rem;">${exp.role}</div>
                    <div class="text-primary mb-1" style="font-size:0.85rem; font-weight:600;">${exp.company_name}</div>
                    <div class="text-muted mb-2" style="font-size:0.75rem;">
                      ${new Date(exp.start_date).toLocaleDateString()} - ${exp.is_current ? 'Present' : (exp.end_date ? new Date(exp.end_date).toLocaleDateString() : '')}
                    </div>
                    <p style="font-size:0.85rem; margin:0; line-height:1.4;">${exp.responsibilities || ''}</p>
                  </div>
                `).join('') : '<p class="text-muted small">No experience listed.</p>'}
              </div>
              <div class="mb-4">
                <h6 class="fw-bold section-label-sm mb-3">Education</h6>
                ${p.education && p.education.length > 0 ? p.education.map(edu => `
                  <div class="mb-2">
                    <div class="fw-bold" style="font-size:0.9rem;">${edu.degree}</div>
                    <div class="text-muted" style="font-size:0.8rem;">${edu.college} | Class of ${edu.graduation_year}</div>
                  </div>
                `).join('') : '<p class="text-muted small">No education listed.</p>'}
              </div>
              <div class="mb-4">
                <h6 class="fw-bold section-label-sm mb-3">Key Projects</h6>
                ${p.projects && p.projects.length > 0 ? p.projects.map(proj => `
                  <div class="mb-3 p-3 rounded" style="background:#f8fafc; border:1px solid #e2e8f0;">
                    <div class="fw-bold" style="font-size:0.9rem;">${proj.title}</div>
                    <div class="text-primary mb-2" style="font-size:0.75rem; font-weight:600;">Tech: ${proj.technologies_used}</div>
                    <p style="font-size:0.85rem; margin:0; line-height:1.4;">${proj.description}</p>
                  </div>
                `).join('') : '<p class="text-muted small">No projects listed.</p>'}
              </div>
            </div>
          </div>
        `;
        modalBody.innerHTML = html;
        const resumeLink = document.getElementById('profResumeLink');
        if (p.resume_path) {
          resumeLink.style.display = 'inline-flex';
          resumeLink.href = `/api/recruiter/resume/${p.user_id}`;
          resumeLink.innerHTML = `<i class="fas fa-file-pdf me-2"></i>Download Resume`;
        } else {
          resumeLink.style.display = 'none';
        }
      } catch (err) {
        console.error('Error:', err);
        modalBody.innerHTML = '<div class="alert alert-danger">Error loading profile.</div>';
      }
    }

    function applyFilters() {
      const query = document.getElementById('searchInput').value.toLowerCase().trim();
      const statusFilter = document.querySelector('input[name="statusFilter"]:checked').value;
      const filtered = allApplicants.filter(app => {
        const matchSearch = app.seeker_name.toLowerCase().includes(query) || app.seeker_email.toLowerCase().includes(query);
        const matchStatus = statusFilter === 'all' || app.status === statusFilter;
        return matchSearch && matchStatus;
      });
      renderApplicants(filtered);
    }

    async function updateStatus(appId, status) {
      showConfirm('Confirm Action', `Mark this applicant as "${status}"?`, async () => {
        try {
          const result = await window.apiService.updateApplicationStatus(appId, status);
          if (result.success) { showNotification('Updated!', result.message, 'success'); loadApplicants(); }
          else { showNotification('Error', result.message, 'error'); }
        } catch (err) { showNotification('Error', 'An error occurred.', 'error'); }
      });
    }

    function getStatusPill(status) {
      const map = { shortlisted: 'pill pill-success', rejected: 'pill pill-danger', hold: 'pill pill-secondary', 'under process': 'pill pill-info' };
      return map[status] || 'pill pill-warning';
    }
    function capitalize(s) { return s.charAt(0).toUpperCase() + s.slice(1); }

    loadApplicants();
  </script>
</body>
</html>

