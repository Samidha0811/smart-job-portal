<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        .sticky-header {
            position: sticky;
            top: 56px;
            z-index: 1020;
            background: rgba(248, 249, 250, 0.8) !important;
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
        }
    </style>
</head>

<body class="bg-light">
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm fixed-top">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/recruiter/dashboard">Smart Job Portal</a>
            <div class="collapse navbar-collapse">
                <ul class="navbar-nav ms-auto align-items-center">
                    <li class="nav-item"><a class="nav-link fw-bold me-3 text-white"
                            href="/recruiter/dashboard">Dashboard</a></li>
                    <li class="nav-item"><a class="nav-link fw-bold me-3 text-white active"
                            href="/recruiter/applications">Applications Received</a></li>
                    <li class="nav-item"><a class="nav-link fw-bold me-3 text-white" href="/recruiter/my-jobs">Posted
                            Jobs</a></li>
                    <li class="nav-item"><a class="btn btn-danger btn-sm ms-3 text-white fw-bold shadow-sm" href="#"
                            id="logoutLink">Logout</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Sticky Header Area -->
    <div class="sticky-header border-bottom shadow-sm" style="margin-top: 56px;">
        <div class="container py-3">
            <div class="d-flex justify-content-between align-items-center">
                <h2 class="fw-bold mb-0">Applications Received</h2>
                <div class="input-group shadow-sm" style="width: 250px;">
                    <span class="input-group-text bg-white border-end-0">
                        <i class="fas fa-search text-muted"></i>
                    </span>
                    <input type="text" id="searchInput" class="form-control border-start-0 ps-0"
                        placeholder="Search applicant or job...">
                </div>
            </div>
        </div>
    </div>

    <div class="container py-4">
        <div class="card shadow border-0 rounded-3">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Applicant</th>
                                <th>Job Title</th>
                                <th>Date</th>
                                <th>Status</th>
                                <th id="tableActionsHeader">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="allApplicationsList">
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    <div class="spinner-border spinner-border-sm text-primary me-2"></div>
                                    Loading applications...
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Logout Confirmation Modal -->
    <div class="modal fade" id="logoutModal" tabindex="-1" aria-labelledby="logoutModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow-lg border-0" style="border-radius: 1rem;">
                <div class="modal-header bg-danger text-white border-0 py-3">
                    <h5 class="modal-title fw-bold" id="logoutModalLabel">
                        <i class="fas fa-sign-out-alt me-2"></i>Confirm Logout
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                        aria-label="Close"></button>
                </div>
                <div class="modal-body p-5 text-center">
                    <div class="mb-3 text-danger">
                        <i class="fas fa-exclamation-circle fa-4x"></i>
                    </div>
                    <h4 class="fw-bold">Are you sure?</h4>
                    <p class="text-muted mb-0">You will be signed out of your session.</p>
                </div>
                <div class="modal-footer border-0 p-3 bg-light justify-content-center">
                    <button type="button" class="btn btn-light px-4 fw-bold text-muted"
                        data-bs-dismiss="modal">Cancel</button>
                    <a href="/api/auth/logout" class="btn btn-danger px-4 fw-bold shadow-sm">Logout Now</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Notification Modal -->
    <div class="modal fade" id="notificationModal" tabindex="-1" aria-labelledby="notificationModalLabel"
        aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow-lg border-0" style="border-radius: 1rem;">
                <div id="modalHeader" class="modal-header border-0 py-3 text-white">
                    <h5 class="modal-title fw-bold" id="notificationModalLabel">Notification</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                        aria-label="Close"></button>
                </div>
                <div class="modal-body p-5 text-center">
                    <div id="modalIcon" class="mb-3"></div>
                    <h4 id="modalTitle" class="fw-bold mb-2"></h4>
                    <p id="modalMessage" class="text-muted mb-0"></p>
                </div>
                <div class="modal-footer border-0 p-3 bg-light justify-content-center">
                    <button type="button" class="btn btn-primary px-5 fw-bold shadow-sm rounded-pill"
                        data-bs-dismiss="modal" id="modalOkBtn">OK</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Confirmation Modal -->
    <div class="modal fade" id="confirmModal" tabindex="-1" aria-labelledby="confirmModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow-lg border-0" style="border-radius: 1rem;">
                <div class="modal-header bg-primary text-white border-0 py-3">
                    <h5 class="modal-title fw-bold" id="confirmModalLabel">Confirm Action</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                        aria-label="Close"></button>
                </div>
                <div class="modal-body p-5 text-center">
                    <div class="mb-3 text-primary">
                        <i class="fas fa-question-circle fa-4x"></i>
                    </div>
                    <h4 id="confirmTitle" class="fw-bold mb-2">Are you sure?</h4>
                    <p id="confirmMessage" class="text-muted mb-0"></p>
                </div>
                <div class="modal-footer border-0 p-3 bg-light justify-content-center">
                    <button type="button" class="btn btn-light px-4 fw-bold text-muted"
                        data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary px-4 fw-bold shadow-sm rounded-pill"
                        id="confirmActionBtn">Confirm</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/apiService.js"></script>
    <script>
        // Handle Logout Popup
        document.addEventListener('DOMContentLoaded', () => {
            const logoutLink = document.getElementById('logoutLink');
            if (logoutLink) {
                logoutLink.addEventListener('click', function (e) {
                    e.preventDefault();
                    const modalEl = document.getElementById('logoutModal');
                    const logoutModal = new bootstrap.Modal(modalEl);
                    logoutModal.show();
                });
            }

            // Prevent Back-Forward Cache (bfcache)
            window.addEventListener('pageshow', (event) => {
                if (event.persisted) {
                    window.location.reload();
                }
            });

            function showNotification(title, message, type = 'success', callback = null) {
                const modalEl = document.getElementById('notificationModal');
                const header = document.getElementById('modalHeader');
                const icon = document.getElementById('modalIcon');
                const titleEl = document.getElementById('modalTitle');
                const msgEl = document.getElementById('modalMessage');

                header.className = 'modal-header border-0 py-3 text-white ' + (type === 'success' ? 'bg-success' : 'bg-danger');
                icon.innerHTML = type === 'success' ? '<i class="fas fa-check-circle fa-4x text-success"></i>' : '<i class="fas fa-times-circle fa-4x text-danger"></i>';
                titleEl.textContent = title;
                msgEl.textContent = message;

                const modal = new bootstrap.Modal(modalEl);
                if (callback) {
                    modalEl.addEventListener('hidden.bs.modal', function handler() {
                        callback();
                        modalEl.removeEventListener('hidden.bs.modal', handler);
                    });
                }
                modal.show();
            }

            function showConfirm(title, message, onConfirm) {
                const modalEl = document.getElementById('confirmModal');
                document.getElementById('confirmTitle').textContent = title;
                document.getElementById('confirmMessage').textContent = message;
                const confirmBtn = document.getElementById('confirmActionBtn');

                const modal = new bootstrap.Modal(modalEl);
                confirmBtn.onclick = () => {
                    onConfirm();
                    modal.hide();
                };
                modal.show();
            }

            const searchInput = document.getElementById('searchInput');
            searchInput.addEventListener('input', (e) => {
                filterApplications(e.target.value);
            });

            loadApplications();
        });

        let allApplications = [];

        async function loadApplications() {
            try {
                allApplications = await window.apiService.getRecruiterApplications();
                renderApplications(allApplications);
            } catch (err) {
                console.error('Error loading applications:', err);
                document.getElementById('allApplicationsList').innerHTML = '<tr><td colspan="5" class="text-center text-danger">Error loading applications.</td></tr>';
            }
        }

        function renderApplications(apps) {
            const appList = document.getElementById('allApplicationsList');

            if (apps && apps.length > 0) {
                appList.innerHTML = apps.map(app => `
                    <tr>
                        <td>
                            <div class="fw-bold text-dark">${app.seeker_name}</div>
                            <div class="text-muted small">${app.seeker_email}</div>
                        </td>
                        <td>
                            <div class="fw-medium">${app.job_title}</div>
                            <div class="text-primary small fw-bold">ID: ${app.job_id || 'N/A'}</div>
                        </td>
                        <td class="text-muted small">${new Date(app.applied_at).toLocaleDateString()}</td>
                        <td>
                            <span class="badge ${getStatusBadge(app.status)} px-3 py-2 rounded-pill">
                                ${app.status.charAt(0).toUpperCase() + app.status.slice(1)}
                            </span>
                        </td>
                        <td>
                            <div class="btn-group btn-group-sm mb-0">
                                <button class="btn btn-outline-success" onclick="updateStatus(${app.id}, 'shortlisted')">Shortlist</button>
                                <button class="btn btn-outline-danger" onclick="updateStatus(${app.id}, 'rejected')">Reject</button>
                            </div>
                        </td>
                    </tr>
                `).join('');
            } else {
                appList.innerHTML = '<tr><td colspan="5" class="text-center py-5 text-muted">No applications found.</td></tr>';
            }
        }

        function filterApplications(query) {
            const q = query.toLowerCase().trim();
            const filtered = allApplications.filter(app =>
                app.seeker_name.toLowerCase().includes(q) ||
                app.seeker_email.toLowerCase().includes(q) ||
                app.job_title.toLowerCase().includes(q) ||
                (app.job_id && app.job_id.toLowerCase().includes(q))
            );
            renderApplications(filtered);
        }

        async function updateStatus(appId, status) {
            showConfirm('Confirmation', `Are you sure you want to mark this applicant as ${status}?`, async () => {
                try {
                    const result = await window.apiService.updateApplicationStatus(appId, status);
                    if (result.success) {
                        showNotification('Success', result.message, 'success');
                        loadApplications(); // Reload list
                    } else {
                        showNotification('Error', result.message, 'error');
                    }
                } catch (err) {
                    console.error('Error updating status:', err);
                    showNotification('Error', 'An error occurred.', 'error');
                }
            });
        }

        function getStatusBadge(status) {
            switch (status) {
                case 'shortlisted': return 'bg-success';
                case 'rejected': return 'bg-danger';
                default: return 'bg-warning text-dark';
            }
        }
    </script>
</body>

</html>