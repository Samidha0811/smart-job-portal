<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - Smart Job Portal</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>

<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm fixed-top">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">Admin Panel</a>
            <div class="collapse navbar-collapse">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link btn btn-outline-danger btn-sm ms-3 text-white" href="#" id="logoutLink">Logout</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container py-5 mt-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div class="d-flex align-items-center">
                <h2 class="fw-bold mb-0 me-4">Manage Recruiters</h2>
                <div class="input-group shadow-sm" style="width: 300px;">
                    <span class="input-group-text bg-white border-end-0">
                        <i class="fas fa-search text-muted"></i>
                    </span>
                    <input type="text" id="recruiterSearch" class="form-control border-start-0 ps-0" placeholder="Search name or company...">
                </div>
            </div>
            <div class="btn-group shadow-sm" role="group" aria-label="Recruiter filters">
                <button type="button" class="btn btn-outline-dark filter-btn" data-filter="all">All</button>
                <button type="button" class="btn btn-outline-dark active filter-btn" data-filter="pending">Pending</button>
                <button type="button" class="btn btn-outline-dark filter-btn" data-filter="approved">Approved</button>
                <button type="button" class="btn btn-outline-dark filter-btn" data-filter="rejected">Rejected</button>
            </div>
        </div>
        <div class="card shadow border-0">
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Name</th>
                            <th>Company</th>
                            <th>Email</th>
                            <th>Status</th>
                            <th>Submitted At</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (recruiters.length===0) { %>
                            <tr>
                                <td colspan="7" class="text-center py-4 text-muted">No recruiters found.</td>
                            </tr>
                            <% } %>
                                <% recruiters.forEach(user=> { 
                                    const displayStatus = (user.status === 'active') ? 'approved' : user.status;
                                %>
                                    <tr class="recruiter-row" 
                                        data-status="<%= displayStatus %>"
                                        data-name="<%= user.fullname.toLowerCase() %>"
                                        data-company="<%= (user.company_name || '').toLowerCase() %>">
                                        <td>
                                            <%= user.fullname %>
                                        </td>
                                        <td>
                                            <span class="badge bg-info text-dark"><%= user.company_name || 'N/A' %></span>
                                        </td>
                                        <td>
                                            <%= user.email %>
                                        </td>
                                        <td>
                                            <% if (user.status === 'pending') { %>
                                                <span class="badge bg-warning text-dark px-3 mt-1"><i class="fas fa-clock me-1"></i> Pending</span>
                                            <% } else if (user.status === 'approved' || user.status === 'active') { %>
                                                <span class="badge bg-success px-3 mt-1"><i class="fas fa-check-circle me-1"></i> Approved</span>
                                            <% } else if (user.status === 'rejected') { %>
                                                <span class="badge bg-danger px-3 mt-1"><i class="fas fa-times-circle me-1"></i> Rejected</span>
                                            <% } else { %>
                                                <span class="badge bg-secondary px-3 mt-1"><%= user.status %></span>
                                            <% } %>
                                        </td>
                                        <td>
                                            <%= user.submitted_at ? new Date(user.submitted_at).toLocaleDateString() : 'N/A' %>
                                        </td>
                                        <td class="text-end">
                                            <a href="/admin/recruiter/<%= user.id %>" class="btn btn-primary btn-sm px-3">
                                                <i class="fas fa-eye me-1"></i> Review
                                            </a>
                                        </td>
                                    </tr>
                                    <% }); %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Logout Confirmation Modal -->
    <div class="modal fade" id="logoutModal" tabindex="-1" aria-labelledby="logoutModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow-lg border-0" style="border-radius: 1rem;">
                <div class="modal-header bg-danger text-white border-0 py-3">
                    <h5 class="modal-title fw-bold" id="logoutModalLabel">
                        <i class="fas fa-sign-out-alt me-2"></i>Confirm Logout
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-5 text-center">
                    <div class="mb-3 text-danger">
                        <i class="fas fa-exclamation-circle fa-4x"></i>
                    </div>
                    <h4 class="fw-bold">Are you sure?</h4>
                    <p class="text-muted mb-0">You will be signed out of the admin session.</p>
                </div>
                <div class="modal-footer border-0 p-3 bg-light justify-content-center">
                    <button type="button" class="btn btn-light px-4 fw-bold text-muted" data-bs-dismiss="modal">Cancel</button>
                    <a href="/api/auth/logout" class="btn btn-danger px-4 fw-bold shadow-sm">Logout Now</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <!-- apiService JS -->
    <script src="/js/apiService.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Prevent Back-Forward Cache (bfcache)
            window.addEventListener('pageshow', (event) => {
                if (event.persisted) {
                    window.location.reload();
                }
            });

            const logoutLink = document.getElementById('logoutLink');
            if (logoutLink) {
                logoutLink.addEventListener('click', function(e) {
                    e.preventDefault();
                    // Initialize and show the modal
                    const modalEl = document.getElementById('logoutModal');
                    const logoutModal = new bootstrap.Modal(modalEl);
                    logoutModal.show();
                });
            }
            const filterButtons = document.querySelectorAll('.filter-btn');
            const searchInput = document.getElementById('recruiterSearch');
            const tableRows = document.querySelectorAll('.recruiter-row');

            let currentFilter = 'pending';
            let currentSearch = '';

            const applyFilters = () => {
                tableRows.forEach(row => {
                    const status = row.getAttribute('data-status');
                    const name = row.getAttribute('data-name');
                    const company = row.getAttribute('data-company');

                    const matchesFilter = currentFilter === 'all' || status === currentFilter;
                    const matchesSearch = name.includes(currentSearch) || company.includes(currentSearch);

                    if (matchesFilter && matchesSearch) {
                        row.style.display = '';
                    } else {
                        row.style.display = 'none';
                    }
                });
            };

            // Call once to apply default filter (pending)
            applyFilters();

            filterButtons.forEach(btn => {
                btn.addEventListener('click', () => {
                    filterButtons.forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                    currentFilter = btn.getAttribute('data-filter');
                    applyFilters();
                });
            });

            searchInput.addEventListener('input', (e) => {
                currentSearch = e.target.value.toLowerCase().trim();
                applyFilters();
            });
        });
    </script>
</body>

</html>