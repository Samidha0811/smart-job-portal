<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - Smart Job Portal</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
        <div class="container">
          <a class="navbar-brand fw-bold" href="/">Admin Panel</a>
          <div class="collapse navbar-collapse">
            <ul class="navbar-nav ms-auto">
              <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
              <li class="nav-item"><a class="nav-link btn btn-outline-danger btn-sm ms-3" href="/login">Logout</a></li>
            </ul>
          </div>
        </div>
    </nav>

    <div class="container py-5">
        <h2 class="fw-bold mb-4">Manage Recruiters</h2>
        <div class="card shadow border-0">
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (recruiters.length === 0) { %>
                            <tr><td colspan="4" class="text-center py-4 text-muted">No pending recruiters found.</td></tr>
                        <% } %>
                        <% recruiters.forEach(user => { %>
                            <tr>
                                <td><%= user.fullname %></td>
                                <td><%= user.email %></td>
                                <td><span class="badge bg-warning text-dark"><%= user.status %></span></td>
                                <td class="text-end">
                                    <form action="/api/admin/approve" method="POST" class="d-inline">
                                        <input type="hidden" name="userId" value="<%= user.id %>">
                                        <button type="submit" class="btn btn-success btn-sm px-3">Approve</button>
                                    </form>
                                    <form action="/api/admin/reject" method="POST" class="d-inline ms-2">
                                        <input type="hidden" name="userId" value="<%= user.id %>">
                                        <button type="submit" class="btn btn-outline-danger btn-sm px-3">Reject</button>
                                    </form>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</body>
</html>
