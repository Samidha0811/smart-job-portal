<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - Smart Job Portal</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>

<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">Admin Panel</a>
            <div class="collapse navbar-collapse">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link btn btn-outline-danger btn-sm ms-3 text-white" href="#" id="logoutLink">Logout</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container py-5">
        <h2 class="fw-bold mb-4">Manage Recruiters</h2>
        <div class="card shadow border-0">
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Name</th>
                            <th>Company</th>
                            <th>Email</th>
                            <th>Submitted At</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (recruiters.length===0) { %>
                            <tr>
                                <td colspan="5" class="text-center py-4 text-muted">No pending recruiters found.</td>
                            </tr>
                            <% } %>
                                <% recruiters.forEach(user=> { %>
                                    <tr>
                                        <td>
                                            <%= user.fullname %>
                                        </td>
                                        <td>
                                            <span class="badge bg-info text-dark"><%= user.company_name || 'N/A' %></span>
                                        </td>
                                        <td>
                                            <%= user.email %>
                                        </td>
                                        <td>
                                            <%= new Date(user.submitted_at).toLocaleDateString() %>
                                        </td>
                                        <td class="text-end">
                                            <a href="/admin/recruiter/<%= user.id %>" class="btn btn-primary btn-sm px-3">
                                                <i class="fas fa-eye me-1"></i> Review
                                            </a>
                                        </td>
                                    </tr>
                                    <% }); %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Logout Confirmation Modal -->
    <div class="modal fade" id="logoutModal" tabindex="-1" aria-labelledby="logoutModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow-lg border-0" style="border-radius: 1rem;">
                <div class="modal-header bg-danger text-white border-0 py-3">
                    <h5 class="modal-title fw-bold" id="logoutModalLabel">
                        <i class="fas fa-sign-out-alt me-2"></i>Confirm Logout
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-5 text-center">
                    <div class="mb-3 text-danger">
                        <i class="fas fa-exclamation-circle fa-4x"></i>
                    </div>
                    <h4 class="fw-bold">Are you sure?</h4>
                    <p class="text-muted mb-0">You will be signed out of the admin session.</p>
                </div>
                <div class="modal-footer border-0 p-3 bg-light justify-content-center">
                    <button type="button" class="btn btn-light px-4 fw-bold text-muted" data-bs-dismiss="modal">Cancel</button>
                    <a href="/api/auth/logout" class="btn btn-danger px-4 fw-bold shadow-sm">Logout Now</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <!-- apiService JS -->
    <script src="/js/apiService.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Prevent Back-Forward Cache (bfcache)
            window.addEventListener('pageshow', (event) => {
                if (event.persisted) {
                    window.location.reload();
                }
            });

            const logoutLink = document.getElementById('logoutLink');
            if (logoutLink) {
                logoutLink.addEventListener('click', function(e) {
                    e.preventDefault();
                    // Initialize and show the modal
                    const modalEl = document.getElementById('logoutModal');
                    const logoutModal = new bootstrap.Modal(modalEl);
                    logoutModal.show();
                });
            }
        });
    </script>
</body>

</html>