<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-light">
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
        <div class="container">
          <a class="navbar-brand fw-bold" href="/">Smart Job Portal</a>
          <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navJobs">
            <span class="navbar-toggler-icon"></span>
          </button>
          <div class="collapse navbar-collapse" id="navJobs">
            <ul class="navbar-nav ms-auto">
                <li class="nav-item"><a class="nav-link active" href="/jobs">Browse Jobs</a></li>
                <li class="nav-item" id="navDashboard" style="display:none;"><a class="nav-link" href="#">Dashboard</a></li>
                <li class="nav-item" id="navLogout" style="display:none;"><a class="nav-link" href="/api/auth/logout">Logout</a></li>
                <li class="nav-item" id="navLogin"><a class="nav-link" href="/login">Login</a></li>
            </ul>
          </div>
        </div>
    </nav>

    <div class="container py-5">
        <div class="text-center mb-5">
            <h1 class="fw-bold text-primary">Discover Your Next Career</h1>
            <p class="text-muted">Explore top opportunities from vetted companies.</p>
        </div>

        <div class="row" id="jobGrid">
            <!-- Spinner while loading -->
            <div class="col-12 text-center py-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/apiService.js"></script>
    <script>
        let currentUser = null;

        document.addEventListener('DOMContentLoaded', async () => {
            await checkAuth();
            await loadJobs();
        });

        async function checkAuth() {
            try {
                const response = await fetch('/api/auth/me');
                if (response.ok) {
                    currentUser = await response.json();
                    document.getElementById('navLogin').style.display = 'none';
                    document.getElementById('navLogout').style.display = 'block';
                    
                    const dashboard = document.getElementById('navDashboard');
                    dashboard.style.display = 'block';
                    if (currentUser.role === 'recruiter') {
                        dashboard.querySelector('a').href = '/recruiter/dashboard';
                        dashboard.querySelector('a').textContent = 'Recruiter Dashboard';
                    } else if (currentUser.role === 'seeker') {
                        dashboard.querySelector('a').href = '/seeker/dashboard';
                        dashboard.querySelector('a').textContent = 'My Applications';
                    } else if (currentUser.role === 'admin') {
                        dashboard.querySelector('a').href = '/admin';
                        dashboard.querySelector('a').textContent = 'Admin Panel';
                    }
                }
            } catch (err) {
                console.log('User not logged in');
            }
        }

        async function loadJobs() {
            try {
                // Anyone can view jobs, but we use the seeker endpoint for listing
                // If not logged in, we fetch from a public endpoint or reuse seeker logic if role is relaxed
                const response = await fetch('/api/seeker/jobs');
                if (!response.ok) {
                    if (response.status === 401 || response.status === 403) {
                         document.getElementById('jobGrid').innerHTML = `
                            <div class="col-12 text-center py-5">
                                <div class="alert alert-warning shadow-sm">
                                    <h4 class="fw-bold">Login Required</h4>
                                    <p>Please <a href="/login">login as a Job Seeker</a> to see available opportunities.</p>
                                </div>
                            </div>`;
                         return;
                    }
                    throw new Error('Failed to fetch');
                }
                const jobs = await response.json();
                
                const jobGrid = document.getElementById('jobGrid');
                if (jobs.length === 0) {
                    jobGrid.innerHTML = '<div class="col-12 text-center py-5 text-muted"><h4>No open jobs found. Check back later!</h4></div>';
                    return;
                }

                jobGrid.innerHTML = jobs.map(job => `
                    <div class="col-md-6 col-lg-4 mb-4">
                        <div class="card h-100 shadow-sm border-0 job-card">
                            <div class="card-body p-4">
                                <div class="d-flex justify-content-between align-items-start mb-3">
                                    <h5 class="card-title fw-bold text-primary mb-0">${job.title}</h5>
                                    <span class="badge bg-light text-dark shadow-sm border">$${job.salary || 'N/A'}</span>
                                </div>
                                <h6 class="card-subtitle mb-2 text-muted">
                                    <i class="fas fa-building me-1"></i> ${job.company_name || 'Hiring Company'}
                                </h6>
                                <div class="text-primary small fw-bold mb-3">
                                    <i class="fas fa-fingerprint me-1"></i> ID: ${job.job_id || 'N/A'}
                                </div>
                                <p class="card-text text-secondary small mb-4">${job.description.substring(0, 120)}${job.description.length > 120 ? '...' : ''}</p>
                                <div class="d-flex align-items-center text-muted small mb-4">
                                    <span class="me-3"><i class="fas fa-map-marker-alt me-1"></i> ${job.location || 'Remote'}</span>
                                    <span><i class="fas fa-calendar-alt me-1"></i> ${new Date(job.created_at).toLocaleDateString()}</span>
                                </div>
                                ${currentUser && currentUser.role === 'seeker' ? 
                                    `<button onclick="applyToJob(${job.id})" id="applyBtn-${job.id}" class="btn btn-primary w-100 fw-bold py-2">Apply Now</button>` : 
                                    (currentUser ? `<button class="btn btn-secondary w-100 disabled">Seekers Only</button>` : `<a href="/login" class="btn btn-outline-primary w-100">Login to Apply</a>`)
                                }
                            </div>
                        </div>
                    </div>
                `).join('');

            } catch (err) {
                console.error(err);
                document.getElementById('jobGrid').innerHTML = '<div class="col-12 text-center py-5 text-danger"><h4>Error loading jobs.</h4></div>';
            }
        }

        async function applyToJob(jobId) {
            const btn = document.getElementById(`applyBtn-${jobId}`);
            const originalText = btn.textContent;
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Submitting...';

            try {
                const result = await window.apiService.applyToJob(jobId);
                if (result.success) {
                    btn.className = 'btn btn-success w-100 fw-bold py-2';
                    btn.textContent = 'Applied Successfully!';
                    alert('Successfully applied!');
                } else {
                    btn.disabled = false;
                    btn.textContent = originalText;
                    if (result.message === 'Please complete your profile first.') {
                        if (confirm('Please complete your profile (including resume upload) before applying. Go to profile page?')) {
                            window.location.href = '/seeker/complete-profile';
                        }
                    } else {
                        alert(result.message || 'Error applying.');
                    }
                }
            } catch (err) {
                console.error(err);
                btn.disabled = false;
                btn.textContent = originalText;
                alert('An error occurred.');
            }
        }
    </script>
</body>
</html>
