<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= title %> — Joblifies - Smart Job Portal
  </title>
  <meta name="description" content="Browse and apply to the latest job openings on Joblifies - Smart Job Portal.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/chatbot.css?v=1.1">
  <style>
    .filter-sidebar {
      background: #fff;
      border-radius: var(--radius-lg);
      border: 1px solid var(--border);
      padding: 1rem;
      position: sticky;
      top: 5rem;
      max-height: calc(100vh - 6rem);
      overflow-y: auto;
    }

    .filter-section {
      margin-bottom: 1.25rem;
    }

    .filter-section:last-child {
      margin-bottom: 0;
    }

    .filter-title {
      font-weight: 700;
      font-size: 0.9rem;
      color: var(--dark);
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .filter-option {
      display: block;
      margin-bottom: 0.5rem;
      cursor: pointer;
      font-size: 0.875rem;
      color: var(--gray);
      transition: var(--transition);
    }

    .filter-option:hover {
      color: var(--primary);
    }

    .filter-checkbox {
      margin-right: 0.5rem;
      accent-color: var(--primary);
    }

    .clear-filters {
      font-size: 0.8rem;
      color: var(--primary);
      text-decoration: none;
      font-weight: 600;
      cursor: pointer;
    }

    .clear-filters:hover {
      text-decoration: underline;
    }

    .job-count-indicator {
      font-size: 0.85rem;
      color: var(--gray);
      margin-bottom: 1.5rem;
    }

    .job-desc-container {
      position: relative;
      margin-bottom: 1.5rem;
    }

    .job-desc {
      font-size: 0.875rem;
      color: var(--dark-3);
      line-height: 1.6;
      word-break: break-word;
      overflow: hidden;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      line-clamp: 3;
      -webkit-box-orient: vertical;
      transition: all 0.3s ease;
    }

    .job-desc.expanded {
      -webkit-line-clamp: unset;
      line-clamp: unset;
      display: block;
    }

    .desc-toggle-btn {
      background: none;
      border: none;
      color: var(--primary);
      font-size: 0.75rem;
      font-weight: 700;
      padding: 0;
      margin-top: 0.5rem;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 0.25rem;
      transition: var(--transition);
    }

    .desc-toggle-btn:hover {
      opacity: 0.8;
      text-decoration: underline;
    }

    .desc-toggle-btn i {
      transition: transform 0.3s ease;
    }

    .desc-toggle-btn.expanded i {
      transform: rotate(180deg);
    }

    /* Recommendation Card Styling */
    .rec-card-premium {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 1.25rem;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      height: 100%;
      min-width: 280px;
      position: relative;
    }

    .rec-card-premium:hover {
      border-color: var(--primary);
      box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05);
      transform: translateY(-4px);
    }

    .match-badge-jobs {
      background: rgba(129, 140, 248, 0.1);
      color: var(--primary);
      padding: 4px 10px;
      border-radius: 20px;
      font-size: 0.72rem;
      font-weight: 700;
      display: inline-flex;
      align-items: center;
      gap: 4px;
    }

    .matched-skill-tag {
      font-size: 0.65rem;
      background: #f3f4f6;
      color: #4b5563;
      padding: 2px 8px;
      border-radius: 4px;
      font-weight: 500;
    }
  </style>
    <link rel="icon" type="image/png" href="/uploads/image.png">
</head>

<body class="dashboard-page">

  <!-- ===== NAVBAR ===== -->
  <nav class="navbar navbar-expand-lg navbar-premium">
    <div class="container">
      <span class="navbar-brand">
        <i class="fas fa-briefcase me-2" style="color:#818cf8;"></i>Joblifies - Smart Job Portal
      </span>
      <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navJobs"
        style="color:rgba(255,255,255,0.7);">
        <i class="fas fa-bars"></i>
      </button>
      <div class="collapse navbar-collapse" id="navJobs">
        <ul class="navbar-nav ms-auto align-items-center gap-1">
          <li class="nav-item"><a class="nav-link active" href="/jobs"><i class="fas fa-search me-1"></i>Browse Jobs</a>
          </li>
          <li class="nav-item" id="navDashboard" style="display:none;"><a class="nav-link" href="#"
              id="dashLink">Dashboard</a></li>
          <li class="nav-item" id="navProfile" style="display:none;">
            <a class="nav-link" href="#" data-bs-toggle="offcanvas" data-bs-target="#profileOffcanvas"
              onclick="loadOffcanvasProfile()"><i class="fas fa-user-circle me-1"></i>Profile</a>
          </li>
          <li class="nav-item" id="navLogout" style="display:none;">
            <a class="btn-nav-danger" href="/api/auth/logout"><i class="fas fa-sign-out-alt me-1"></i>Logout</a>
          </li>
          <li class="nav-item" id="navLogin">
            <a class="btn-nav-cta" href="/login">Login <i class="fas fa-arrow-right ms-1"
                style="font-size:0.8rem;"></i></a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <!-- ===== PAGE HEADER ===== -->
  <div style="background:linear-gradient(135deg,#0f172a 0%,#1e1b4b 100%);padding:1rem 0;">
    <div
      class="container-fluid px-4 text-center d-flex flex-column flex-md-row align-items-center justify-content-between gap-3">
      <div class="text-md-start">
        <h1 style="color:#fff;font-size:1.5rem;font-weight:800;letter-spacing:-0.5px;margin-bottom:0.25rem;">
          Discover Your <span
            style="background:linear-gradient(135deg,#a5b4fc,#67e8f9);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">Next
            Career</span> Move
        </h1>
        <p style="color:rgba(255,255,255,0.55);font-size:0.85rem;margin:0;">Hand-picked opportunities from verified
          companies.</p>
      </div>
      <!-- Search bar -->
      <div style="flex-grow:1; max-width:600px;">
        <div class="search-bar"
          style="padding:0.2rem 0.2rem 0.2rem 1rem;border-radius:8px;background:rgba(255,255,255,0.95);border:none;display:flex;align-items:center;">
          <i class="fas fa-search search-bar-icon" style="color:var(--gray);font-size:0.9rem;margin-right:0.5rem;"></i>
          <input type="text" id="globalSearch" placeholder="Search job title, company, or skills..."
            style="background:transparent;color:var(--dark);flex-grow:1;border:none;outline:none;padding:0.4rem 0;font-size:0.9rem;">
          <button onclick="filterJobs()" id="searchBtn"
            style="background:linear-gradient(135deg,var(--primary),var(--primary-dark));color:#fff;border:none;padding:0.4rem 1.25rem;border-radius:6px;font-family:var(--font);font-weight:700;font-size:0.85rem;cursor:pointer;margin-left:0.5rem;">
            Search
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- ===== MAIN CONTENT ===== -->
  <div class="container-fluid px-4 py-3">
    <div class="row g-4">
      <!-- Sidebar Filters -->
      <div class="col-lg-2 col-md-3">
        <div class="filter-sidebar">
          <div class="d-flex justify-content-between align-items-center mb-4">
            <h5 class="fw-bold mb-0" style="font-size:1.1rem;">Filters</h5>
            <span class="clear-filters" onclick="resetFilters()">Clear All</span>
          </div>

          <!-- Location -->
          <div class="filter-section">
            <div class="filter-title"><i class="fas fa-map-marker-alt text-primary"></i> Location</div>
            <div id="locationFilters">
              <!-- Dynamically Populated -->
            </div>
          </div>

          <!-- Salary Range -->
          <div class="filter-section">
            <div class="filter-title"><i class="fas fa-money-bill-wave text-success"></i> Salary (Monthly)</div>
            <label class="filter-option"><input type="checkbox" class="filter-checkbox salary-filter" value="0-20000">
              ₹0 - ₹20,000</label>
            <label class="filter-option"><input type="checkbox" class="filter-checkbox salary-filter"
                value="20000-50000"> ₹20,000 - ₹50,000</label>
            <label class="filter-option"><input type="checkbox" class="filter-checkbox salary-filter"
                value="50000-100000"> ₹50,000 - ₹1,00,000</label>
            <label class="filter-option"><input type="checkbox" class="filter-checkbox salary-filter" value="100000+">
              ₹1,00,000++</label>
          </div>

          <!-- Company -->
          <div class="filter-section">
            <div class="filter-title"><i class="fas fa-user-tie text-info"></i> Company</div>
            <div id="companyFilters">
              <!-- Dynamically Populated -->
            </div>
          </div>

          <!-- Date Posted -->
          <div class="filter-section">
            <div class="filter-title"><i class="fas fa-calendar-alt text-warning"></i> Date Posted</div>
            <label class="filter-option"><input type="radio" name="datePosted" class="filter-radio" value="all" checked>
              All Time</label>
            <label class="filter-option"><input type="radio" name="datePosted" class="filter-radio" value="today"> Last
              24 Hours</label>
            <label class="filter-option"><input type="radio" name="datePosted" class="filter-radio" value="week"> Last 7
              Days</label>
            <label class="filter-option"><input type="radio" name="datePosted" class="filter-radio" value="month"> Last
              30 Days</label>
          </div>
        </div>
      </div>

      <!-- Job Grid -->
      <div class="col-lg-10 col-md-9">
        <!-- ===== PERSONALIZED RECOMMENDATIONS ===== -->
        <div id="recommendationContainer" style="display:none;">
          <div class="d-flex align-items-center justify-content-between mb-3">
            <h5 class="fw-bold mb-0" style="font-size:1.15rem; color:var(--dark);"><i
                class="fas fa-magic text-primary me-2"></i>Personalized For You</h5>
            <div class="d-flex gap-2">
              <button class="btn btn-sm btn-light scroll-btn"
                onclick="document.getElementById('recScrollList').scrollBy({left:-300,behavior:'smooth'})"><i
                  class="fas fa-chevron-left"></i></button>
              <button class="btn btn-sm btn-light scroll-btn"
                onclick="document.getElementById('recScrollList').scrollBy({left:300,behavior:'smooth'})"><i
                  class="fas fa-chevron-right"></i></button>
            </div>
          </div>
          <div id="recScrollList" class="d-flex gap-3 overflow-auto pb-3"
            style="scrollbar-width:none; -ms-overflow-style:none;">
            <!-- Recommendations injected here -->
          </div>
        </div>

        <div class="job-count-indicator" id="jobCountIndicator">Showing all jobs</div>
        <div class="row g-4" id="jobGrid">
          <div class="col-12">
            <div class="loading-overlay py-5">
              <div class="spinner-border text-primary"></div>
              <span>Loading jobs...</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ===== PROFILE OFFCANVAS ===== -->
  <div class="offcanvas offcanvas-end" tabindex="-1" id="profileOffcanvas" aria-labelledby="profileOffcanvasLabel"
    style="width: 350px;">
    <div class="offcanvas-header bg-light border-bottom p-3">
      <h5 class="offcanvas-title fw-bold" id="profileOffcanvasLabel" style="font-size:1.15rem;"><i
          class="fas fa-user-circle me-2 text-primary"></i>My Profile</h5>
      <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body p-4 bg-light">
      <div class="sidebar-card m-0 w-100 shadow-none border-0" style="background:transparent;">
        <div class="sidebar-header pb-3 mb-3 border-bottom">
          <div class="avatar-circle mx-auto mb-3"
            style="width:70px;height:70px;font-size:2rem;background:rgba(79,70,229,0.1);color:var(--primary);border-radius:50%;display:flex;align-items:center;justify-content:center;">
            <i class="fas fa-user"></i>
          </div>
          <div class="sidebar-name fs-5 fw-bold text-center" id="ocName">
            Loading...
          </div>
          <div class="sidebar-email text-muted text-center" id="ocEmail">
            Loading...
          </div>
          <div class="mt-3 text-center">
            <span class="status-badge status-approved px-3 py-2"
              style="background:rgba(16,185,129,0.1);color:#059669;border-radius:20px;font-size:0.75rem;font-weight:700;">
              <i class="fas fa-check-circle" style="font-size:0.8rem;"></i> Verified Seeker
            </span>
          </div>
        </div>
        <div class="sidebar-body px-0">
          <div class="sidebar-info-row d-flex flex-column gap-3 mb-4">
            <div class="sidebar-info-item w-100 d-flex gap-3 align-items-center">
              <div class="sidebar-info-icon"
                style="width:40px;height:40px;border-radius:10px;background:rgba(79,70,229,0.1);color:var(--primary);display:flex;align-items:center;justify-content:center;">
                <i class="fas fa-briefcase"></i>
              </div>
              <div>
                <div
                  style="font-size:0.75rem;color:var(--gray);text-transform:uppercase;letter-spacing:0.05em;font-weight:600;margin-bottom:0.15rem;">
                  Current Role</div>
                <div style="font-size:0.95rem;color:var(--dark);font-weight:600;" id="ocRole">
                  N/A
                </div>
              </div>
            </div>
            <div class="sidebar-info-item w-100 d-flex gap-3 align-items-center">
              <div class="sidebar-info-icon"
                style="width:40px;height:40px;border-radius:10px;background:rgba(6,182,212,0.1);color:var(--secondary);display:flex;align-items:center;justify-content:center;">
                <i class="fas fa-history"></i>
              </div>
              <div>
                <div
                  style="font-size:0.75rem;color:var(--gray);text-transform:uppercase;letter-spacing:0.05em;font-weight:600;margin-bottom:0.15rem;">
                  Experience</div>
                <div style="font-size:0.95rem;color:var(--dark);font-weight:600;" id="ocExp">
                  0y 0m
                </div>
              </div>
            </div>
            <div class="sidebar-info-item w-100 d-flex gap-3 align-items-center">
              <div class="sidebar-info-icon"
                style="width:40px;height:40px;border-radius:10px;background:rgba(245,158,11,0.1);color:var(--warning);display:flex;align-items:center;justify-content:center;">
                <i class="fas fa-map-marker-alt"></i>
              </div>
              <div>
                <div
                  style="font-size:0.75rem;color:var(--gray);text-transform:uppercase;letter-spacing:0.05em;font-weight:600;margin-bottom:0.15rem;">
                  Location</div>
                <div style="font-size:0.95rem;color:var(--dark);font-weight:600;" id="ocLocation">
                  Not set
                </div>
              </div>
            </div>
          </div>

          <div class="mt-2 d-grid gap-2">
            <a href="/seeker/profile-setup" class="btn btn-primary w-100 fw-bold py-2 btn-lg"
              style="border-radius:10px;font-size:0.95rem;background:linear-gradient(135deg,var(--primary),var(--primary-dark));border:none;color:white;">
              <i class="fas fa-user-edit me-2"></i>Edit My Profile
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script src="/js/apiService.js"></script>
  <script>
    let currentUser = null;
    let allJobs = [];

    document.getElementById('globalSearch').addEventListener('keyup', function (e) {
      if (e.key === 'Enter') filterJobs();
    });

    // Listen for changes in checkboxes and radios
    document.addEventListener('change', (e) => {
      if (e.target.classList.contains('filter-checkbox') || e.target.classList.contains('filter-radio')) {
        filterJobs();
      }
    });

    function resetFilters() {
      document.getElementById('globalSearch').value = '';
      document.querySelectorAll('.filter-checkbox').forEach(cb => cb.checked = false);
      const allTimeRadio = document.querySelector('input[name="datePosted"][value="all"]');
      if (allTimeRadio) allTimeRadio.checked = true;
      filterJobs();
    }

    function populateDynamicFilters() {
      const locations = [...new Set(allJobs.map(j => j.location).filter(Boolean))].sort();
      const companies = [...new Set(allJobs.map(j => j.company_name).filter(Boolean))].sort();

      const locContainer = document.getElementById('locationFilters');
      if (locContainer) {
        locContainer.innerHTML = locations.map(loc => `
          <label class="filter-option">
            <input type="checkbox" class="filter-checkbox location-filter" value="${loc}"> ${loc}
          </label>
        `).join('') || '<div class="text-muted small">No locations found</div>';
      }

      const compContainer = document.getElementById('companyFilters');
      if (compContainer) {
        compContainer.innerHTML = companies.map(comp => `
          <label class="filter-option">
            <input type="checkbox" class="filter-checkbox company-filter" value="${comp}"> ${comp}
          </label>
        `).join('') || '<div class="text-muted small">No companies found</div>';
      }
    }

    function filterJobs() {
      const q = document.getElementById('globalSearch').value.toLowerCase().trim();

      // Get selected locations
      const selectedLocs = Array.from(document.querySelectorAll('.location-filter:checked')).map(cb => cb.value);

      // Get selected companies
      const selectedComps = Array.from(document.querySelectorAll('.company-filter:checked')).map(cb => cb.value);

      // Get selected salary ranges
      const selectedSalaries = Array.from(document.querySelectorAll('.salary-filter:checked')).map(cb => cb.value);

      // Get date range
      const datePostedRadio = document.querySelector('input[name="datePosted"]:checked');
      const dateRange = datePostedRadio ? datePostedRadio.value : 'all';
      const now = new Date();

      const filtered = allJobs.filter(j => {
        // Search Match
        const searchMatch = !q ||
          j.title.toLowerCase().includes(q) ||
          (j.company_name && j.company_name.toLowerCase().includes(q)) ||
          (j.location && j.location.toLowerCase().includes(q)) ||
          (j.keywords && j.keywords.toLowerCase().includes(q));

        // Location Match
        const locMatch = selectedLocs.length === 0 || selectedLocs.includes(j.location);

        // Company Match
        const compMatch = selectedComps.length === 0 || selectedComps.includes(j.company_name);

        // Salary Match (Simple numeric extraction for demo)
        let salaryMatch = selectedSalaries.length === 0;
        if (!salaryMatch) {
          const jobSalary = parseInt(j.salary ? j.salary.replace(/[^0-9]/g, '') : '0') || 0;
          salaryMatch = selectedSalaries.some(range => {
            if (range === '100000+') return jobSalary >= 100000;
            const [min, max] = range.split('-').map(Number);
            return jobSalary >= min && jobSalary <= max;
          });
        }

        // Date Match
        let dateMatch = true;
        const jobDate = new Date(j.created_at);
        const diffMs = now - jobDate;
        const diffDays = diffMs / (1000 * 60 * 60 * 24);
        if (dateRange === 'today') dateMatch = diffDays <= 1;
        else if (dateRange === 'week') dateMatch = diffDays <= 7;
        else if (dateRange === 'month') dateMatch = diffDays <= 30;

        return searchMatch && locMatch && compMatch && salaryMatch && dateMatch;
      });

      const indicator = document.getElementById('jobCountIndicator');
      if (indicator) indicator.textContent = `Found ${filtered.length} jobs`;
      renderJobs(filtered);
    }

    document.addEventListener('DOMContentLoaded', async () => {
      await checkAuth();
      await loadJobs();
    });

    async function checkAuth() {
      try {
        const res = await fetch('/api/auth/me');
        if (res.ok) {
          currentUser = await res.json();
          document.getElementById('navLogin').style.display = 'none';
          document.getElementById('navLogout').style.display = 'block';
          const dash = document.getElementById('navDashboard');
          if (dash) dash.style.display = 'block';
          const link = document.getElementById('dashLink');
          if (link) {
            if (currentUser.role === 'recruiter') { link.href = '/recruiter/dashboard'; link.textContent = 'Dashboard'; }
            else if (currentUser.role === 'seeker') {
              link.href = '/seeker/dashboard';
              link.textContent = 'My Applications';
              const navProf = document.getElementById('navProfile');
              if (navProf) navProf.style.display = 'block';
              loadRecommendations();
              const chatBtn = document.getElementById('chatbot-toggle-btn');
              if (chatBtn) chatBtn.style.display = 'flex';
            }
            else if (currentUser.role === 'admin') { link.href = '/admin'; link.textContent = 'Admin Panel'; }
          }
        }
      } catch (e) { console.log('Not logged in'); }
    }

    async function loadOffcanvasProfile() {
      try {
        document.getElementById('ocName').textContent = currentUser.fullname || 'Loading...';
        document.getElementById('ocEmail').textContent = currentUser.email || 'Loading...';

        const res = await fetch('/api/seeker/api/profile');
        if (res.ok) {
          const data = await res.json();
          if (data.success && data.profile) {
            const p = data.profile;
            document.getElementById('ocName').textContent = p.full_name || currentUser.fullname;
            document.getElementById('ocEmail').textContent = p.email || currentUser.email;
            document.getElementById('ocRole').textContent = p.current_job_title || 'N/A';
            document.getElementById('ocExp').textContent = `${p.total_experience_years || 0}y ${p.total_experience_months || 0}m`;
            document.getElementById('ocLocation').textContent = p.location || 'Not set';
          }
        }
      } catch (e) {
        console.error("Error loading offcanvas profile", e);
      }
    }

    async function loadRecommendations() {
      try {
        const res = await fetch('/api/recommendations');
        const recs = await res.json();

        const container = document.getElementById('recommendationContainer');
        const list = document.getElementById('recScrollList');

        if (recs && recs.length > 0) {
          container.style.display = 'block';
          list.innerHTML = recs.map(job => `
            <div class="rec-card-premium" style="padding: 1rem; border-radius: 12px; min-width:240px; box-shadow:0 2px 8px rgba(0,0,0,0.03);">
              <div class="d-flex justify-content-between align-items-center mb-1">   
            </div>
              <h4 style="font-size:0.95rem; font-weight:700; color:var(--dark); margin-bottom:0.15rem; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;" title="${job.title}">${job.title}</h4>
              <div class="text-muted mb-2" style="font-size:0.75rem;">
                <i class="fas fa-building me-1"></i> <span style="white-space:nowrap; overflow:hidden; text-overflow:ellipsis; max-width:140px; display:inline-block; vertical-align:bottom;">${job.company}</span>
              </div>
              <div class="d-flex flex-wrap gap-1 mb-2" style="max-height: 20px; overflow: hidden;">
                ${job.matched_skills.slice(0, 3).map(s => `<span class="matched-skill-tag" style="font-size:0.6rem; padding:1px 5px; border-radius:4px; border:1px solid #e2e8f0;">${s}</span>`).join('')}
              </div>
              <button onclick="applyToJob(${job.job_id})" id="applyBtn-rec-${job.job_id}" class="btn btn-primary btn-sm w-100 fw-bold py-1" style="font-size:0.8rem; border-radius:6px;">Apply</button>
            </div>
          `).join('');
        }
      } catch (e) {
        console.error('Error fetching recommendations:', e);
      }
    }

    async function loadJobs() {
      try {
        const res = await fetch('/api/seeker/jobs');
        if (!res.ok || res.redirected) {
          const grid = document.getElementById('jobGrid');
          if (grid) {
            grid.innerHTML = `
              <div class="col-12">
                <div style="background:var(--white);border:1px solid var(--border);border-radius:var(--radius-lg);padding:4rem 2rem;text-align:center;">
                  <div style="width:80px;height:80px;background:rgba(79,70,229,0.08);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1.5rem;font-size:2rem;color:var(--primary);border:2px dashed rgba(79,70,229,0.2);">
                    <i class="fas fa-lock"></i>
                  </div>
                  <h4 class="fw-bold mb-2">Login to Browse Jobs</h4>
                  <p style="color:var(--gray);max-width:380px;margin:0 auto 1.75rem;font-size:0.9rem;">Please login as a Job Seeker to browse all available opportunities and apply in one click.</p>
                  <div class="d-flex justify-content-center gap-3 flex-wrap">
                    <a href="/login" class="btn-primary-premium"><i class="fas fa-sign-in-alt"></i> Login Now</a>
                    <a href="/register" class="btn-outline-premium" style="background:rgba(79,70,229,0.06);color:var(--primary);border-color:rgba(79,70,229,0.2);">Create Account</a>
                  </div>
                </div>
              </div>`;
          }
          return;
        }
        allJobs = await res.json();
        const badge = document.getElementById('jobCountBadge');
        populateDynamicFilters();
        renderJobs(allJobs);
      } catch (err) {
        const grid = document.getElementById('jobGrid');
        if (grid) grid.innerHTML = '<div class="col-12 text-center py-5 text-danger"><h5>Error loading jobs. Please refresh.</h5></div>';
      }
    }

    function renderJobs(jobs) {
      const grid = document.getElementById('jobGrid');
      if (!grid) return;
      if (jobs.length === 0) {
        grid.innerHTML = `
          <div class="col-12">
            <div class="empty-state" style="background:var(--white);border:1px solid var(--border);border-radius:var(--radius-lg);">
              <div class="empty-state-icon"><i class="fas fa-search"></i></div>
              <div class="empty-state-title">No Jobs Found</div>
              <div class="empty-state-text">Try adjusting your filters or search term.</div>
            </div>
          </div>`;
        return;
      }

      grid.innerHTML = jobs.map(job => `
        <div class="col-md-6 col-lg-4 col-xl-3">
          <div class="job-card h-100 d-flex flex-column" style="padding:1rem; border-radius:12px; box-shadow:0 2px 8px rgba(0,0,0,0.03); margin-bottom:0;">
            <div class="d-flex justify-content-between align-items-start mb-1">
              <div class="d-flex align-items-center gap-2">
                 <div style="width:24px;height:24px;background:rgba(79,70,229,0.08);border-radius:4px;display:flex;align-items:center;justify-content:center;color:var(--primary);">
                  <i class="fas fa-building" style="font-size:0.6rem;"></i>
                 </div>
                 <div style="font-size:0.8rem; font-weight:600; color:var(--dark); max-width:120px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;" title="${job.company_name || 'Company'}">${job.company_name || 'Company'}</div>
              </div>
              <div style="font-size:0.65rem; color:var(--gray);"><i class="fas fa-calendar me-1"></i>${new Date(job.created_at).toLocaleDateString('en-IN', { month: 'short', day: 'numeric' })}</div>
            </div>
            
            <div class="job-card-title mb-1" style="font-size:0.95rem; line-height:1.2; font-weight:700;">${job.title}</div>
            
            <div class="d-flex flex-wrap gap-2 mb-2">
              ${job.location ? `<span style="font-size:0.7rem; color:var(--gray);"><i class="fas fa-map-marker-alt me-1 text-primary"></i>${job.location}</span>` : ''}
              ${job.salary ? `<span style="font-size:0.7rem; color:var(--gray);"><i class="fas fa-money-bill-wave me-1 text-success"></i>₹${job.salary}</span>` : ''}
            </div>

            <div class="job-desc-container mt-0 mb-2">
              <p class="job-desc mb-0" id="desc-${job.id}" style="font-size:0.75rem; color:var(--dark-4); -webkit-line-clamp:2;">${job.description}</p>
              <button class="btn btn-link p-0 text-primary fw-bold" style="font-size:0.7rem; text-decoration:none; margin-top:0.25rem;" onclick="openJobModal(${job.id})">Read full description <i class="fas fa-arrow-right ms-1"></i></button>
            </div>
            
            <div class="mt-auto d-flex align-items-end justify-content-between">
              <div style="font-size:0.65rem; color:var(--gray-light);"><i class="fas fa-fingerprint me-1"></i>ID: ${job.job_id || 'N/A'}</div>
              <div style="min-width: 100px;">
              ${currentUser && currentUser.role === 'seeker'
          ? job.isApplied
            ? `<button class="btn btn-sm w-100 text-center" style="padding:0.35rem 0.6rem; font-size:0.75rem; font-weight:700; border-radius:6px; background:rgba(16,185,129,0.1); color:#059669; border:1px solid rgba(16,185,129,0.2); cursor:default;" disabled>
                         <i class="fas fa-check"></i> Applied
                       </button>`
            : `<button onclick="applyToJob(${job.id})" id="applyBtn-grid-${job.id}" class="btn btn-primary btn-sm w-100 text-center" style="padding:0.35rem 0.6rem; font-size:0.75rem; font-weight:700; border-radius:6px; background:linear-gradient(135deg,var(--primary),var(--primary-dark)); border:none;">
                         <i class="fas fa-paper-plane me-1"></i> Apply
                       </button>`
          : currentUser
            ? `<button class="btn btn-sm w-100 text-center" style="padding:0.35rem 0.6rem; font-size:0.75rem; font-weight:700; border-radius:6px; background:var(--bg); border:1px solid var(--border); color:var(--gray); cursor:default;" disabled>Seekers Only</button>`
            : `<a href="/login" class="btn btn-sm w-100 text-center" style="padding:0.35rem 0.6rem; font-size:0.75rem; font-weight:700; border-radius:6px; background:rgba(79,70,229,0.08); color:var(--primary); border:1px solid rgba(79,70,229,0.2);">Login</a>`
        }
              </div>
            </div>
          </div>
        </div>
      `).join('');
    }

    async function applyToJob(jobId) {
      // Find all apply buttons (in recommendations and main grid)
      const buttons = [
        document.getElementById(`applyBtn-rec-${jobId}`),
        document.getElementById(`applyBtn-grid-${jobId}`)
      ].filter(btn => btn !== null);

      if (buttons.length === 0) return;

      const originalContents = buttons.map(btn => btn.innerHTML);
      buttons.forEach(btn => {
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>...';
      });

      try {
        const result = await window.apiService.applyToJob(jobId);
        if (result.success) {
          buttons.forEach(btn => {
            btn.style.background = 'rgba(16,185,129,0.1)';
            btn.style.color = '#059669';
            btn.style.border = '1.5px solid rgba(16,185,129,0.2)';
            btn.innerHTML = '<i class="fas fa-check me-1"></i>Applied';
            btn.disabled = true;
            btn.style.cursor = 'default';
          });

          Swal.fire({
            icon: 'success',
            title: 'Great Job!',
            text: 'You have applied successfully.',
            timer: 2000,
            showConfirmButton: false
          }).then(() => {
            if (result.redirectTo) {
              window.location.href = result.redirectTo;
            }
          });
        } else {
          buttons.forEach((btn, i) => {
            btn.disabled = false;
            btn.innerHTML = originalContents[i];
          });
          if (result.message === 'Please complete your profile first.') {
            Swal.fire({
              icon: 'warning',
              title: 'Profile Incomplete',
              text: 'Please complete your profile before applying.',
              showCancelButton: true,
              confirmButtonText: 'Go to Profile Page',
              cancelButtonText: 'Not Now'
            }).then((res) => {
              if (res.isConfirmed) {
                window.location.href = '/seeker/complete-profile';
              }
            });
          } else {
            Swal.fire('Oops...', result.message || 'Error applying.', 'error');
          }
        }
      } catch (err) {
        buttons.forEach((btn, i) => {
          btn.disabled = false;
          btn.innerHTML = originalContents[i];
        });
        Swal.fire('Error', 'An error occurred.', 'error');
      }
    }

    function openJobModal(jobId) {
      const job = allJobs.find(j => j.id === jobId || j.job_id === jobId);
      if (!job) return;
      document.getElementById('jobModalTitle').textContent = job.title;
      document.getElementById('jobModalCompany').innerHTML = `<i class="fas fa-building me-1 text-primary"></i> ${job.company_name || 'Hiring Company'}`;
      document.getElementById('jobModalLocation').innerHTML = `<i class="fas fa-map-marker-alt me-1 text-primary"></i> ${job.location || 'N/A'}`;
      document.getElementById('jobModalSalary').innerHTML = `<i class="fas fa-money-bill-wave me-1 text-success"></i> ${job.salary ? '₹' + job.salary : 'Not specified'}`;
      document.getElementById('jobModalDesc').innerHTML = job.description ? job.description.replace(/\n/g, '<br>') : 'No description provided for this role.';

      const modal = new bootstrap.Modal(document.getElementById('jobDetailsModal'));
      modal.show();
    }
  </script>

  <!-- ===== JOB DETAILS MODAL ===== -->
  <div class="modal fade" id="jobDetailsModal" tabindex="-1" aria-labelledby="jobDetailsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-lg">
      <div class="modal-content" style="border-radius:16px; border:none; box-shadow:0 10px 30px rgba(0,0,0,0.1);">
        <div class="modal-header bg-light" style="border-bottom:1px solid rgba(0,0,0,0.05); padding:1.5rem;">
          <div>
            <h4 class="modal-title fw-bold text-dark mb-2" id="jobModalTitle" style="font-size:1.4rem;">Job Title</h4>
            <div class="d-flex flex-wrap gap-3 text-muted" style="font-size:0.85rem;">
              <span id="jobModalCompany" class="fw-semibold"></span>
              <span id="jobModalLocation" class="fw-semibold"></span>
              <span id="jobModalSalary" class="fw-semibold"></span>
            </div>
          </div>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"
            style="align-self:flex-start;"></button>
        </div>
        <div class="modal-body" style="padding:1.5rem; font-size:0.95rem; line-height:1.7; color:var(--dark-3);">
          <h6 class="fw-bold text-dark mb-3" style="font-size:1.05rem;">Job Description:</h6>
          <div id="jobModalDesc" style="white-space:pre-wrap;"></div>
        </div>
        <div class="modal-footer bg-light" style="border-top:1px solid rgba(0,0,0,0.05); padding:1rem 1.5rem;">
          <button type="button" class="btn btn-outline-secondary fw-bold px-4" style="border-radius:8px;"
            data-bs-dismiss="modal">Close</button>
        </div>
      </div>
    </div>
  </div>

  <!-- ===== AI CAREER MENTOR CHATBOT ===== -->
  <button id="chatbot-toggle-btn" class="chatbot-toggle-btn" style="display:none;">
    <i class="fas fa-robot"></i> Ask Career Mentor
  </button>

  <div id="chatbot-container" class="chatbot-container d-none">
    <div class="chatbot-header">
      <div class="d-flex align-items-center gap-2">
        <div class="chatbot-avatar"><i class="fas fa-robot"></i></div>
        <div>
          <h5 class="mb-0 text-white" style="font-size:1rem;font-weight:600;">AI Mentor</h5>
          <small style="color:rgba(255,255,255,0.8);font-size:0.75rem;">Online</small>
        </div>
      </div>
      <button id="chatbot-close-btn" class="btn-close btn-close-white"></button>
    </div>

    <div class="chatbot-messages" id="chatbot-messages">
      <div class="message bot-message">
        Hi there! I'm your AI Career Mentor. I've reviewed your profile and I'm ready to help. What would you like to
        know?
      </div>
    </div>

    <div class="chatbot-suggestions">
      <button class="chat-suggestion-btn">What skills should I learn?</button>
      <button class="chat-suggestion-btn">Am I ready for my desired role?</button>
      <button class="chat-suggestion-btn">Improve my resume</button>
    </div>

    <div class="chatbot-input-area">
      <input type="text" id="chatbot-input" placeholder="Type your message..." autocomplete="off">
      <button id="chatbot-send-btn"><i class="fas fa-paper-plane"></i></button>
    </div>
  </div>

  <script src="/js/chatbot.js?v=1.1"></script>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const logoutLinks = document.querySelectorAll('a[href="/api/auth/logout"]');
      logoutLinks.forEach(link => {
        link.addEventListener('click', function (e) {
          e.preventDefault();
          Swal.fire({
            title: 'Confirm Logout',
            text: 'Are you sure you want to sign out of your session?',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#ef4444',
            cancelButtonColor: '#6b7280',
            confirmButtonText: '<i class="fas fa-sign-out-alt me-2"></i>Logout Now'
          }).then((result) => {
            if (result.isConfirmed) {
              window.location.href = '/api/auth/logout';
            }
          });
        });
      });
    });
  </script>
</body>

</html>
