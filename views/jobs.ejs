<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — Smart Job Portal</title>
  <meta name="description" content="Browse and apply to the latest job openings on Smart Job Portal.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/chatbot.css?v=1.1">
  <style>
    .filter-sidebar {
      background: #fff;
      border-radius: var(--radius-lg);
      border: 1px solid var(--border);
      padding: 1.5rem;
      position: sticky;
      top: 6rem;
      max-height: calc(100vh - 8rem);
      overflow-y: auto;
    }
    .filter-section {
      margin-bottom: 2rem;
    }
    .filter-section:last-child {
      margin-bottom: 0;
    }
    .filter-title {
      font-weight: 700;
      font-size: 0.9rem;
      color: var(--dark);
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .filter-option {
      display: block;
      margin-bottom: 0.5rem;
      cursor: pointer;
      font-size: 0.875rem;
      color: var(--gray);
      transition: var(--transition);
    }
    .filter-option:hover {
      color: var(--primary);
    }
    .filter-checkbox {
      margin-right: 0.5rem;
      accent-color: var(--primary);
    }
    .clear-filters {
      font-size: 0.8rem;
      color: var(--primary);
      text-decoration: none;
      font-weight: 600;
      cursor: pointer;
    }
    .clear-filters:hover {
      text-decoration: underline;
    }
    .job-count-indicator {
      font-size: 0.85rem;
      color: var(--gray);
      margin-bottom: 1.5rem;
    }
    .job-desc-container {
      position: relative;
      margin-bottom: 1.5rem;
    }
    .job-desc {
      font-size: 0.875rem;
      color: var(--dark-3);
      line-height: 1.6;
      word-break: break-word;
      overflow: hidden;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      line-clamp: 3;
      -webkit-box-orient: vertical;
      transition: all 0.3s ease;
    }
    .job-desc.expanded {
      -webkit-line-clamp: unset;
      line-clamp: unset;
      display: block;
    }
    .desc-toggle-btn {
      background: none;
      border: none;
      color: var(--primary);
      font-size: 0.75rem;
      font-weight: 700;
      padding: 0;
      margin-top: 0.5rem;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 0.25rem;
      transition: var(--transition);
    }
    .desc-toggle-btn:hover {
      opacity: 0.8;
      text-decoration: underline;
    }
    .desc-toggle-btn i {
      transition: transform 0.3s ease;
    }
    .desc-toggle-btn.expanded i {
      transform: rotate(180deg);
    }
    /* Recommendation Card Styling */
    .rec-card-premium {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 1.25rem;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      height: 100%;
      min-width: 280px;
      position: relative;
    }
    .rec-card-premium:hover {
      border-color: var(--primary);
      box-shadow: 0 10px 25px -5px rgba(0,0,0,0.05);
      transform: translateY(-4px);
    }
    .match-badge-jobs {
      background: rgba(129,140,248,0.1);
      color: var(--primary);
      padding: 4px 10px;
      border-radius: 20px;
      font-size: 0.72rem;
      font-weight: 700;
      display: inline-flex;
      align-items: center;
      gap: 4px;
    }
    .matched-skill-tag {
      font-size: 0.65rem;
      background: #f3f4f6;
      color: #4b5563;
      padding: 2px 8px;
      border-radius: 4px;
      font-weight: 500;
    }
  </style>
</head>
<body class="dashboard-page">

  <!-- ===== NAVBAR ===== -->
  <nav class="navbar navbar-expand-lg navbar-premium">
    <div class="container">
      <a class="navbar-brand" href="/">
        <i class="fas fa-briefcase me-2" style="color:#818cf8;"></i>SmartJobPortal
      </a>
      <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navJobs" style="color:rgba(255,255,255,0.7);">
        <i class="fas fa-bars"></i>
      </button>
      <div class="collapse navbar-collapse" id="navJobs">
        <ul class="navbar-nav ms-auto align-items-center gap-1">
          <li class="nav-item"><a class="nav-link active" href="/jobs"><i class="fas fa-search me-1"></i>Browse Jobs</a></li>
          <li class="nav-item" id="navDashboard" style="display:none;"><a class="nav-link" href="#" id="dashLink">Dashboard</a></li>
          <li class="nav-item" id="navLogout" style="display:none;">
            <a class="btn-nav-danger" href="/api/auth/logout"><i class="fas fa-sign-out-alt me-1"></i>Logout</a>
          </li>
          <li class="nav-item" id="navLogin">
            <a class="btn-nav-cta" href="/login">Login <i class="fas fa-arrow-right ms-1" style="font-size:0.8rem;"></i></a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <!-- ===== PAGE HEADER ===== -->
  <div style="background:linear-gradient(135deg,#0f172a 0%,#1e1b4b 100%);padding:3.5rem 0 3rem;">
    <div class="container text-center">
      <div class="hero-badge mb-3" style="display:inline-flex;margin:0 auto;">
        <span class="dot"></span> <span id="jobCountBadge">Explore Opportunities</span>
      </div>
      <h1 style="color:#fff;font-size:2.25rem;font-weight:800;letter-spacing:-1px;margin-bottom:0.75rem;">
        Discover Your <span style="background:linear-gradient(135deg,#a5b4fc,#67e8f9);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">Next Career</span> Move
      </h1>
      <p style="color:rgba(255,255,255,0.55);font-size:0.95rem;max-width:480px;margin:0 auto 2rem;">
        Hand-picked opportunities from verified companies, all in one place.
      </p>
      <!-- Search bar -->
      <div style="max-width:540px;margin:0 auto;">
        <div class="search-bar" style="padding:0.25rem 0.25rem 0.25rem 1.25rem;border-radius:50px;background:rgba(255,255,255,0.95);border:none;">
          <i class="fas fa-search search-bar-icon" style="color:var(--gray);"></i>
          <input type="text" id="globalSearch" placeholder="Search job title, company, or skills..."
            style="background:transparent;color:var(--dark);">
          <button onclick="filterJobs()" id="searchBtn" style="background:linear-gradient(135deg,var(--primary),var(--primary-dark));color:#fff;border:none;padding:0.6rem 1.5rem;border-radius:50px;font-family:var(--font);font-weight:700;font-size:0.875rem;cursor:pointer;">
            Search
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- ===== MAIN CONTENT ===== -->
  <div class="container py-5">
    <div class="row g-4">
      <!-- Sidebar Filters -->
      <div class="col-lg-3">
        <div class="filter-sidebar">
          <div class="d-flex justify-content-between align-items-center mb-4">
            <h5 class="fw-bold mb-0" style="font-size:1.1rem;">Filters</h5>
            <span class="clear-filters" onclick="resetFilters()">Clear All</span>
          </div>

          <!-- Location -->
          <div class="filter-section">
            <div class="filter-title"><i class="fas fa-map-marker-alt text-primary"></i> Location</div>
            <div id="locationFilters">
              <!-- Dynamically Populated -->
            </div>
          </div>

          <!-- Salary Range -->
          <div class="filter-section">
            <div class="filter-title"><i class="fas fa-money-bill-wave text-success"></i> Salary (Monthly)</div>
            <label class="filter-option"><input type="checkbox" class="filter-checkbox salary-filter" value="0-20000"> ₹0 - ₹20,000</label>
            <label class="filter-option"><input type="checkbox" class="filter-checkbox salary-filter" value="20000-50000"> ₹20,000 - ₹50,000</label>
            <label class="filter-option"><input type="checkbox" class="filter-checkbox salary-filter" value="50000-100000"> ₹50,000 - ₹1,00,000</label>
            <label class="filter-option"><input type="checkbox" class="filter-checkbox salary-filter" value="100000+"> ₹1,00,000++</label>
          </div>

          <!-- Company -->
          <div class="filter-section">
            <div class="filter-title"><i class="fas fa-user-tie text-info"></i> Company</div>
            <div id="companyFilters">
              <!-- Dynamically Populated -->
            </div>
          </div>

          <!-- Date Posted -->
          <div class="filter-section">
            <div class="filter-title"><i class="fas fa-calendar-alt text-warning"></i> Date Posted</div>
            <label class="filter-option"><input type="radio" name="datePosted" class="filter-radio" value="all" checked> All Time</label>
            <label class="filter-option"><input type="radio" name="datePosted" class="filter-radio" value="today"> Last 24 Hours</label>
            <label class="filter-option"><input type="radio" name="datePosted" class="filter-radio" value="week"> Last 7 Days</label>
            <label class="filter-option"><input type="radio" name="datePosted" class="filter-radio" value="month"> Last 30 Days</label>
          </div>
        </div>
      </div>

      <!-- Job Grid -->
      <div class="col-lg-9">
        <!-- ===== PERSONALIZED RECOMMENDATIONS ===== -->
        <div id="recommendationContainer" style="display:none; margin-bottom:2.5rem;">
          <div class="d-flex align-items-center justify-content-between mb-3">
            <h5 class="fw-bold mb-0" style="font-size:1.15rem; color:var(--dark);"><i class="fas fa-magic text-primary me-2"></i>Personalized For You</h5>
            <div class="d-flex gap-2">
               <button class="btn btn-sm btn-light scroll-btn" onclick="document.getElementById('recScrollList').scrollBy({left:-300,behavior:'smooth'})"><i class="fas fa-chevron-left"></i></button>
               <button class="btn btn-sm btn-light scroll-btn" onclick="document.getElementById('recScrollList').scrollBy({left:300,behavior:'smooth'})"><i class="fas fa-chevron-right"></i></button>
            </div>
          </div>
          <div id="recScrollList" class="d-flex gap-3 overflow-auto pb-3" style="scrollbar-width:none; -ms-overflow-style:none;">
            <!-- Recommendations injected here -->
          </div>
        </div>

        <div class="job-count-indicator" id="jobCountIndicator">Showing all jobs</div>
        <div class="row g-4" id="jobGrid">
          <div class="col-12">
            <div class="loading-overlay py-5">
              <div class="spinner-border text-primary"></div>
              <span>Loading jobs...</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/apiService.js"></script>
  <script>
    let currentUser = null;
    let allJobs = [];

    document.getElementById('globalSearch').addEventListener('keyup', function(e) {
      if (e.key === 'Enter') filterJobs();
    });

    // Listen for changes in checkboxes and radios
    document.addEventListener('change', (e) => {
      if (e.target.classList.contains('filter-checkbox') || e.target.classList.contains('filter-radio')) {
        filterJobs();
      }
    });

    function resetFilters() {
      document.getElementById('globalSearch').value = '';
      document.querySelectorAll('.filter-checkbox').forEach(cb => cb.checked = false);
      const allTimeRadio = document.querySelector('input[name="datePosted"][value="all"]');
      if(allTimeRadio) allTimeRadio.checked = true;
      filterJobs();
    }

    function populateDynamicFilters() {
      const locations = [...new Set(allJobs.map(j => j.location).filter(Boolean))].sort();
      const companies = [...new Set(allJobs.map(j => j.company_name).filter(Boolean))].sort();

      const locContainer = document.getElementById('locationFilters');
      if(locContainer) {
        locContainer.innerHTML = locations.map(loc => `
          <label class="filter-option">
            <input type="checkbox" class="filter-checkbox location-filter" value="${loc}"> ${loc}
          </label>
        `).join('') || '<div class="text-muted small">No locations found</div>';
      }

      const compContainer = document.getElementById('companyFilters');
      if(compContainer) {
        compContainer.innerHTML = companies.map(comp => `
          <label class="filter-option">
            <input type="checkbox" class="filter-checkbox company-filter" value="${comp}"> ${comp}
          </label>
        `).join('') || '<div class="text-muted small">No companies found</div>';
      }
    }

    function filterJobs() {
      const q = document.getElementById('globalSearch').value.toLowerCase().trim();
      
      // Get selected locations
      const selectedLocs = Array.from(document.querySelectorAll('.location-filter:checked')).map(cb => cb.value);
      
      // Get selected companies
      const selectedComps = Array.from(document.querySelectorAll('.company-filter:checked')).map(cb => cb.value);
      
      // Get selected salary ranges
      const selectedSalaries = Array.from(document.querySelectorAll('.salary-filter:checked')).map(cb => cb.value);
      
      // Get date range
      const datePostedRadio = document.querySelector('input[name="datePosted"]:checked');
      const dateRange = datePostedRadio ? datePostedRadio.value : 'all';
      const now = new Date();

      const filtered = allJobs.filter(j => {
        // Search Match
        const searchMatch = !q || 
          j.title.toLowerCase().includes(q) ||
          (j.company_name && j.company_name.toLowerCase().includes(q)) ||
          (j.location && j.location.toLowerCase().includes(q)) ||
          (j.keywords && j.keywords.toLowerCase().includes(q));

        // Location Match
        const locMatch = selectedLocs.length === 0 || selectedLocs.includes(j.location);

        // Company Match
        const compMatch = selectedComps.length === 0 || selectedComps.includes(j.company_name);

        // Salary Match (Simple numeric extraction for demo)
        let salaryMatch = selectedSalaries.length === 0;
        if (!salaryMatch) {
          const jobSalary = parseInt(j.salary ? j.salary.replace(/[^0-9]/g, '') : '0') || 0;
          salaryMatch = selectedSalaries.some(range => {
            if (range === '100000+') return jobSalary >= 100000;
            const [min, max] = range.split('-').map(Number);
            return jobSalary >= min && jobSalary <= max;
          });
        }

        // Date Match
        let dateMatch = true;
        const jobDate = new Date(j.created_at);
        const diffMs = now - jobDate;
        const diffDays = diffMs / (1000 * 60 * 60 * 24);
        if (dateRange === 'today') dateMatch = diffDays <= 1;
        else if (dateRange === 'week') dateMatch = diffDays <= 7;
        else if (dateRange === 'month') dateMatch = diffDays <= 30;

        return searchMatch && locMatch && compMatch && salaryMatch && dateMatch;
      });

      const indicator = document.getElementById('jobCountIndicator');
      if(indicator) indicator.textContent = `Found ${filtered.length} jobs`;
      renderJobs(filtered);
    }

    document.addEventListener('DOMContentLoaded', async () => {
      await checkAuth();
      await loadJobs();
    });

    async function checkAuth() {
      try {
        const res = await fetch('/api/auth/me');
        if (res.ok) {
          currentUser = await res.json();
          document.getElementById('navLogin').style.display = 'none';
          document.getElementById('navLogout').style.display = 'block';
          const dash = document.getElementById('navDashboard');
          if(dash) dash.style.display = 'block';
          const link = document.getElementById('dashLink');
          if(link) {
            if (currentUser.role === 'recruiter') { link.href = '/recruiter/dashboard'; link.textContent = 'Dashboard'; }
            else if (currentUser.role === 'seeker') { 
              link.href = '/seeker/dashboard'; 
              link.textContent = 'My Applications'; 
              loadRecommendations();
              const chatBtn = document.getElementById('chatbot-toggle-btn');
              if (chatBtn) chatBtn.style.display = 'flex';
            }
            else if (currentUser.role === 'admin') { link.href = '/admin'; link.textContent = 'Admin Panel'; }
          }
        }
      } catch (e) { console.log('Not logged in'); }
    }

    async function loadRecommendations() {
      try {
        const res = await fetch('/api/recommendations');
        const recs = await res.json();
        
        const container = document.getElementById('recommendationContainer');
        const list = document.getElementById('recScrollList');
        
        if (recs && recs.length > 0) {
          container.style.display = 'block';
          list.innerHTML = recs.map(job => `
            <div class="rec-card-premium">
              <div class="d-flex justify-content-between align-items-start mb-2">
                <div class="match-badge-jobs">
                  <i class="fas fa-bolt"></i> ${job.match_score}% Match
                </div>
                <div style="font-size:0.8rem; font-weight:700; color:var(--dark);">${job.salary ? '₹'+job.salary : 'Best'}</div>
              </div>
              <h4 style="font-size:1rem; font-weight:700; color:var(--dark); margin-bottom:0.25rem; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">${job.title}</h4>
              <div class="text-muted mb-3" style="font-size:0.85rem;">
                <i class="fas fa-building me-1"></i> ${job.company}
              </div>
              <div class="d-flex flex-wrap gap-1 mb-3">
                ${job.matched_skills.map(s => `<span class="matched-skill-tag">${s}</span>`).join('')}
              </div>
              <button onclick="applyToJob(${job.job_id})" id="applyBtn-${job.job_id}" class="btn btn-primary btn-sm w-100 fw-bold py-2" style="border-radius:8px;">Apply Now</button>
            </div>
          `).join('');
        }
      } catch (e) {
        console.error('Error fetching recommendations:', e);
      }
    }

    async function loadJobs() {
      try {
        const res = await fetch('/api/seeker/jobs');
        if (!res.ok || res.redirected) {
          const grid = document.getElementById('jobGrid');
          if(grid) {
            grid.innerHTML = `
              <div class="col-12">
                <div style="background:var(--white);border:1px solid var(--border);border-radius:var(--radius-lg);padding:4rem 2rem;text-align:center;">
                  <div style="width:80px;height:80px;background:rgba(79,70,229,0.08);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1.5rem;font-size:2rem;color:var(--primary);border:2px dashed rgba(79,70,229,0.2);">
                    <i class="fas fa-lock"></i>
                  </div>
                  <h4 class="fw-bold mb-2">Login to Browse Jobs</h4>
                  <p style="color:var(--gray);max-width:380px;margin:0 auto 1.75rem;font-size:0.9rem;">Please login as a Job Seeker to browse all available opportunities and apply in one click.</p>
                  <div class="d-flex justify-content-center gap-3 flex-wrap">
                    <a href="/login" class="btn-primary-premium"><i class="fas fa-sign-in-alt"></i> Login Now</a>
                    <a href="/register" class="btn-outline-premium" style="background:rgba(79,70,229,0.06);color:var(--primary);border-color:rgba(79,70,229,0.2);">Create Account</a>
                  </div>
                </div>
              </div>`;
          }
          return;
        }
        allJobs = await res.json();
        const badge = document.getElementById('jobCountBadge');
        if(badge) badge.textContent = `${allJobs.length} Jobs Available`;
        populateDynamicFilters();
        renderJobs(allJobs);
      } catch (err) {
        const grid = document.getElementById('jobGrid');
        if(grid) grid.innerHTML = '<div class="col-12 text-center py-5 text-danger"><h5>Error loading jobs. Please refresh.</h5></div>';
      }
    }

    function renderJobs(jobs) {
      const grid = document.getElementById('jobGrid');
      if(!grid) return;
      if (jobs.length === 0) {
        grid.innerHTML = `
          <div class="col-12">
            <div class="empty-state" style="background:var(--white);border:1px solid var(--border);border-radius:var(--radius-lg);">
              <div class="empty-state-icon"><i class="fas fa-search"></i></div>
              <div class="empty-state-title">No Jobs Found</div>
              <div class="empty-state-text">Try adjusting your filters or search term.</div>
            </div>
          </div>`;
        return;
      }

      grid.innerHTML = jobs.map(job => `
        <div class="col-md-6 col-xxl-4">
          <div class="job-card h-100 d-flex flex-column">
            <div class="job-card-company">
              <div style="width:26px;height:26px;background:rgba(79,70,229,0.08);border-radius:6px;display:flex;align-items:center;justify-content:center;color:var(--primary);">
                <i class="fas fa-building" style="font-size:0.7rem;"></i>
              </div>
              ${job.company_name || 'Hiring Company'}
            </div>
            <div class="job-card-title">${job.title}</div>
            <div class="job-id-tag"><i class="fas fa-fingerprint" style="font-size:0.65rem;"></i>Job ID: ${job.job_id || 'N/A'}</div>
            <div class="job-card-meta">
              ${job.location ? `<span class="job-meta-item"><i class="fas fa-map-marker-alt"></i>${job.location}</span>` : ''}
              ${job.salary ? `<span class="job-meta-item"><i class="fas fa-money-bill-wave"></i>₹${job.salary}</span>` : ''}
              <span class="job-meta-item"><i class="fas fa-calendar"></i>${new Date(job.created_at).toLocaleDateString('en-IN',{month:'short',day:'numeric'})}</span>
            </div>
            <div class="job-desc-container">
              <p class="job-desc" id="desc-${job.id}">${job.description}</p>
              ${job.description.length > 150 ? `
                <button class="desc-toggle-btn" onclick="toggleDesc(${job.id}, this)">
                  <span class="btn-text">Read More</span> <i class="fas fa-chevron-down"></i>
                </button>
              ` : ''}
            </div>
            <div class="mt-auto">
              ${currentUser && currentUser.role === 'seeker'
                ? job.isApplied 
                   ? `<button class="btn-primary-premium w-100 justify-content-center" style="padding:0.65rem; background:rgba(16,185,129,0.1); color:#059669; border:1.5px solid rgba(16,185,129,0.2); cursor:default;" disabled>
                        <i class="fas fa-check me-2"></i>Applied Successfully!
                      </button>`
                   : `<button onclick="applyToJob(${job.id})" id="applyBtn-${job.id}" class="btn-primary-premium w-100 justify-content-center" style="padding:0.65rem;">
                        <i class="fas fa-paper-plane"></i> Apply Now
                      </button>`
                : currentUser
                  ? `<button class="btn w-100 fw-bold py-2" style="background:var(--bg);border:1px solid var(--border);color:var(--gray);border-radius:10px;cursor:default;" disabled>Seekers Only</button>`
                  : `<a href="/login" class="btn w-100 fw-bold py-2" style="background:rgba(79,70,229,0.08);color:var(--primary);border:1.5px solid rgba(79,70,229,0.2);border-radius:10px;">Login to Apply</a>`
              }
            </div>
          </div>
        </div>
      `).join('');
    }

    async function applyToJob(jobId) {
      const btn = document.getElementById(`applyBtn-${jobId}`);
      if (!btn) return;
      const orig = btn.innerHTML;
      btn.disabled = true;
      btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Submitting...';
      try {
        const result = await window.apiService.applyToJob(jobId);
        if (result.success) {
          btn.style.background = 'rgba(16,185,129,0.1)';
          btn.style.color = '#059669';
          btn.style.border = '1.5px solid rgba(16,185,129,0.2)';
          btn.innerHTML = '<i class="fas fa-check me-2"></i>Applied Successfully!';
        } else {
          btn.disabled = false;
          btn.innerHTML = orig;
          if (result.message === 'Please complete your profile first.') {
            if (confirm('Please complete your profile before applying. Go to profile page?')) {
              window.location.href = '/seeker/complete-profile';
            }
          } else {
            alert(result.message || 'Error applying.');
          }
        }
      } catch (err) {
        btn.disabled = false;
        btn.innerHTML = orig;
        alert('An error occurred.');
      }
    }

    function toggleDesc(jobId, btn) {
      const desc = document.getElementById(`desc-${jobId}`);
      const isExpanded = desc.classList.toggle('expanded');
      btn.classList.toggle('expanded', isExpanded);
      btn.querySelector('.btn-text').textContent = isExpanded ? 'Read Less' : 'Read More';
    }
  </script>

  <!-- ===== AI CAREER MENTOR CHATBOT ===== -->
  <button id="chatbot-toggle-btn" class="chatbot-toggle-btn" style="display:none;">
    <i class="fas fa-robot"></i> Ask Career Mentor
  </button>

  <div id="chatbot-container" class="chatbot-container d-none">
    <div class="chatbot-header">
      <div class="d-flex align-items-center gap-2">
        <div class="chatbot-avatar"><i class="fas fa-robot"></i></div>
        <div>
          <h5 class="mb-0 text-white" style="font-size:1rem;font-weight:600;">AI Mentor</h5>
          <small style="color:rgba(255,255,255,0.8);font-size:0.75rem;">Online</small>
        </div>
      </div>
      <button id="chatbot-close-btn" class="btn-close btn-close-white"></button>
    </div>
    
    <div class="chatbot-messages" id="chatbot-messages">
      <div class="message bot-message">
        Hi there! I'm your AI Career Mentor. I've reviewed your profile and I'm ready to help. What would you like to know?
      </div>
    </div>

    <div class="chatbot-suggestions">
      <button class="chat-suggestion-btn">What skills should I learn?</button>
      <button class="chat-suggestion-btn">Am I ready for my desired role?</button>
      <button class="chat-suggestion-btn">Improve my resume</button>
    </div>

    <div class="chatbot-input-area">
      <input type="text" id="chatbot-input" placeholder="Type your message..." autocomplete="off">
      <button id="chatbot-send-btn"><i class="fas fa-paper-plane"></i></button>
    </div>
  </div>
  
  <script src="/js/chatbot.js?v=1.1"></script>
</body>
</html>
