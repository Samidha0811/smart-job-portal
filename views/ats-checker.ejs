<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %> | Smart Job Portal
    </title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/ats.css">
</head>

<body class="bg-dark-premium">

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-premium">
        <div class="container">
            <a class="navbar-brand" href="/">
                <i class="fas fa-briefcase me-2" style="color:#818cf8;"></i>SmartJobPortal
            </a>
            <div class="ms-auto">
                <a href="/" class="btn btn-outline-light btn-sm rounded-pill px-3">
                    <i class="fas fa-arrow-left me-1"></i> Back to Home
                </a>
            </div>
        </div>
    </nav>

    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="text-center mb-5 animate-fade-in">
                    <div class="hero-badge mx-auto mb-3">
                        <span class="dot"></span> AI-Powered Analysis
                    </div>
                    <h1 class="display-5 fw-800 text-white mb-3">ATS Resume <span class="gradient-text">Score
                            Checker</span></h1>
                    <p class="text-gray mx-auto" style="max-width: 600px;">
                        Upload your resume and the job description to see how well you match.
                        Get instant feedback and actionable tips to land your dream interview.
                    </p>
                </div>

                <div class="row g-4">
                    <!-- Input Section -->
                    <div class="col-md-6">
                        <div class="ats-card p-4 h-100 animate-fade-in-up">
                            <h4 class="text-white mb-4"><i class="fas fa-file-alt text-primary me-2"></i> Your Resume
                            </h4>

                            <div class="mb-4">
                                <label class="text-gray mb-2 small fw-600 text-uppercase">1. Choose Input Method</label>
                                <div class="btn-group w-100 mb-3" role="group">
                                    <input type="radio" class="btn-check" name="resumeType" id="typeUpload"
                                        value="upload" checked>
                                    <label class="btn btn-outline-premium-sm" for="typeUpload">
                                        <i class="fas fa-upload me-1"></i> Upload PDF
                                    </label>
                                    <input type="radio" class="btn-check" name="resumeType" id="typePaste"
                                        value="paste">
                                    <label class="btn btn-outline-premium-sm" for="typePaste">
                                        <i class="fas fa-keyboard me-1"></i> Paste Text
                                    </label>
                                </div>
                            </div>

                            <div id="uploadContainer" class="mb-4">
                                <div class="upload-area" id="dropZone">
                                    <input type="file" id="resumeFile" accept=".pdf" class="d-none">
                                    <i class="fas fa-cloud-upload-alt mb-3"></i>
                                    <p class="mb-1 text-white">Click or drag PDF here</p>
                                    <p class="small text-gray">Only .pdf files accepted</p>
                                    <div id="fileName" class="mt-2 text-primary d-none small"></div>
                                </div>
                            </div>

                            <div id="pasteContainer" class="mb-4 d-none">
                                <textarea id="resumeText" class="form-control premium-input h-150"
                                    placeholder="Paste your resume content here..."></textarea>
                            </div>
                        </div>
                    </div>

                    <!-- Job Description Section -->
                    <div class="col-md-6">
                        <div class="ats-card p-4 h-100 animate-fade-in-up delay-1">
                            <h4 class="text-white mb-4"><i class="fas fa-briefcase text-primary me-2"></i> Job
                                Description</h4>
                            <div class="mb-4">
                                <label class="text-gray mb-2 small fw-600 text-uppercase">2. Provide
                                    Requirements</label>
                                <textarea id="jobDescription" class="form-control premium-input h-400"
                                    placeholder="Paste the job description from the company website here..."
                                    style="height: 280px;">
                                </textarea>
                                <div class="text-end mt-1 ">
                                    <span class="small text-gray" id="charCount">0 characters</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- CTA Button -->
                    <div class="col-12 text-center mt-4">
                        <button id="checkScoreBtn"
                            class="btn btn-primary-premium px-5 py-3 rounded-pill animate-fade-in delay-2">
                            <i class="fas fa-rocket me-2"></i> Check ATS Score Now
                        </button>
                    </div>
                </div>

                <!-- Results Section (Hidden initially) -->
                <div id="resultsSection" class="mt-5 d-none pb-5">
                    <div class="ats-card p-5 animate-scale-up">
                        <div class="row align-items-center">
                            <div class="col-md-4 text-center">
                                <div class="score-circle-container mb-3">
                                    <svg viewBox="0 0 100 100">
                                        <circle cx="50" cy="50" r="45" class="bg-circle"></circle>
                                        <circle cx="50" cy="50" r="45" class="progress-circle" id="scoreCircle">
                                        </circle>
                                    </svg>
                                    <div class="score-value">
                                        <span id="finalScoreVal">0</span><small>%</small>
                                    </div>
                                </div>
                                <h4 class="text-white">Match Score</h4>
                                <div id="scoreLabel" class="badge rounded-pill px-3 py-2 small">Low Match</div>
                            </div>
                            <div class="col-md-8">
                                <div class="row g-3 mb-4">
                                    <div class="col-4">
                                        <div class="stat-box">
                                            <div class="stat-label">Keywords</div>
                                            <div class="stat-val" id="keywordStat">0%</div>
                                        </div>
                                    </div>
                                    <div class="col-4">
                                        <div class="stat-box">
                                            <div class="stat-label">Sections</div>
                                            <div class="stat-val" id="sectionStat">0%</div>
                                        </div>
                                    </div>
                                    <div class="col-4">
                                        <div class="stat-box">
                                            <div class="stat-label">Length</div>
                                            <div class="stat-val" id="lengthStat">0%</div>
                                        </div>
                                    </div>
                                </div>

                                <h5 class="text-white mb-3"><i class="fas fa-lightbulb text-warning me-2"></i>
                                    Actionable Suggestions</h5>
                                <ul id="suggestionsList" class="suggestions-list mb-4">
                                    <!-- Suggestions will be injected here -->
                                </ul>

                                <h5 class="text-white mb-3"><i class="fas fa-tags text-primary me-2"></i> Missing
                                    Keywords</h5>
                                <div id="missingKeywords" class="keyword-chips">
                                    <!-- Keywords will be injected here -->
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="footer-premium py-4 mt-auto">
        <div class="container text-center">
            <p class="text-gray small mb-0">&copy; 2026 Smart Job Portal - ATS Analyzer Tool. All rights reserved.</p>
        </div>
    </footer>

    <!-- Loading Overlay -->
    <div id="loadingOverlay" class="loading-overlay d-none">
        <div class="loader text-center">
            <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;"></div>
            <p class="text-white mt-3">Analyzing your resume... Please wait.</p>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/ats.js"></script>
</body>

</html>