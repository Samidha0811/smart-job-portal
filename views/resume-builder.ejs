<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= title %> — Smart Job Portal
  </title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/css/resume.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"
    rel="stylesheet">
</head>

<body class="resume-builder-page">

  <nav class="navbar navbar-expand-lg border-bottom bg-white py-3">
    <div class="container">
      <a class="navbar-brand fw-bold text-primary" href="/">
        <i class="fas fa-briefcase me-2"></i>SmartJobPortal
      </a>
      <div class="ms-auto d-flex gap-2">
        <a href="/" class="btn btn-sm btn-outline-secondary">Back to Home</a>
        <button id="download-btn" class="btn btn-sm btn-primary">
          <i class="fas fa-download me-1"></i> Download PDF
        </button>
      </div>
    </div>
  </nav>

  <div class="container-fluid builder-container">
    <div class="row g-4 px-lg-5">
      <!-- Left Column: Form -->
      <div class="col-lg-6">
        <form id="resume-form">
          <!-- Personal Information -->
          <div class="form-section">
            <h4><i class="fas fa-user-circle me-2"></i> Personal Information</h4>
            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label">Full Name</label>
                <input type="text" name="fullName" class="form-control" placeholder="e.g. John Doe">
              </div>
              <div class="col-md-6">
                <label class="form-label">Email</label>
                <input type="email" name="email" class="form-control" placeholder="john@example.com">
              </div>
              <div class="col-md-6">
                <label class="form-label">Phone</label>
                <input type="text" name="phone" class="form-control" placeholder="+1 234 567 890">
              </div>
              <div class="col-md-6">
                <label class="form-label">LinkedIn</label>
                <input type="text" name="linkedin" class="form-control" placeholder="linkedin.com/in/username">
              </div>
              <div class="col-md-12">
                <label class="form-label">GitHub</label>
                <input type="text" name="github" class="form-control" placeholder="github.com/username">
              </div>
            </div>
          </div>

          <!-- Summary -->
          <div class="form-section">
            <div class="d-flex justify-content-between align-items-center mb-1">
              <h4><i class="fas fa-align-left me-2"></i> Professional Summary</h4>
              <button type="button" class="btn btn-sm btn-light text-primary fw-bold mb-3" style="font-size:0.75rem;">
                <i class="fas fa-magic me-1"></i> Generate with AI
              </button>
            </div>
            <textarea name="summary" class="form-control" rows="4"
              placeholder="Write a brief professional summary..."></textarea>
          </div>

          <!-- Education -->
          <div class="form-section">
            <div class="d-flex justify-content-between align-items-center mb-1">
              <h4><i class="fas fa-graduation-cap me-2"></i> Education</h4>
              <button type="button" id="add-education-btn" class="btn btn-sm btn-outline-primary mb-3">
                <i class="fas fa-plus me-1"></i> Add Education
              </button>
            </div>
            <div id="education-list">
              <!-- Education item will be cloned here -->
              <div class="education-item mb-4 pb-3 border-bottom position-relative">
                <div class="row g-3">
                  <div class="col-md-8">
                    <label class="form-label">Degree</label>
                    <input type="text" name="degree[]" class="form-control edu-degree"
                      placeholder="B.Tech in Computer Science">
                  </div>
                  <div class="col-md-4">
                    <label class="form-label">Year of Passing</label>
                    <input type="text" name="year[]" class="form-control edu-year" placeholder="2024">
                  </div>
                  <div class="col-md-8">
                    <label class="form-label">College/University</label>
                    <input type="text" name="college[]" class="form-control edu-college"
                      placeholder="Oxford University">
                  </div>
                  <div class="col-md-4">
                    <label class="form-label">CGPA / %</label>
                    <input type="text" name="cgpa[]" class="form-control edu-cgpa" placeholder="9.2">
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Projects/Experience -->
          <div class="form-section">
            <div class="d-flex justify-content-between align-items-center mb-1">
              <h4><i class="fas fa-project-diagram me-2"></i> Projects / Experience</h4>
              <button type="button" id="add-project-btn" class="btn btn-sm btn-outline-primary mb-3">
                <i class="fas fa-plus me-1"></i> Add Project
              </button>
            </div>
            <div id="projects-list">
              <!-- Project item will be cloned here -->
              <div class="project-item mb-4 pb-3 border-bottom position-relative">
                <div class="row g-3">
                  <div class="col-md-7">
                    <label class="form-label">Company name and Designation </label>
                    <input type="text" name="projectTitle[]" class="form-control project-title"
                      placeholder="E-commerce Portal">
                  </div>
                  <div class="col-md-5">
                    <label class="form-label">Experience </label>
                    <input type="text" name="techStack[]" class="form-control tech-stack"
                      placeholder="sep 2025 - March 2026">
                  </div>
                  <div class="col-md-12">
                    <label class="form-label">Description</label>
                    <textarea name="projectDesc[]" class="form-control project-desc" rows="2"
                      placeholder="Describe your key contributions and features..."></textarea>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Skills -->
          <div class="form-section">
            <h4><i class="fas fa-tools me-2"></i> Skills</h4>
            <div class="skills-container mb-2" id="skills-tags">
              <!-- Skills tags appear here -->
            </div>
            <div class="input-group">
              <input type="text" id="skill-input" class="form-control"
                placeholder="Enter a skill (e.g. JavaScript) and press Enter">
              <button type="button" id="add-skill-btn" class="btn btn-primary">Add</button>
            </div>
          </div>

          <!-- Achievements -->
          <div class="form-section">
            <h4><i class="fas fa-trophy me-2"></i> Achievements (Optional)</h4>
            <textarea name="achievements" class="form-control" rows="3"
              placeholder="Honors, certificates, or competitive programming achievements..."></textarea>
          </div>
        </form>
      </div>

      <!-- Right Column: Preview -->
      <div class="col-lg-6">
        <div id="resume-preview-container">
          <%- include('./partials/resume-preview') %>
        </div>
      </div>
    </div>
  </div>

  <script src="/js/resume.js"></script>
</body>

</html>