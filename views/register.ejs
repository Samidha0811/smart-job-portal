<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= title %> — Smart Job Portal
  </title>
  <meta name="description" content="Create your Smart Job Portal account as a job seeker or recruiter.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
    rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    /* ---- Page Base ---- */
    body {
      background: #fff;
      font-family: 'Inter', sans-serif;
    }

    /* ---- Left decorative panel ---- */
    .auth-left {
      background: linear-gradient(160deg, #0f172a 0%, #1e1b4b 55%, #312e81 100%);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: flex-start;
      padding: 3.5rem 1.5rem;
      position: sticky;
      top: 0;
      overflow: hidden;
    }

    .auth-left::before {
      content: '';
      position: absolute;
      width: 420px;
      height: 420px;
      background: radial-gradient(circle, rgba(99, 102, 241, 0.35) 0%, transparent 70%);
      top: -80px;
      right: -100px;
      border-radius: 50%;
    }

    .auth-left::after {
      content: '';
      position: absolute;
      width: 300px;
      height: 300px;
      background: radial-gradient(circle, rgba(6, 182, 212, 0.2) 0%, transparent 70%);
      bottom: -60px;
      left: -60px;
      border-radius: 50%;
    }

    .auth-left-brand {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      color: #fff;
      font-weight: 800;
      font-size: 1.15rem;
      margin-bottom: 3.5rem;
      position: relative;
      z-index: 1;
    }

    .auth-left-brand i {
      color: #818cf8;
      font-size: 1.1rem;
    }

    .auth-left-heading {
      color: #fff;
      font-size: clamp(1.9rem, 3.5vw, 2.6rem);
      font-weight: 900;
      letter-spacing: -1.5px;
      line-height: 1.1;
      margin-bottom: 1rem;
      position: relative;
      z-index: 1;
    }

    .auth-left-heading span {
      background: linear-gradient(135deg, #a5b4fc, #67e8f9);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .auth-left-sub {
      color: rgba(255, 255, 255, 0.55);
      font-size: 0.95rem;
      max-width: 340px;
      line-height: 1.65;
      margin-bottom: 2.5rem;
      position: relative;
      z-index: 1;
    }

    .auth-feature-list {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      position: relative;
      z-index: 1;
    }

    .auth-feature-item {
      display: flex;
      align-items: center;
      gap: 0.85rem;
    }

    .auth-feature-icon {
      width: 38px;
      height: 38px;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.9rem;
      flex-shrink: 0;
    }

    .auth-feature-item span {
      color: rgba(255, 255, 255, 0.75);
      font-size: 0.875rem;
      font-weight: 500;
    }

    /* ---- Right form panel ---- */
    .auth-right {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #fff;
      overflow-y: auto;
    }

    .auth-form-box {
      width: 100%;
      max-width: 500px;
    }

    .auth-form-title {
      font-size: 2.25rem;
      font-weight: 900;
      color: #0f172a;
      letter-spacing: -1.5px;
      margin-bottom: 0.4rem;
    }

    .auth-form-sub {
      color: #64748b;
      font-size: 0.9rem;
    }

    .auth-form-sub a {
      color: #4f46e5;
      font-weight: 600;
      text-decoration: none;
    }

    .auth-form-sub a:hover {
      text-decoration: underline;
    }

    /* ---- Role selector ---- */
    .role-label {
      font-size: 0.82rem;
      font-weight: 700;
      color: #64748b;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-bottom: 0.75rem;
    }

    .role-cards {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.85rem;
      margin-bottom: 1.75rem;
    }

    .role-card {
      border: 2px solid #e2e8f0;
      border-radius: 14px;
      padding: 1.1rem;
      cursor: pointer;
      transition: all 0.2s ease;
      background: #fff;
      position: relative;
    }

    .role-card:hover {
      border-color: #818cf8;
      background: #f5f3ff;
    }

    .role-card.selected {
      border-color: #4f46e5;
      background: #eef2ff;
    }

    .role-card.selected::after {
      content: '\f058';
      font-family: 'Font Awesome 6 Free';
      font-weight: 900;
      position: absolute;
      top: 0.65rem;
      right: 0.75rem;
      color: #4f46e5;
      font-size: 0.85rem;
    }

    .role-card-icon {
      font-size: 1.75rem;
      margin-bottom: 0.55rem;
      display: block;
    }

    .role-card-title {
      font-size: 0.9rem;
      font-weight: 700;
      color: #0f172a;
      margin-bottom: 0.15rem;
    }

    .role-card-desc {
      font-size: 0.75rem;
      color: #94a3b8;
    }

    /* ---- Fields ---- */
    .field-label {
      font-size: 0.82rem;
      font-weight: 600;
      color: #334155;
      margin-bottom: 0.4rem;
      display: block;
    }

    .field-input {
      width: 100%;
      padding: 0.8rem 1rem;
      border: 1.5px solid #e2e8f0;
      border-radius: 12px;
      font-family: 'Inter', sans-serif;
      font-size: 0.9rem;
      color: #0f172a;
      background: #fff;
      transition: all 0.2s;
      outline: none;
    }

    .field-input:focus {
      border-color: #4f46e5;
      box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.1);
    }

    .field-input::placeholder {
      color: #cbd5e1;
    }

    .field-group {
      margin-bottom: 1.1rem;
    }

    .field-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.85rem;
    }

    .pwd-wrap {
      position: relative;
    }

    .pwd-wrap .field-input {
      padding-right: 2.75rem;
    }

    .pwd-toggle {
      position: absolute;
      right: 0.9rem;
      top: 50%;
      transform: translateY(-50%);
      background: none;
      border: none;
      color: #94a3b8;
      cursor: pointer;
      padding: 0;
      font-size: 0.9rem;
    }

    /* ---- Submit Button ---- */
    .btn-auth-submit {
      width: 100%;
      padding: 0.95rem;
      background: #4f46e5;
      color: #fff;
      border: none;
      border-radius: 12px;
      font-family: 'Inter', sans-serif;
      font-size: 1rem;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.2s;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      margin-top: 0.5rem;
    }

    .btn-auth-submit:hover {
      background: #4338ca;
      transform: translateY(-1px);
      box-shadow: 0 6px 20px rgba(79, 70, 229, 0.3);
    }

    .btn-auth-submit:disabled {
      opacity: 0.7;
      cursor: not-allowed;
      transform: none;
    }

    .auth-terms {
      text-align: center;
      color: #94a3b8;
      font-size: 0.78rem;
      margin-top: 1.1rem;
      line-height: 1.6;
    }

    .auth-terms a {
      color: #4f46e5;
      font-weight: 600;
      text-decoration: none;
    }

    .auth-terms a:hover {
      text-decoration: underline;
    }

    @media (max-width: 768px) {
      .auth-left {
        display: none !important;
      }

      .auth-form-title {
        font-size: 1.8rem;
      }

      .field-row {
        grid-template-columns: 1fr;
      }

      .role-cards {
        gap: 0.65rem;
      }
    }
  </style>
</head>

<body>
  <div class="container-fluid p-0">
    <div class="row g-0" style="min-height:100vh;">

      <!-- ===== LEFT PANEL ===== -->
      <div class="col-lg-6 auth-left d-none d-lg-flex flex-column">
        <div class="auth-left-brand">
          <i class="fas fa-briefcase"></i> SmartJobPortal
        </div>
        <h2 class="auth-left-heading">
          Your next big<br>opportunity <span>starts here</span>
        </h2>
        <p class="auth-left-sub">
          Join thousands of job seekers and top recruiters on one unified platform. Apply smart, hire faster.
        </p>
        <div class="auth-feature-list">
          <div class="auth-feature-item">
            <div class="auth-feature-icon" style="background:rgba(129,140,248,0.15);color:#818cf8;">
              <i class="fas fa-robot"></i>
            </div>
            <span>AI-powered resume &amp; skill matching</span>
          </div>
          <div class="auth-feature-item">
            <div class="auth-feature-icon" style="background:rgba(6,182,212,0.15);color:#06b6d4;">
              <i class="fas fa-shield-alt"></i>
            </div>
            <span>Verified recruiter profiles only</span>
          </div>
          <div class="auth-feature-item">
            <div class="auth-feature-icon" style="background:rgba(16,185,129,0.15);color:#10b981;">
              <i class="fas fa-bolt"></i>
            </div>
            <span>One-click apply with stored resume</span>
          </div>
          <div class="auth-feature-item">
            <div class="auth-feature-icon" style="background:rgba(245,158,11,0.15);color:#f59e0b;">
              <i class="fas fa-chart-line"></i>
            </div>
            <span>Real-time application status tracking</span>
          </div>
        </div>
      </div>

      <!-- ===== RIGHT FORM ===== -->
      <div class="col-lg-6 auth-right">
        <div class="auth-form-box">

          <!-- Back link -->
          <a href="/" class="mb-4 d-inline-flex align-items-center gap-2"
            style="color:#64748b;font-size:0.85rem;font-weight:600;text-decoration:none;">
            <i class="fas fa-arrow-left" style="font-size:0.8rem;"></i> Back to Home
          </a>

          <h1 class="auth-form-title">Create account</h1>
          <p class="auth-form-sub">
            Already have one? <a href="/login">Sign in</a>
          </p>

          <!-- Role Selector -->
          <div class="role-label">I am a:</div>
          <div class="role-cards">
            <div class="role-card selected" id="roleSeeker" onclick="selectRole('seeker')">
              <span class="role-card-icon">🔍</span>
              <div class="role-card-title">Job Seeker</div>
              <div class="role-card-desc">Find &amp; apply to jobs</div>
            </div>
            <div class="role-card" id="roleRecruiter" onclick="selectRole('recruiter')">
              <span class="role-card-icon">🏢</span>
              <div class="role-card-title">Recruiter</div>
              <div class="role-card-desc">Post jobs &amp; find talent</div>
            </div>
          </div>
          <input type="hidden" id="selectedRole" value="seeker">

          <form action="/api/auth/register" method="POST" id="registrationForm" autocomplete="off">
            <input type="hidden" name="role" id="roleInput" value="seeker">

            <!-- Name row -->
            <div class="field-row field-group">
              <div>
                <label class="field-label" for="firstName">First name</label>
                <input type="text" class="field-input" id="firstName" name="firstName" placeholder="Rahul" required
                  autocomplete="off" readonly onfocus="this.removeAttribute('readonly');">
              </div>
              <div>
                <label class="field-label" for="lastName">Last name</label>
                <input type="text" class="field-input" id="lastName" name="lastName" placeholder="Sharma"
                  autocomplete="off" readonly onfocus="this.removeAttribute('readonly');">
              </div>
            </div>

            <!-- Hidden combined username field -->
            <input type="hidden" name="username" id="usernameHidden">

            <!-- Email -->
            <div class="field-group">
              <label class="field-label" for="email">Email address</label>
              <input type="email" class="field-input" id="email" name="email" placeholder="rahul@email.com" required
                autocomplete="off" readonly onfocus="this.removeAttribute('readonly');">
            </div>

            <!-- Password -->
            <div class="field-group">
              <label class="field-label" for="password">Password</label>
              <div class="pwd-wrap">
                <input type="password" class="field-input" id="password" name="password" placeholder="Min. 8 characters"
                  required autocomplete="new-password" readonly onfocus="this.removeAttribute('readonly');">
                <button type="button" class="pwd-toggle" onclick="togglePassword()">
                  <i class="fas fa-eye" id="eyeIcon"></i>
                </button>
              </div>
            </div>

            <!-- Submit -->
            <button type="submit" class="btn-auth-submit" id="registerBtn">
              Create Account <i class="fas fa-arrow-right"></i>
            </button>

            <p class="auth-terms">
              By creating an account you agree to our
              <a href="#">Terms of Service</a> and <a href="#">Privacy Policy</a>.
            </p>
          </form>

        </div>
      </div>

    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script src="/js/apiService.js"></script>
  <script src="/js/validation.js"></script>
  <script src="/js/script.js"></script>
  <script>
    // Role Selection
    function selectRole(role) {
      document.getElementById('selectedRole').value = role;
      document.getElementById('roleInput').value = role;
      document.getElementById('roleSeeker').classList.toggle('selected', role === 'seeker');
      document.getElementById('roleRecruiter').classList.toggle('selected', role === 'recruiter');
    }

    // Pre-select recruiter if URL param
    const params = new URLSearchParams(window.location.search);
    if (params.get('role') === 'recruiter') selectRole('recruiter');

    // Password toggle
    function togglePassword() {
      const pwd = document.getElementById('password');
      const icon = document.getElementById('eyeIcon');
      pwd.type = pwd.type === 'password' ? 'text' : 'password';
      icon.className = pwd.type === 'password' ? 'fas fa-eye' : 'fas fa-eye-slash';
    }

    // --- REAL-TIME VALIDATION MAPPING ---
    const validationMap = {
      'firstName': { validate: (val) => Validator.isValidName(val), message: 'Please enter a valid first name (letters only)' },
      'lastName': { validate: (val) => !val || Validator.isValidName(val), message: 'Please enter a valid last name (letters only)' },
      'email': { validate: (val) => Validator.isValidEmail(val), message: 'Please enter a valid email address' },
      'password': { validate: (val) => Validator.isValidPassword(val), message: 'Password must be at least 6 characters with letters and numbers' }
    };

    /**
     * Validates a single input element
     */
    function validateField(inputElement) {
      const name = inputElement.name;
      const val = inputElement.value;
      const rule = validationMap[name];

      if (rule) {
        if (!rule.validate(val)) {
          Validator.showError(inputElement, rule.message);
          return false;
        } else {
          Validator.clearError(inputElement);
          return true;
        }
      }
      return true;
    }

    // Attach listeners
    Object.keys(validationMap).forEach(fieldName => {
      const input = document.getElementsByName(fieldName)[0];
      if (input) {
        input.addEventListener('blur', () => validateField(input));
        input.addEventListener('input', () => {
          if (input.classList.contains('is-invalid')) {
            validateField(input);
          }
        });
      }
    });

    // Combine first + last name into username
    document.getElementById('registrationForm').addEventListener('submit', function (e) {
      e.preventDefault();

      // Perform full validation check
      let isFormValid = true;
      let firstInvalid = null;

      Object.keys(validationMap).forEach(fieldName => {
        const input = document.getElementsByName(fieldName)[0];
        if (input && !validateField(input)) {
          isFormValid = false;
          if (!firstInvalid) firstInvalid = input;
        }
      });

      if (!isFormValid) {
        if (firstInvalid) firstInvalid.focus();
        Swal.fire({
          icon: 'error',
          title: 'Validation Error',
          text: 'Please correct the highlighted errors before proceeding.',
          confirmButtonColor: '#4f46e5'
        });
        return;
      }

      const first = document.getElementById('firstName').value.trim();
      const last = document.getElementById('lastName').value.trim();
      document.getElementById('usernameHidden').value = (first + ' ' + last).trim();

      const btn = document.getElementById('registerBtn');
      btn.disabled = true;
      btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" style="width:1rem;height:1rem;border-width:2px;"></span> Creating account...';

      const formData = new FormData(this);
      const data = Object.fromEntries(formData.entries());

      apiService.register(data).then(async (response) => {
          const result = await response.json();
          if (response.ok) {
              if (result.redirectTo) {
                  if (result.role === 'recruiter') {
                      sessionStorage.setItem('pendingRecruiterId', result.userId);
                      window.location.href = result.redirectTo;
                  } else {
                      window.location.href = result.redirectTo;
                  }
              } else {
                  document.body.innerHTML = `<div class="container py-5 text-center"><h1>Success!</h1><p>${result.message}</p><a href="/login" class="btn btn-primary">Go to Login</a></div>`;
              }
          } else {
              if (result.message && result.message.toLowerCase().includes('already registered')) {
                  Swal.fire({
                      icon: 'info',
                      title: 'Already Registered',
                      text: result.message,
                      showCancelButton: true,
                      confirmButtonText: 'Go to Login',
                      cancelButtonText: 'Try another email',
                      confirmButtonColor: '#4f46e5'
                  }).then((res) => {
                      if (res.isConfirmed) {
                          window.location.href = '/login';
                      }
                  });
              } else {
                  Swal.fire({ icon: 'error', title: 'Registration Failed', text: result.message || 'Unknown error' });
              }
              btn.disabled = false;
              btn.innerHTML = 'Create Account <i class="fas fa-arrow-right"></i>';
          }
      }).catch(err => {
          console.error('Registration error:', err);
          Swal.fire({ icon: 'error', title: 'Error', text: 'An error occurred during registration.' });
          btn.disabled = false;
          btn.innerHTML = 'Create Account <i class="fas fa-arrow-right"></i>';
      });
    });
  </script>
</body>

</html>