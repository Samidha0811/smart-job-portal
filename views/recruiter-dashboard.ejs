<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= title %> — Smart Job Portal
  </title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>

<body class="dashboard-page">
  <!-- ===== INITIAL LOADING SCREEN ===== -->
  <div id="initialLoading"
    style="position:fixed;top:0;left:0;width:100%;height:100%;background:var(--bg);z-index:10000;display:flex;flex-direction:column;align-items:center;justify-content:center;">
    <div class="spinner-border text-primary mb-3" style="width: 3rem; height: 3rem;"></div>
    <div class="fw-bold" style="color:var(--dark-2);">Verifying Account...</div>
  </div>

  <!-- ===== PENDING/REJECTED OVERLAY ===== -->
  <div id="pendingOverlay"
    style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:var(--bg); z-index:9999; align-items:center; justify-content:center; padding:20px;">
    <div class="main-card shadow-lg text-center p-5" style="max-width:550px; border-radius:24px; border:none;">
      <div id="statusIcon"
        style="width:80px;height:80px;background:rgba(245,158,11,0.1);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1.5rem;font-size:2rem;color:#f59e0b;">
        <i class="fas fa-hourglass-half"></i>
      </div>
      <h2 class="fw-bold mb-3" id="statusTitle" style="font-size:1.8rem; letter-spacing:-0.02em;">Account Under Review</h2>
      <p class="text-muted mb-4" id="statusDescription" style="font-size:0.95rem; line-height:1.6;">
        Your recruiter profile is currently being verified by our administration team. You will gain full access to post
        jobs and manage applications once approved.
      </p>
      <div class="d-grid gap-3">
        <a href="/api/auth/logout" class="btn btn-danger py-3 fw-bold shadow-sm" style="border-radius:12px;">
          <i class="fas fa-sign-out-alt me-2"></i> Logout Now
        </a>
      </div>
    </div>
  </div>

  <!-- ===== DASHBOARD CONTENT WRAPPER ===== -->
  <div id="dashboardWrapper" style="display:none;">
    <!-- ===== NAVBAR ===== -->
    <nav class="navbar navbar-expand-lg navbar-premium">
    <div class="container-fluid px-4">
      <a class="navbar-brand" href="/recruiter/dashboard">
        <i class="fas fa-briefcase me-2" style="color:#818cf8;"></i>SmartJobPortal
      </a>
      <div class="collapse navbar-collapse">
        <ul class="navbar-nav ms-auto align-items-center gap-1">
          <li class="nav-item"><a class="nav-link active" href="/recruiter/dashboard"><i
                class="fas fa-th-large me-1"></i>Dashboard</a></li>
          <li class="nav-item"><a class="nav-link" href="/recruiter/applications"><i
                class="fas fa-users me-1"></i>Applications</a></li>
          <li class="nav-item"><a class="nav-link" href="/recruiter/my-jobs"><i class="fas fa-list me-1"></i>Posted
              Jobs</a></li>
          <li class="nav-item ms-2">
            <a class="btn-nav-danger" href="#" id="logoutLink"><i class="fas fa-sign-out-alt me-1"></i>Logout</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="dashboard-container">
    <!-- Page Header -->
    <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-3">
      <div>
        <h1 class="page-title" style="font-size:1.6rem;">Recruiter Dashboard</h1>
        <p style="color:var(--gray);font-size:0.85rem;margin:0;">Manage your job postings and applications</p>
      </div>
      <div class="d-flex align-items-center gap-3 flex-wrap">
        <div class="search-bar" style="width: 280px; margin: 0;">
          <i class="fas fa-search search-bar-icon"></i>
          <input type="text" id="dashboardSearch" placeholder="Search jobs...">
        </div>
        <button id="postJobBtn" class="btn-primary-premium" disabled>
          <i class="fas fa-plus"></i> Post a New Job
        </button>
      </div>
    </div>

    <div class="row g-4">
      <!-- ===== SIDEBAR ===== -->
      <div class="col-lg-3">
        <!-- Profile Card -->
        <div class="sidebar-card mb-4">
          <div class="sidebar-header">
            <div class="avatar-circle">
              <i class="fas fa-user-tie"></i>
            </div>
            <div class="sidebar-name" id="recruiterName">Loading...</div>
            <div class="sidebar-email" id="recruiterEmail">...</div>
          </div>
          <div class="sidebar-body">
            <a href="/recruiter/create-profile" class="btn w-100 fw-bold"
              style="border-radius:10px;font-size:0.85rem;border:1.5px solid var(--border);color:var(--dark);">
              <i class="fas fa-edit me-2" style="color:var(--primary);"></i> Company Profile For Seeker view
            </a>
          </div>
        </div>

        <!-- Account Status -->
        <div class="sidebar-card">
          <div class="sidebar-body">
            <div
              style="font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:var(--gray);margin-bottom:1rem;">
              Account Status</div>
            <div id="statusBadge" class="status-badge status-checking d-flex justify-content-center w-100 py-2 mb-3">
              <i class="fas fa-circle-notch fa-spin me-2"></i> Checking...
            </div>
            <p style="font-size:0.82rem;color:var(--gray);margin:0;" id="statusMessage">We are verifying your account
              details.</p>
          </div>
        </div>
      </div>

      <!-- ===== MAIN CONTENT ===== -->
      <div class="col-lg-9">


        <div class="main-card">
          <div class="main-card-header">
            <h2 class="page-title" style="font-size:1.15rem;">Your Job Postings</h2>
          </div>
          <div id="jobsList">
            <div class="loading-overlay">
              <div class="spinner-border spinner-border-sm text-primary"></div>
              <span>Loading jobs...</span>
            </div>
          </div>
          <div id="viewAllJobsContainer" class="p-4 text-center border-top" style="display:none;">
            <a href="/recruiter/my-jobs" class="btn btn-outline-primary fw-bold px-4" style="border-radius:50px;">
              View All Posted Jobs <i class="fas fa-arrow-right ms-2"></i>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div> <!-- Close #dashboardWrapper -->

  <!-- ===== NOTIFICATION MODAL ===== -->
  <div class="modal fade modal-premium" id="notificationModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div id="modalHeader" class="modal-header header-success border-0">
          <h5 class="modal-title fw-bold text-white" id="notificationModalLabel">Notification</h5>
          <button class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body text-center py-4">
          <div id="modalIcon" class="mb-3"></div>
          <h5 id="modalTitle" class="fw-bold mb-2"></h5>
          <p id="modalMessage" class="text-muted mb-0" style="font-size:0.9rem;"></p>
        </div>
        <div class="modal-footer justify-content-center border-0 bg-white pb-4">
          <button class="btn btn-primary px-5 fw-bold" data-bs-dismiss="modal" id="modalOkBtn">OK</button>
        </div>
      </div>
    </div>
  </div>

  <!-- ===== CONFIRM MODAL ===== -->
  <div class="modal fade modal-premium" id="confirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header header-primary border-0">
          <h5 class="modal-title fw-bold text-white">Confirm Action</h5>
          <button class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body text-center py-4">
          <div
            style="width:66px;height:66px;background:rgba(79,70,229,0.1);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1.25rem;font-size:1.6rem;color:var(--primary);">
            <i class="fas fa-question"></i>
          </div>
          <h5 id="confirmTitle" class="fw-bold mb-2"></h5>
          <p id="confirmMessage" class="text-muted mb-0" style="font-size:0.9rem;"></p>
        </div>
        <div class="modal-footer justify-content-center border-0 bg-white pb-4 gap-2">
          <button class="btn btn-light px-4 fw-bold" data-bs-dismiss="modal">Cancel</button>
          <button class="btn btn-primary px-4 fw-bold" id="confirmActionBtn">Confirm</button>
        </div>
      </div>
    </div>
  </div>

  <!-- ===== LOGOUT MODAL ===== -->
  <div class="modal fade modal-premium" id="logoutModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header header-danger border-0">
          <h5 class="modal-title fw-bold text-white"><i class="fas fa-sign-out-alt me-2"></i>Confirm Logout</h5>
          <button class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body text-center py-4">
          <div
            style="width:70px;height:70px;background:rgba(239,68,68,0.1);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1.25rem;font-size:1.75rem;color:#ef4444;">
            <i class="fas fa-exclamation-triangle"></i>
          </div>
          <h5 class="fw-bold mb-2">Are you sure?</h5>
          <p class="text-muted mb-0" style="font-size:0.9rem;">You will be signed out of your session.</p>
        </div>
        <div class="modal-footer justify-content-center border-0 bg-white pb-4">
          <button class="btn btn-light px-4 fw-bold" data-bs-dismiss="modal">Cancel</button>
          <a href="/api/auth/logout" class="btn btn-danger px-4 fw-bold">
            <i class="fas fa-sign-out-alt me-2"></i>Logout Now
          </a>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/apiService.js"></script>
  <script>
    document.getElementById('logoutLink').addEventListener('click', function (e) {
      e.preventDefault();
      new bootstrap.Modal(document.getElementById('logoutModal')).show();
    });

    window.addEventListener('pageshow', (e) => { if (e.persisted) window.location.reload(); });

    function showNotification(title, message, type = 'success', callback = null) {
      const modalEl = document.getElementById('notificationModal');
      const header = document.getElementById('modalHeader');
      const icon = document.getElementById('modalIcon');
      document.getElementById('modalTitle').textContent = title;
      document.getElementById('modalMessage').textContent = message;
      header.className = 'modal-header border-0 ' + (type === 'success' ? 'header-success' : 'header-danger');
      icon.innerHTML = type === 'success'
        ? '<div style="width:66px;height:66px;background:rgba(16,185,129,0.1);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto;font-size:1.75rem;color:#10b981;"><i class="fas fa-check-circle"></i></div>'
        : '<div style="width:66px;height:66px;background:rgba(239,68,68,0.1);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto;font-size:1.75rem;color:#ef4444;"><i class="fas fa-times-circle"></i></div>';
      const modal = new bootstrap.Modal(modalEl);
      if (callback) { modalEl.addEventListener('hidden.bs.modal', function h() { callback(); modalEl.removeEventListener('hidden.bs.modal', h); }); }
      modal.show();
    }

    function showConfirm(title, message, onConfirm) {
      document.getElementById('confirmTitle').textContent = title;
      document.getElementById('confirmMessage').textContent = message;
      const confirmBtn = document.getElementById('confirmActionBtn');
      const modal = new bootstrap.Modal(document.getElementById('confirmModal'));
      confirmBtn.onclick = () => { onConfirm(); modal.hide(); };
      modal.show();
    }

    let allJobs = [];

    async function loadJobs() {
      try {
        allJobs = await window.apiService.getMyJobs();
        renderJobs(allJobs, true);
      } catch (err) { console.error('Error loading jobs:', err); }
    }

    async function renderJobs(jobs, limited = false) {
      const jobsList = document.getElementById('jobsList');
      const viewAll = document.getElementById('viewAllJobsContainer');

      if (jobs.length === 0) {
        jobsList.innerHTML = `
          <div class="empty-state">
            <div class="empty-state-icon"><i class="fas fa-briefcase"></i></div>
            <div class="empty-state-title">No Jobs Posted Yet</div>
            <div class="empty-state-text">Post your first job to start receiving applications from top talent.</div>
          </div>`;
        viewAll.style.display = 'none';
        return;
      }

      const displayJobs = limited ? jobs.slice(0, 3) : jobs;
      viewAll.style.display = (limited && jobs.length > 3) ? 'block' : 'none';
      jobsList.innerHTML = '';

      for (const job of displayJobs) {
        const applicants = await window.apiService.getJobApplicants(job.id);
        const item = document.createElement('div');
        item.className = 'job-list-item';
        item.innerHTML = `
          <div class="flex-grow-1">
            <div class="d-flex align-items-center gap-2 mb-1">
              <span class="fw-bold" style="font-size:0.95rem;color:var(--dark);">${job.title}</span>
              <span class="job-id-tag"><i class="fas fa-fingerprint" style="font-size:0.65rem;"></i>${job.job_id || 'N/A'}</span>
            </div>
            <div class="d-flex align-items-center gap-3" style="font-size:0.8rem;color:var(--gray);">
              ${job.location ? `<span><i class="fas fa-map-marker-alt me-1"></i>${job.location}</span>` : ''}
              <span><i class="fas fa-calendar me-1"></i>${new Date(job.created_at).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' })}</span>
            </div>
          </div>
          <div class="d-flex align-items-center gap-2">
            <span class="status-badge status-approved">
              <i class="fas fa-users" style="font-size:0.65rem;"></i> ${applicants.length} Applicant${applicants.length !== 1 ? 's' : ''}
            </span>
          </div>`;
        jobsList.appendChild(item);
      }
    }

    document.getElementById('dashboardSearch').addEventListener('input', (e) => {
      const q = e.target.value.toLowerCase().trim();
      if (q === '') { renderJobs(allJobs, true); return; }
      const filtered = allJobs.filter(j => j.title.toLowerCase().includes(q) || (j.job_id && j.job_id.toLowerCase().includes(q)));
      renderJobs(filtered, false);
    });

    async function loadDashboard() {
      try {
        const user = await window.apiService.getCurrentUser();
        if (user.message === 'No token provided' || user.message === 'User not found') {
          window.location.href = '/login'; return;
        }
        document.getElementById('recruiterName').textContent = user.fullname;
        document.getElementById('recruiterEmail').textContent = user.email;

        const badge = document.getElementById('statusBadge');
        const btn = document.getElementById('postJobBtn');
        const msg = document.getElementById('statusMessage');

        if (user.status === 'approved') {
          document.getElementById('dashboardWrapper').style.display = 'block';
          document.getElementById('initialLoading').style.display = 'none';

          badge.className = 'status-badge status-approved d-flex justify-content-center w-100 py-2 mb-3';
          badge.innerHTML = '<i class="fas fa-check-circle me-2"></i> APPROVED';
          msg.textContent = 'Your account is verified! You can post jobs and manage applicants.';
          btn.disabled = false;
          btn.onclick = async () => {
            const originalHtml = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Checking...';
            try {
              const profile = await window.apiService.getMyProfile();
              if (!profile || !profile.profile_exists) {
                showNotification('Profile Incomplete', 'Please save your Company Profile for Seeker view before posting a job.', 'error', () => {
                  window.location.href = '/recruiter/create-profile';
                });
                btn.innerHTML = originalHtml;
                btn.disabled = false;
              } else {
                window.location.href = '/recruiter/post-job';
              }
            } catch (err) {
              console.error(err);
              btn.innerHTML = originalHtml;
              btn.disabled = false;
            }
          };
          loadJobs();
        } else if (user.status === 'pending') {
          const overlay = document.getElementById('pendingOverlay');
          overlay.style.display = 'flex';
          document.getElementById('initialLoading').style.display = 'none';
        } else if (user.status === 'rejected') {
          const overlay = document.getElementById('pendingOverlay');
          const icon = document.getElementById('statusIcon');
          const title = document.getElementById('statusTitle');
          const desc = document.getElementById('statusDescription');

          overlay.style.display = 'flex';
          document.getElementById('initialLoading').style.display = 'none';

          icon.style.background = 'rgba(239,68,68,0.1)';
          icon.style.color = '#ef4444';
          icon.innerHTML = '<i class="fas fa-times-circle"></i>';
          title.textContent = 'Account Rejected';
          desc.textContent = 'Your recruiter application was not approved by our team. If you believe this is a mistake, please contact support.';
        }
      } catch (err) {
        console.error('Error:', err);
        window.location.href = '/login';
      }
    }

    loadDashboard();
  </script>
</body>

</html>