<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-light">
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm fixed-top">
        <div class="container">
          <a class="navbar-brand fw-bold" href="/recruiter/dashboard">Smart Job Portal</a>
          <div class="collapse navbar-collapse">
            <ul class="navbar-nav ms-auto align-items-center">
              <li class="nav-item"><a class="nav-link fw-bold me-3 text-white" href="/recruiter/applications">Applications Received</a></li>
              <li class="nav-item"><a class="btn btn-danger btn-sm ms-3 text-white fw-bold shadow-sm" href="#" id="logoutLink">Logout</a></li>
            </ul>
          </div>
        </div>
    </nav>

    <div class="container py-5 mt-5">
        <div class="row">
            <!-- Sidebar/Info -->
            <div class="col-md-4">
                <div class="card shadow border-0 rounded-3 mb-4">
                    <div class="card-body p-4 text-center">
                        <div class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                            <i class="fas fa-user-tie fa-2x"></i>
                        </div>
                        <h4 class="fw-bold" id="recruiterName">Loading...</h4>
                        <p class="text-muted" id="recruiterEmail">...</p>
                        <hr>
                        <div class="d-grid">
                            <a href="/recruiter/create-profile" class="btn btn-outline-primary btn-sm">Edit Company Profile</a>
                        </div>
                    </div>
                </div>

                <div class="card shadow border-0 rounded-3">
                    <div class="card-body p-4">
                        <h6 class="fw-bold mb-3">Account Status</h6>
                        <div id="statusBadge" class="alert alert-secondary py-2 text-center fw-bold">
                            CHECKING...
                        </div>
                        <p class="small text-muted mb-0" id="statusMessage">
                            We are verifying your account details.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Main Content -->
            <div class="col-md-8">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2 class="fw-bold">Your Job Postings</h2>
                    <button id="postJobBtn" class="btn btn-primary px-4 fw-bold" disabled>
                        <i class="fas fa-plus me-2"></i> Post a New Job
                    </button>
                </div>

                <div class="card shadow border-0 rounded-3">
                    <div class="card-body p-0">
                        <div id="jobsList" class="list-group list-group-flush">
                            <!-- Jobs will be loaded here -->
                            <div class="p-5 text-center text-muted">
                                <i class="fas fa-briefcase fa-3x mb-3 opacity-25"></i>
                                <p>You haven't posted any jobs yet.</p>
                            </div>
                        </div>
                    </div>
                    </div>
                </div>


            </div>
        </div>
    </div>

    <!-- Notification Modal -->
    <div class="modal fade" id="notificationModal" tabindex="-1" aria-labelledby="notificationModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow-lg border-0" style="border-radius: 1rem;">
                <div id="modalHeader" class="modal-header border-0 py-3 text-white">
                    <h5 class="modal-title fw-bold" id="notificationModalLabel">Notification</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-5 text-center">
                    <div id="modalIcon" class="mb-3"></div>
                    <h4 id="modalTitle" class="fw-bold mb-2"></h4>
                    <p id="modalMessage" class="text-muted mb-0"></p>
                </div>
                <div class="modal-footer border-0 p-3 bg-light justify-content-center">
                    <button type="button" class="btn btn-primary px-5 fw-bold shadow-sm rounded-pill" data-bs-dismiss="modal" id="modalOkBtn">OK</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Confirmation Modal -->
    <div class="modal fade" id="confirmModal" tabindex="-1" aria-labelledby="confirmModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow-lg border-0" style="border-radius: 1rem;">
                <div class="modal-header bg-primary text-white border-0 py-3">
                    <h5 class="modal-title fw-bold" id="confirmModalLabel">Confirm Action</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-5 text-center">
                    <div class="mb-3 text-primary">
                        <i class="fas fa-question-circle fa-4x"></i>
                    </div>
                    <h4 id="confirmTitle" class="fw-bold mb-2">Are you sure?</h4>
                    <p id="confirmMessage" class="text-muted mb-0"></p>
                </div>
                <div class="modal-footer border-0 p-3 bg-light justify-content-center">
                    <button type="button" class="btn btn-light px-4 fw-bold text-muted" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary px-4 fw-bold shadow-sm rounded-pill" id="confirmActionBtn">Confirm</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Logout Confirmation Modal -->
    <div class="modal fade" id="logoutModal" tabindex="-1" aria-labelledby="logoutModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow-lg border-0" style="border-radius: 1rem;">
                <div class="modal-header bg-danger text-white border-0 py-3">
                    <h5 class="modal-title fw-bold" id="logoutModalLabel">
                        <i class="fas fa-sign-out-alt me-2"></i>Confirm Logout
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-5 text-center">
                    <div class="mb-3 text-danger">
                        <i class="fas fa-exclamation-circle fa-4x"></i>
                    </div>
                    <h4 class="fw-bold">Are you sure?</h4>
                    <p class="text-muted mb-0">You will be signed out of your session.</p>
                </div>
                <div class="modal-footer border-0 p-3 bg-light justify-content-center">
                    <button type="button" class="btn btn-light px-4 fw-bold text-muted" data-bs-dismiss="modal">Cancel</button>
                    <a href="/api/auth/logout" class="btn btn-danger px-4 fw-bold shadow-sm">Logout Now</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/apiService.js"></script>
    <script>
        // Handle Logout Popup
        document.addEventListener('DOMContentLoaded', () => {
            function showNotification(title, message, type = 'success', callback = null) {
            const modalEl = document.getElementById('notificationModal');
            const header = document.getElementById('modalHeader');
            const icon = document.getElementById('modalIcon');
            const titleEl = document.getElementById('modalTitle');
            const msgEl = document.getElementById('modalMessage');

            header.className = 'modal-header border-0 py-3 text-white ' + (type === 'success' ? 'bg-success' : 'bg-danger');
            icon.innerHTML = type === 'success' ? '<i class="fas fa-check-circle fa-4x text-success"></i>' : '<i class="fas fa-times-circle fa-4x text-danger"></i>';
            titleEl.textContent = title;
            msgEl.textContent = message;

            const modal = new bootstrap.Modal(modalEl);
            if (callback) {
                modalEl.addEventListener('hidden.bs.modal', function handler() {
                    callback();
                    modalEl.removeEventListener('hidden.bs.modal', handler);
                });
            }
            modal.show();
        }

        function showConfirm(title, message, onConfirm) {
            const modalEl = document.getElementById('confirmModal');
            document.getElementById('confirmTitle').textContent = title;
            document.getElementById('confirmMessage').textContent = message;
            const confirmBtn = document.getElementById('confirmActionBtn');
            
            const modal = new bootstrap.Modal(modalEl);
            confirmBtn.onclick = () => {
                onConfirm();
                modal.hide();
            };
            modal.show();
        }

        const logoutLink = document.getElementById('logoutLink');
            if (logoutLink) {
                logoutLink.addEventListener('click', function(e) {
                    e.preventDefault();
                    const modalEl = document.getElementById('logoutModal');
                    const logoutModal = new bootstrap.Modal(modalEl);
                    logoutModal.show();
                });
            }
        });

        // Prevent Back-Forward Cache (bfcache)
        window.addEventListener('pageshow', (event) => {
            if (event.persisted) {
                window.location.reload();
            }
        });

        async function loadJobs() {
            try {
                const jobs = await window.apiService.getMyJobs();
                const jobsList = document.getElementById('jobsList');
                
                if (jobs.length > 0) {
                    jobsList.innerHTML = '';
                    for (const job of jobs) {
                        const applicants = await window.apiService.getJobApplicants(job.id);
                        
                        const item = document.createElement('div');
                        item.className = 'list-group-item p-4';
                        item.innerHTML = `
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h5 class="fw-bold mb-1">${job.title}</h5>
                                    <p class="text-muted small mb-0">
                                        <i class="fas fa-map-marker-alt me-1"></i> ${job.location || 'Not specified'} | 
                                        <i class="fas fa-calendar-alt me-1"></i> Posted on ${new Date(job.created_at).toLocaleDateString()}
                                    </p>
                                </div>
                                <div class="text-end">
                                    <span class="badge bg-primary rounded-pill px-3 py-2">
                                        ${applicants.length} Applicants
                                    </span>
                                </div>
                            </div>
                        `;
                        jobsList.appendChild(item);
                    }
                }
            } catch (err) {
                console.error('Error loading jobs:', err);
            }
        }



        async function updateStatus(appId, status) {
            showConfirm('Confirmation', `Are you sure you want to mark this applicant as ${status}?`, async () => {
                try {
                    const result = await window.apiService.updateApplicationStatus(appId, status);
                    if (result.success) {
                        showNotification('Success', result.message, 'success');
                        loadApplications(); // Reload list
                    } else {
                        showNotification('Error', result.message, 'error');
                    }
                } catch (err) {
                    console.error('Error updating status:', err);
                    showNotification('Error', 'An error occurred.', 'error');
                }
            });
        }

        function getStatusBadge(status) {
            switch(status) {
                case 'shortlisted': return 'bg-success';
                case 'rejected': return 'bg-danger';
                default: return 'bg-warning text-dark';
            }
        }

        async function loadDashboard() {
            try {
                const user = await window.apiService.getCurrentUser();
                
                if (user.message === 'No token provided' || user.message === 'User not found') {
                    window.location.href = '/login';
                    return;
                }

                document.getElementById('recruiterName').textContent = user.fullname;
                document.getElementById('recruiterEmail').textContent = user.email;

                const statusBadge = document.getElementById('statusBadge');
                const postJobBtn = document.getElementById('postJobBtn');
                const statusMessage = document.getElementById('statusMessage');

                if (user.status === 'approved') {
                    statusBadge.className = 'alert alert-success py-2 text-center fw-bold';
                    statusBadge.textContent = 'APPROVED';
                    postJobBtn.disabled = false;
                    statusMessage.textContent = 'Account verified! You can now post jobs and view applicants.';
                    
                    postJobBtn.onclick = () => window.location.href = '/recruiter/post-job';
                    
                    // Load data if approved
                    loadJobs();
                } else if (user.status === 'pending') {
                    statusBadge.className = 'alert alert-warning py-2 text-center fw-bold text-dark';
                    statusBadge.textContent = 'PENDING APPROVAL';
                    statusMessage.textContent = 'Your account is under review by the Admin. You will be able to post jobs once approved.';
                } else if (user.status === 'rejected') {
                    statusBadge.className = 'alert alert-danger py-2 text-center fw-bold';
                    statusBadge.textContent = 'REJECTED';
                    statusMessage.textContent = 'Your account application was not approved. Contact support for details.';
                }

            } catch (err) {
                console.error('Error loading dashboard:', err);
                window.location.href = '/login';
            }
        }

        loadDashboard();
    </script>
</body>
</html>
