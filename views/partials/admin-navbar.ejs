<!-- Common Admin Navbar -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link rel="stylesheet" href="/css/style.css">

<nav class="navbar navbar-expand-lg navbar-premium">
  <div class="container-fluid px-4">
    <a class="navbar-brand" href="/admin">
      <i class="fas fa-shield-alt me-2" style="color:#818cf8;"></i>Admin Panel
    </a>
    <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#adminNavbarContent" style="color:rgba(255,255,255,0.7);">
      <i class="fas fa-bars"></i>
    </button>
    <div class="collapse navbar-collapse" id="adminNavbarContent">
      <ul class="navbar-nav ms-auto align-items-center gap-1">
        <li class="nav-item">
          <a class="nav-link <%= typeof activePage !== 'undefined' && activePage === 'dashboard' ? 'active' : '' %>" href="/admin">
            <i class="fas fa-chart-line me-1"></i>Dashboard
          </a>
        </li>
        <li class="nav-item ms-2">
          <a class="btn-nav-danger" href="#" id="adminLogoutLink">
            <i class="fas fa-sign-out-alt me-1"></i>Logout
          </a>
        </li>
      </ul>
    </div>
  </div>
</nav>

<!-- Logout Confirmation Modal -->
<div class="modal fade modal-premium" id="logoutModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header header-danger border-0">
        <h5 class="modal-title fw-bold text-white"><i class="fas fa-sign-out-alt me-2"></i>Confirm Logout</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body text-center py-4">
        <div style="width:70px;height:70px;background:rgba(239,68,68,0.1);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1.25rem;font-size:1.75rem;color:#ef4444;">
          <i class="fas fa-exclamation-triangle"></i>
        </div>
        <h5 class="fw-bold mb-2">Are you sure?</h5>
        <p class="text-muted mb-0" style="font-size:0.9rem;">You will be signed out of the admin session.</p>
      </div>
      <div class="modal-footer justify-content-center border-0 bg-white pb-4">
        <button type="button" class="btn btn-light px-4 fw-bold" data-bs-dismiss="modal">Cancel</button>
        <a href="/api/auth/logout" class="btn btn-danger px-4 fw-bold">
          <i class="fas fa-sign-out-alt me-2"></i>Logout Now
        </a>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const adminLogoutLink = document.getElementById('adminLogoutLink');
    if (adminLogoutLink) {
      adminLogoutLink.addEventListener('click', function(e) {
        e.preventDefault();
        new bootstrap.Modal(document.getElementById('logoutModal')).show();
      });
    }
  });
</script>
