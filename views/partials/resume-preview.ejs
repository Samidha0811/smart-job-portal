<div id="preview-wrapper">
  <div class="resume-paper" id="resume-document">
    <header class="resume-header">
      <div class="resume-name" id="prev-name">YOUR NAME</div>
      <div class="resume-contact">
        <span id="prev-email">email@example.com</span>
        <span id="prev-phone">+1 234 567 890</span>
        <span id="prev-linkedin">linkedin.com/in/username</span>
        <span id="prev-github">github.com/username</span>
      </div>
    </header>

    <div class="resume-section">
      <div class="resume-section-title">Summary</div>
      <div class="resume-summary" id="prev-summary">
        A brief professional summary highlighting your key strengths and career goals.
      </div>
    </div>

    <div class="resume-section">
      <div class="resume-section-title">Experience & Projects</div>
      <div id="prev-projects-list">
        <!-- Projects will be dynamically inserted here -->
        <div class="resume-item">
          <div class="resume-item-header">
            <span>Company name And Designation</span>
            <span>Experience</span>
          </div>
          <div class="resume-item-desc">
            Detailed description of your project and your role in it.
          </div>
        </div>
      </div>
    </div>

    <div class="resume-section">
      <div class="resume-section-title">Education</div>
      <div id="prev-education-list">
        <!-- Education will be dynamically inserted here -->
        <div class="resume-item">
          <div class="resume-item-header">
            <span>Degree Name</span>
            <span>Year</span>
          </div>
          <div class="resume-item-sub">
            <span>College/University Name</span>
            <span>CGPA: 0.0</span>
          </div>
        </div>
      </div>
    </div>

    <div class="resume-section">
      <div class="resume-section-title">Skills</div>
      <div class="resume-skills" id="prev-skills-list">
        <!-- Skills will be dynamically inserted here -->
        <span class="resume-skill-item">Skill 1</span>
        <span class="resume-skill-item">Skill 2</span>
      </div>
    </div>

    <div id="prev-achievements-section" style="display: none;">
      <div class="resume-section-title">Achievements</div>
      <div class="resume-item-desc" id="prev-achievements">
        Optional achievements and certifications.
      </div>
    </div>
  </div>
</div>
