<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="bg-light">
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm fixed-top">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/recruiter/dashboard">Smart Job Portal</a>
            <div class="collapse navbar-collapse">
                <ul class="navbar-nav ms-auto align-items-center">
                    <li class="nav-item"><a class="nav-link fw-bold me-3 text-white" href="/recruiter/dashboard">Dashboard</a></li>
                    <li class="nav-item"><a class="nav-link fw-bold me-3 text-white" href="/recruiter/applications">Applications Received</a></li>
                    <li class="nav-item"><a class="nav-link fw-bold me-3 text-white" href="/recruiter/my-jobs">Posted Jobs</a></li>
                    <li class="nav-item"><a class="btn btn-danger btn-sm ms-3 text-white fw-bold shadow-sm" href="#" id="logoutLink">Logout</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container py-5 mt-5">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card shadow border-0 rounded-3">
                    <div class="card-body ">
                        <h2 class="fw-bold mb-4">Post a New Job</h2>
                        <form id="jobForm">
                            <div class="mb-3">
                                <label for="title" class="form-label">Job Title</label>
                                <input type="text" class="form-control" id="title" name="title" required
                                    placeholder="e.g. Senior Software Engineer">
                            </div>
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label for="location" class="form-label">Location</label>
                                    <input type="text" class="form-control" id="location" name="location"
                                        placeholder="e.g. New York, NY (or Remote)">
                                </div>
                                <div class="col-md-6">
                                    <label for="salary" class="form-label">Salary Range</label>
                                    <input type="text" class="form-control" id="salary" name="salary"
                                        placeholder="e.g. $80k - $120k">
                                </div>
                            </div>
                            <div class="mb-3">
                                <label for="keywords" class="form-label">Keywords (Skills)</label>
                                <input type="text" class="form-control" id="keywords" name="keywords"
                                    placeholder="e.g. nodejs, react, mysql, javascript">
                                <small class="text-muted">Separate with commas</small>
                            </div>
                            <div class="mb-3">
                                <label for="description" class="form-label">Job Description</label>
                                <textarea class="form-control" id="description" name="description" rows="3" required
                                    placeholder="Describe the role, responsibilities, and requirements..."></textarea>
                            </div>

                            <hr class="my-4">

                            <div class="d-flex justify-content-between">
                                <a href="/recruiter/dashboard" class="btn btn-outline-secondary px-4">Cancel</a>
                                <button type="submit" class="btn btn-primary px-5 fw-bold">Post Job</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Logout Confirmation Modal -->
    <div class="modal fade" id="logoutModal" tabindex="-1" aria-labelledby="logoutModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow-lg border-0" style="border-radius: 1rem;">
                <div class="modal-header bg-danger text-white border-0 py-3">
                    <h5 class="modal-title fw-bold" id="logoutModalLabel">
                        <i class="fas fa-sign-out-alt me-2"></i>Confirm Logout
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                        aria-label="Close"></button>
                </div>
                <div class="modal-body p-5 text-center">
                    <div class="mb-3 text-danger">
                        <i class="fas fa-exclamation-circle fa-4x"></i>
                    </div>
                    <h4 class="fw-bold">Are you sure?</h4>
                    <p class="text-muted mb-0">You will be signed out of your session.</p>
                </div>
                <div class="modal-footer border-0 p-3 bg-light justify-content-center">
                    <button type="button" class="btn btn-light px-4 fw-bold text-muted"
                        data-bs-dismiss="modal">Cancel</button>
                    <a href="/api/auth/logout" class="btn btn-danger px-4 fw-bold shadow-sm">Logout Now</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Notification Modal -->
    <div class="modal fade" id="notificationModal" tabindex="-1" aria-labelledby="notificationModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow-lg border-0" style="border-radius: 1rem;">
                <div id="modalHeader" class="modal-header border-0 py-3 text-white">
                    <h5 class="modal-title fw-bold" id="notificationModalLabel">Notification</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-5 text-center">
                    <div id="modalIcon" class="mb-3"></div>
                    <h4 id="modalTitle" class="fw-bold mb-2"></h4>
                    <p id="modalMessage" class="text-muted mb-0"></p>
                </div>
                <div class="modal-footer border-0 p-3 bg-light justify-content-center">
                    <button type="button" class="btn btn-primary px-5 fw-bold shadow-sm rounded-pill" data-bs-dismiss="modal" id="modalOkBtn">OK</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/apiService.js"></script>
    <script>
        function showNotification(title, message, type = 'success', callback = null) {
            const modalEl = document.getElementById('notificationModal');
            const header = document.getElementById('modalHeader');
            const icon = document.getElementById('modalIcon');
            const titleEl = document.getElementById('modalTitle');
            const msgEl = document.getElementById('modalMessage');
            const okBtn = document.getElementById('modalOkBtn');

            header.className = 'modal-header border-0 py-3 text-white ' + (type === 'success' ? 'bg-success' : 'bg-danger');
            icon.innerHTML = type === 'success' ? '<i class="fas fa-check-circle fa-4x text-success"></i>' : '<i class="fas fa-times-circle fa-4x text-danger"></i>';
            titleEl.textContent = title;
            msgEl.textContent = message;

            const modal = new bootstrap.Modal(modalEl);
            
            if (callback) {
                modalEl.addEventListener('hidden.bs.modal', function handler() {
                    callback();
                    modalEl.removeEventListener('hidden.bs.modal', handler);
                });
            }
            
            modal.show();
        }

        // Handle Logout Popup
        document.addEventListener('DOMContentLoaded', () => {
            const logoutLink = document.getElementById('logoutLink');
            if (logoutLink) {
                logoutLink.addEventListener('click', function (e) {
                    e.preventDefault();
                    const modalEl = document.getElementById('logoutModal');
                    const logoutModal = new bootstrap.Modal(modalEl);
                    logoutModal.show();
                });
            }
        });

        // Prevent Back-Forward Cache (bfcache)
        window.addEventListener('pageshow', (event) => {
            if (event.persisted) {
                window.location.reload();
            }
        });

        const jobForm = document.getElementById('jobForm');

        jobForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const formData = new FormData(jobForm);
            const data = Object.fromEntries(formData.entries());

            try {
                const result = await window.apiService.postJob(data);
                if (result.success) {
                    showNotification('Success', 'Job posted successfully!', 'success', () => {
                        window.location.href = '/recruiter/dashboard';
                    });
                } else {
                    showNotification('Error', result.message, 'error');
                }
            } catch (err) {
                console.error('Job Posting Error:', err);
                showNotification('Error', 'An error occurred while posting the job.', 'error');
            }
        });
    </script>
</body>

</html>