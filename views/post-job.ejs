<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — Joblifies - Smart Job Portal</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .setup-container {
      max-width: 850px;
      margin: 3rem auto;
      padding: 0 1.5rem;
    }
    .setup-header {
      text-align: center;
      margin-bottom: 3.5rem;
    }
    .form-section {
      background: var(--white);
      border-radius: var(--radius-lg);
      padding: 2.5rem;
      border: 1px solid var(--border);
      margin-bottom: 2rem;
      transition: var(--transition);
    }
    .form-section:hover {
      border-color: rgba(79, 70, 229, 0.2);
      box-shadow: var(--shadow);
    }
    .section-head {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-bottom: 2rem;
    }
    .section-icon-box {
      width: 46px;
      height: 46px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.2rem;
      flex-shrink: 0;
    }
    .action-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-top: 3rem;
      gap: 1rem;
    }
  </style>
    <link rel="icon" type="image/png" href="/uploads/image.png">
</head>
<body class="dashboard-page">

  <!-- ===== NAVBAR ===== -->
  <nav class="navbar navbar-expand-lg navbar-premium">
    <div class="container">
      <a class="navbar-brand" href="/recruiter/dashboard">
        <i class="fas fa-briefcase me-2" style="color:#818cf8;"></i>Joblifies - Smart Job Portal
      </a>
      <div class="collapse navbar-collapse">
        <ul class="navbar-nav ms-auto align-items-center gap-1">
          <li class="nav-item"><a class="nav-link" href="/recruiter/dashboard"><i class="fas fa-th-large me-1"></i>Dashboard</a></li>
          <li class="nav-item"><a class="nav-link" href="/recruiter/applications"><i class="fas fa-users me-1"></i>Applications</a></li>
          <li class="nav-item"><a class="nav-link" href="/recruiter/my-jobs"><i class="fas fa-list me-1"></i>Posted Jobs</a></li>
          <li class="nav-item ms-2">
            <a class="btn-nav-danger" href="#" id="logoutLink"><i class="fas fa-sign-out-alt me-1"></i>Logout</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="setup-container">
    <!-- Header -->
    <div class="setup-header">
      <div class="section-label mx-auto">
        <i class="fas fa-pen-fancy me-1 text-primary"></i> Recruitment
      </div>
      <h1 class="page-title mt-3" style="font-size: 2.5rem;">Post a New Job</h1>
      <p class="text-muted mt-2" style="font-size: 1.1rem;">
        Attract top talent by providing clear and professional job details.
      </p>
    </div>

    <!-- Main Form Section -->
    <div class="form-section">
      <div class="section-head">
        <div class="section-icon-box" style="background: rgba(79, 70, 229, 0.1); color: var(--primary);">
          <i class="fas fa-bullhorn"></i>
        </div>
        <div>
          <h4 class="mb-0 fw-bold" style="font-size: 1.1rem;">Listing Details</h4>
          <p class="text-muted mb-0" style="font-size: 0.85rem;">Specify everything about the role</p>
        </div>
      </div>

      <form id="jobForm">
        <div class="row g-4">
          <!-- Job Title -->
          <div class="col-12">
            <label class="form-label-premium">Job Title <span class="text-danger">*</span></label>
            <div class="input-group-premium">
              <i class="fas fa-briefcase input-icon"></i>
              <input type="text" class="form-control-premium" id="title" name="title" required
                placeholder="e.g. Senior Software Engineer">
            </div>
          </div>

          <!-- Location + Salary -->
          <div class="col-md-6">
            <label class="form-label-premium">Location</label>
            <div class="input-group-premium">
              <i class="fas fa-map-marker-alt input-icon"></i>
              <input type="text" class="form-control-premium" id="location" name="location"
                placeholder="e.g. Mumbai, MH (or Remote)">
            </div>
          </div>
          <div class="col-md-6">
            <label class="form-label-premium">Salary Range</label>
            <div class="input-group-premium">
              <i class="fas fa-tag input-icon"></i>
              <input type="text" class="form-control-premium" id="salary" name="salary"
                placeholder="e.g. ₹8L – ₹15L per annum">
            </div>
          </div>

          <!-- Keywords -->
          <div class="col-12">
            <label class="form-label-premium">Required Skills / Keywords</label>
            <div class="input-group-premium">
              <i class="fas fa-tags input-icon"></i>
              <input type="text" class="form-control-premium" id="keywords" name="keywords"
                placeholder="e.g. Node.js, React, MySQL, Docker">
            </div>
            <div class="form-text mt-2" style="font-size: 0.8rem; color: var(--gray-light);">
              <i class="fas fa-lightbulb me-1"></i> Separate skills with commas for better matching.
            </div>
          </div>

          <!-- Description -->
          <div class="col-12">
            <label class="form-label-premium">Job Description <span class="text-danger">*</span></label>
            <textarea class="form-control-premium" id="description" name="description" rows="6" required
              placeholder="Describe the role, responsibilities, requirements and perks..."></textarea>
          </div>
        </div>

        <div class="action-row">
          <a href="/recruiter/dashboard" class="btn btn-light fw-bold px-4 py-2" style="border-radius:12px; border:1px solid var(--border);">
            <i class="fas fa-times me-1"></i> Cancel
          </a>
          <button type="submit" class="btn-submit-premium" id="submitBtn" style="width: auto; padding: 1rem 3rem;">
            Post Job Listing <i class="fas fa-paper-plane ms-2"></i>
          </button>
        </div>
      </form>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script src="/js/apiService.js"></script>
  <script>
    document.getElementById('logoutLink').addEventListener('click', function(e) {
      e.preventDefault();
      Swal.fire({
        title: 'Confirm Logout',
        text: 'Are you sure you want to log out?',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#ef4444',
        cancelButtonColor: '#64748b',
        confirmButtonText: 'Yes, logout'
      }).then((result) => {
        if (result.isConfirmed) {
          window.location.href = '/api/auth/logout';
        }
      });
    });
    window.addEventListener('pageshow', (e) => { if (e.persisted) window.location.reload(); });

    function showNotification(title, message, type = 'success', callback = null) {
      Swal.fire({
        title: title,
        text: message,
        icon: type,
        confirmButtonColor: '#4f46e5'
      }).then(() => {
        if (callback) callback();
      });
    }

    document.getElementById('jobForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = document.getElementById('submitBtn');
      btn.disabled = true;
      btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Posting...';
      const formData = new FormData(document.getElementById('jobForm'));
      const data = Object.fromEntries(formData.entries());
      try {
        const result = await window.apiService.postJob(data);
        if (result.success) {
          showNotification('Success!', 'Job posted successfully. Redirecting...', 'success', () => { window.location.href = '/recruiter/dashboard'; });
        } else {
          showNotification('Error', result.message, 'error');
          btn.disabled = false;
          btn.innerHTML = 'Post Job Listing <i class="fas fa-paper-plane ms-2"></i>';
        }
      } catch (err) {
        showNotification('Error', 'An error occurred while posting.', 'error');
        btn.disabled = false;
        btn.innerHTML = 'Post Job Listing <i class="fas fa-paper-plane ms-2"></i>';
      }
    });
  </script>
</body>
</html>

</html>
