<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — Smart Job Portal</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="dashboard-page">

  <!-- ===== NAVBAR ===== -->
  <nav class="navbar navbar-expand-lg navbar-premium">
    <div class="container">
      <span class="navbar-brand">
        <i class="fas fa-briefcase me-2" style="color:#818cf8;"></i>SmartJobPortal
      </span>
      <div class="ms-auto">
        <a href="/api/auth/logout" class="btn-nav-danger">
          <i class="fas fa-sign-out-alt me-1"></i>Logout
        </a>
      </div>
    </div>
  </nav>

  <div class="dashboard-container" style="max-width:740px;">
    <!-- Header -->
    <div class="text-center mb-5">
      <div class="section-label mx-auto" style="display:inline-flex;">
        <i class="fas fa-user-check me-1"></i> Profile Setup
      </div>
      <h1 class="page-title mt-2" style="font-size:2rem;">Complete Your Profile</h1>
      <p style="color:var(--gray);font-size:0.9rem;margin-top:0.5rem;">
        Just a few more details and you're ready to apply to top jobs!
      </p>
    </div>

    <!-- Onboarding Card -->
    <div class="main-card">
      <div style="background:linear-gradient(135deg,var(--primary) 0%,var(--primary-dark) 100%);padding:1.75rem 2rem;border-radius:var(--radius-lg) var(--radius-lg) 0 0;">
        <div class="d-flex align-items-center gap-3">
          <div style="width:52px;height:52px;background:rgba(255,255,255,0.2);border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:1.4rem;color:#fff;flex-shrink:0;">
            <i class="fas fa-user-circle"></i>
          </div>
          <div>
            <div style="color:#fff;font-weight:700;font-size:1.05rem;">You're almost there!</div>
            <div style="color:rgba(255,255,255,0.7);font-size:0.85rem;">Complete your profile to start applying to jobs</div>
          </div>
          <div class="ms-auto d-flex gap-2">
            <div style="width:8px;height:8px;background:rgba(255,255,255,0.4);border-radius:50%;"></div>
            <div style="width:8px;height:8px;background:rgba(255,255,255,0.4);border-radius:50%;"></div>
            <div style="width:8px;height:8px;background:#fff;border-radius:50%;"></div>
          </div>
        </div>
      </div>

      <div class="main-card-body">
        <form id="profileForm" enctype="multipart/form-data">

          <!-- Personal Information -->
          <div class="mb-5">
            <div class="d-flex align-items-center gap-2 mb-4">
              <div style="width:32px;height:32px;background:rgba(79,70,229,0.1);border-radius:8px;display:flex;align-items:center;justify-content:center;color:var(--primary);">
                <i class="fas fa-user" style="font-size:0.85rem;"></i>
              </div>
              <h4 style="font-size:1rem;font-weight:700;color:var(--dark);margin:0;">Personal Information</h4>
            </div>
            <div class="row g-3">
              <div class="col-md-6">
                <label for="phone_number" class="form-label fw-bold" style="font-size:0.85rem;">Phone Number <span class="text-danger">*</span></label>
                <input type="tel" class="form-control" id="phone_number" name="phone_number"
                  placeholder="+91 9876543210" required style="padding:0.8rem;">
              </div>
              <div class="col-12">
                <label for="bio" class="form-label fw-bold" style="font-size:0.85rem;">Professional Bio <span class="text-danger">*</span></label>
                <textarea class="form-control" id="bio" name="bio" rows="3" required style="padding:0.8rem;"
                  placeholder="Briefly describe your career goals and unique strengths..."></textarea>
                <div style="font-size:0.78rem;color:var(--gray);margin-top:0.3rem;">This is what recruiters will see about you.</div>
              </div>
            </div>
          </div>

          <!-- Professional Details -->
          <div class="mb-5">
            <div class="d-flex align-items-center gap-2 mb-4">
              <div style="width:32px;height:32px;background:rgba(6,182,212,0.1);border-radius:8px;display:flex;align-items:center;justify-content:center;color:#06b6d4;">
                <i class="fas fa-briefcase" style="font-size:0.85rem;"></i>
              </div>
              <h4 style="font-size:1rem;font-weight:700;color:var(--dark);margin:0;">Professional Details</h4>
            </div>
            <div class="row g-3">
              <div class="col-12">
                <label for="education" class="form-label fw-bold" style="font-size:0.85rem;">Education <span class="text-danger">*</span></label>
                <input type="text" class="form-control" id="education" name="education" required style="padding:0.8rem;"
                  placeholder="e.g. B.Tech in Computer Science, Mumbai University (2022)">
              </div>
              <div class="col-md-6">
                <label for="experience_years" class="form-label fw-bold" style="font-size:0.85rem;">Years of Experience <span class="text-danger">*</span></label>
                <input type="number" class="form-control" id="experience_years" name="experience_years"
                  value="0" min="0" required style="padding:0.8rem;">
              </div>
              <div class="col-12">
                <label for="skills" class="form-label fw-bold" style="font-size:0.85rem;">Key Skills <span class="text-danger">*</span></label>
                <input type="text" class="form-control" id="skills" name="skills" required style="padding:0.8rem;"
                  placeholder="e.g. Node.js, React, Python, SQL">
                <div style="font-size:0.78rem;color:var(--gray);margin-top:0.3rem;">Separate with commas. This is used for job matching.</div>
              </div>
            </div>
          </div>

          <!-- Resume Upload -->
          <div class="mb-5">
            <div class="d-flex align-items-center gap-2 mb-4">
              <div style="width:32px;height:32px;background:rgba(245,158,11,0.1);border-radius:8px;display:flex;align-items:center;justify-content:center;color:#f59e0b;">
                <i class="fas fa-file-upload" style="font-size:0.85rem;"></i>
              </div>
              <h4 style="font-size:1rem;font-weight:700;color:var(--dark);margin:0;">Resume Upload</h4>
            </div>
            <div id="dropZone"
              style="background:var(--bg);border:2px dashed var(--border);border-radius:var(--radius-lg);padding:2.5rem;text-align:center;cursor:pointer;transition:var(--transition);"
              onclick="document.getElementById('resume').click()"
              onmouseover="this.style.borderColor='var(--primary)';this.style.background='rgba(79,70,229,0.03)'"
              onmouseout="this.style.borderColor='var(--border)';this.style.background='var(--bg)'">
              <div style="width:56px;height:56px;background:rgba(79,70,229,0.1);border-radius:14px;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;font-size:1.4rem;color:var(--primary);">
                <i class="fas fa-cloud-upload-alt"></i>
              </div>
              <h6 class="fw-bold mb-1">Click to upload your resume</h6>
              <p style="color:var(--gray);font-size:0.82rem;margin:0;">PDF only. Maximum file size: 5MB</p>
              <input type="file" id="resume" name="resume" class="visually-hidden" accept=".pdf" required>
            </div>
            <div id="file-name" style="margin-top:0.75rem;font-size:0.875rem;font-weight:600;color:#059669;display:none;">
              <i class="fas fa-check-circle me-2"></i><span id="fileName"></span>
            </div>
          </div>

          <!-- Submit -->
          <div class="d-grid">
            <button type="submit" class="btn-submit-premium" id="submitBtn">
              Finalize Profile <i class="fas fa-arrow-right ms-2"></i>
            </button>
          </div>

        </form>
      </div>
    </div>
  </div>

  <!-- Status Modal -->
  <div class="modal fade modal-premium" id="statusModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-body text-center py-5">
          <div id="modalIcon" class="mb-4"></div>
          <h3 id="modalTitle" class="fw-bold mb-3"></h3>
          <p id="modalMessage" class="text-muted" style="font-size:0.95rem;"></p>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    const resumeInput = document.getElementById('resume');
    const fileNameDisplay = document.getElementById('file-name');
    const fileNameSpan = document.getElementById('fileName');

    resumeInput.onchange = () => {
      if (resumeInput.files.length > 0) {
        fileNameSpan.textContent = resumeInput.files[0].name;
        fileNameDisplay.style.display = 'block';
      }
    };

    document.getElementById('profileForm').onsubmit = async (e) => {
      e.preventDefault();
      const formData = new FormData(document.getElementById('profileForm'));
      const btn = document.getElementById('submitBtn');
      btn.disabled = true;
      btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Saving Profile...';

      try {
        const res = await fetch('/api/seeker/complete-profile', { method: 'POST', body: formData });
        const result = await res.json();
        if (result.success) {
          showStatus('Profile Complete!', 'Your profile is set up. Redirecting to dashboard...', 'success');
          setTimeout(() => window.location.href = result.redirectTo, 2000);
        } else {
          showStatus('Error', result.message || 'Something went wrong.', 'error');
          btn.disabled = false;
          btn.innerHTML = 'Finalize Profile <i class="fas fa-arrow-right ms-2"></i>';
        }
      } catch (err) {
        showStatus('Error', 'Failed to submit profile. Please try again.', 'error');
        btn.disabled = false;
        btn.innerHTML = 'Finalize Profile <i class="fas fa-arrow-right ms-2"></i>';
      }
    };

    function showStatus(title, message, type) {
      const modalEl = document.getElementById('statusModal');
      document.getElementById('modalIcon').innerHTML = type === 'success'
        ? '<div style="width:80px;height:80px;background:rgba(16,185,129,0.1);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto;font-size:2.5rem;color:#10b981;"><i class="fas fa-check-circle"></i></div>'
        : '<div style="width:80px;height:80px;background:rgba(239,68,68,0.1);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto;font-size:2.5rem;color:#ef4444;"><i class="fas fa-times-circle"></i></div>';
      document.getElementById('modalTitle').textContent = title;
      document.getElementById('modalMessage').textContent = message;
      new bootstrap.Modal(modalEl).show();
    }
  </script>
</body>
</html>
