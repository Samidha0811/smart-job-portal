<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= title %> — Admin Panel
  </title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>

<body class="dashboard-page">

  <%- include('partials/admin-navbar') %>

    <div class="dashboard-container">
      <!-- Breadcrumb + Back -->
      <div class="d-flex align-items-center gap-3 mb-4">
        <a href="/admin"
          style="color:var(--gray);font-size:0.85rem;text-decoration:none;display:inline-flex;align-items:center;gap:0.4rem;padding:0.5rem 1rem;background:var(--white);border:1px solid var(--border);border-radius:8px;font-weight:600;transition:var(--transition);"
          onmouseover="this.style.borderColor='var(--primary)';this.style.color='var(--primary)'"
          onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--gray)'">
          <i class="fas fa-arrow-left"></i> Back to Dashboard
        </a>
        <div>
          <span style="color:var(--gray);font-size:0.82rem;">Admin Panel → Recruiter Review</span>
        </div>
      </div>

      <!-- Hero Row: Recruiter identity + Status -->
      <div class="main-card mb-4">
        <div
          style="background:linear-gradient(135deg,var(--dark) 0%,var(--dark-2) 100%);padding:2rem;border-radius:var(--radius-lg) var(--radius-lg) 0 0;">
          <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
            <div class="d-flex align-items-center gap-4">
              <div
                style="width:72px;height:72px;background:rgba(129,140,248,0.2);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:2rem;color:#818cf8;border:2px solid rgba(255,255,255,0.15);flex-shrink:0;">
                <%= recruiter.fullname.charAt(0).toUpperCase() %>
              </div>
              <div>
                <div
                  style="color:rgba(255,255,255,0.5);font-size:0.75rem;text-transform:uppercase;letter-spacing:0.08em;font-weight:600;margin-bottom:0.2rem;">
                  Recruiter Profile</div>
                <h2 style="color:#fff;font-size:1.5rem;font-weight:800;margin-bottom:0.25rem;">
                  <%= recruiter.fullname %>
                </h2>
                <div style="color:rgba(255,255,255,0.55);font-size:0.875rem;">
                  <%= recruiter.email %>
                </div>
              </div>
            </div>
            <div>
              <% if (recruiter.status==='pending' ) { %>
                <span class="status-badge status-pending" style="font-size:0.85rem;padding:0.6rem 1.25rem;">
                  <i class="fas fa-hourglass-half"></i> Pending Verification
                </span>
                <% } else if (recruiter.status==='approved' || recruiter.status==='active' ) { %>
                  <span class="status-badge status-approved" style="font-size:0.85rem;padding:0.6rem 1.25rem;">
                    <i class="fas fa-check-circle"></i> Verified Partner
                  </span>
                  <% } else { %>
                    <span class="status-badge status-rejected" style="font-size:0.85rem;padding:0.6rem 1.25rem;">
                      <i class="fas fa-times-circle"></i> Rejected
                    </span>
                    <% } %>
            </div>
          </div>
        </div>
        <!-- Submission date row -->
        <div style="padding:1rem 2rem;border-bottom:1px solid var(--border);display:flex;gap:2rem;flex-wrap:wrap;">
          <div style="font-size:0.82rem;color:var(--gray);">
          </div>
          <% if (recruiter.company_name) { %>
            <div style="font-size:0.82rem;color:var(--gray);">
              <i class="fas fa-building me-1 text-primary"></i>
              Company: <strong style="color:var(--dark);">
                <%= recruiter.company_name %>
              </strong>
            </div>
            <% } %>
              <% if (recruiter.designation) { %>
                <div style="font-size:0.82rem;color:var(--gray);">
                  <i class="fas fa-id-badge me-1 text-primary"></i>
                  Designation: <strong style="color:var(--dark);">
                    <%= recruiter.designation %>
                  </strong>
                </div>
                <% } %>
        </div>
      </div>

      <div class="row g-4">
        <!-- Left Column -->
        <div class="col-lg-8">
          <!-- Company Overview -->
          <div class="main-card mb-4">
            <div class="main-card-header">
              <h3 class="page-title" style="font-size:1rem;">
                <i class="fas fa-building me-2" style="color:var(--primary);"></i>Company Overview
              </h3>
            </div>
            <div class="main-card-body">
              <div class="row g-3">
                <div class="col-md-6">
                  <div class="sidebar-info-item">
                    <div class="sidebar-info-icon icon-purple"><i class="fas fa-building"></i></div>
                    <div>
                      <div
                        style="font-size:0.72rem;color:var(--gray);text-transform:uppercase;letter-spacing:0.05em;font-weight:700;margin-bottom:0.15rem;">
                        Company Name</div>
                      <div style="font-size:0.9rem;font-weight:600;color:var(--dark);">
                        <%= recruiter.company_name || 'N/A' %>
                      </div>
                    </div>
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="sidebar-info-item">
                    <div class="sidebar-info-icon icon-cyan"><i class="fas fa-envelope"></i></div>
                    <div>
                      <div
                        style="font-size:0.72rem;color:var(--gray);text-transform:uppercase;letter-spacing:0.05em;font-weight:700;margin-bottom:0.15rem;">
                        Official Email</div>
                      <div style="font-size:0.875rem;font-weight:600;color:var(--dark);">
                        <%= recruiter.company_email || 'N/A' %>
                      </div>
                    </div>
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="sidebar-info-item">
                    <div class="sidebar-info-icon icon-amber"><i class="fas fa-industry"></i></div>
                    <div>
                      <div
                        style="font-size:0.72rem;color:var(--gray);text-transform:uppercase;letter-spacing:0.05em;font-weight:700;margin-bottom:0.15rem;">
                        Industry</div>
                      <div style="font-size:0.875rem;font-weight:600;color:var(--dark);">
                        <%= recruiter.industry || 'N/A' %>
                      </div>
                    </div>
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="sidebar-info-item">
                    <div class="sidebar-info-icon icon-emerald"><i class="fas fa-users"></i></div>
                    <div>
                      <div
                        style="font-size:0.72rem;color:var(--gray);text-transform:uppercase;letter-spacing:0.05em;font-weight:700;margin-bottom:0.15rem;">
                        Company Size</div>
                      <div style="font-size:0.875rem;font-weight:600;color:var(--dark);">
                        <%= recruiter.company_size || 'N/A' %> Employees
                      </div>
                    </div>
                  </div>
                </div>
                <% if (recruiter.company_website) { %>
                  <div class="col-md-6">
                    <div class="sidebar-info-item">
                      <div class="sidebar-info-icon icon-purple"><i class="fas fa-globe"></i></div>
                      <div>
                        <div
                          style="font-size:0.72rem;color:var(--gray);text-transform:uppercase;letter-spacing:0.05em;font-weight:700;margin-bottom:0.15rem;">
                          Website</div>
                        <a href="<%= recruiter.company_website %>" target="_blank"
                          style="font-size:0.875rem;font-weight:600;color:var(--primary);text-decoration:none;">
                          <%= recruiter.company_website.replace('https://','').replace('http://','') %> <i
                              class="fas fa-external-link-alt" style="font-size:0.7rem;"></i>
                        </a>
                      </div>
                    </div>
                  </div>
                  <% } %>
                    <% if (recruiter.linkedin_profile) { %>
                      <div class="col-md-6">
                        <div class="sidebar-info-item">
                          <div class="sidebar-info-icon icon-cyan"><i class="fab fa-linkedin"></i></div>
                          <div>
                            <div
                              style="font-size:0.72rem;color:var(--gray);text-transform:uppercase;letter-spacing:0.05em;font-weight:700;margin-bottom:0.15rem;">
                              LinkedIn</div>
                            <a href="<%= recruiter.linkedin_profile %>" target="_blank"
                              style="font-size:0.875rem;font-weight:600;color:var(--primary);text-decoration:none;">
                              Company Page <i class="fas fa-external-link-alt" style="font-size:0.7rem;"></i>
                            </a>
                          </div>
                        </div>
                      </div>
                      <% } %>
                        <% if (recruiter.company_description) { %>
                          <div class="col-12">
                            <div
                              style="padding:1rem;background:var(--bg);border-radius:10px;border:1px solid var(--border);">
                              <div
                                style="font-size:0.72rem;color:var(--gray);text-transform:uppercase;letter-spacing:0.05em;font-weight:700;margin-bottom:0.5rem;">
                                Company Description</div>
                              <div style="font-size:0.875rem;color:var(--dark-2);line-height:1.7;">
                                <%= recruiter.company_description %>
                              </div>
                            </div>
                          </div>
                          <% } %>
              </div>
            </div>
          </div>

          <!-- Documents -->
          <div class="main-card">
            <div class="main-card-header">
              <h3 class="page-title" style="font-size:1rem;">
                <i class="fas fa-file-contract me-2" style="color:var(--success);"></i>Verification Documents
              </h3>
            </div>
            <div class="main-card-body">
              <div class="row g-3">
                <!-- Registration Cert -->
                <div class="col-md-4">
                  <div
                    style="background:var(--bg);border:1px solid var(--border);border-radius:14px;padding:1.5rem;text-align:center;transition:var(--transition);"
                    onmouseover="this.style.borderColor='rgba(245,158,11,0.4)';this.style.transform='translateY(-2px)'"
                    onmouseout="this.style.borderColor='var(--border)';this.style.transform='none'">
                    <div
                      style="width:56px;height:56px;background:rgba(245,158,11,0.1);border-radius:14px;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;font-size:1.4rem;color:#f59e0b;">
                      <i class="fas fa-certificate"></i>
                    </div>
                    <div class="fw-bold mb-1" style="font-size:0.875rem;">Registration Cert</div>
                    <div style="font-size:0.78rem;color:var(--gray);margin-bottom:1rem;">ID: <%=
                        recruiter.registration_cert_no || 'N/A' %>
                    </div>
                    <% if (recruiter.registration_cert_no) { %>
                      <a href="/api/recruiter/document/registration_cert/<%= recruiter.user_id %>" target="_blank"
                        class="btn btn-sm fw-bold w-100"
                        style="background:rgba(245,158,11,0.1);color:#b45309;border:1px solid rgba(245,158,11,0.2);border-radius:8px;">
                        <i class="fas fa-eye me-1"></i>View Document
                      </a>
                      <% } else { %>
                        <span class="pill pill-danger w-100 justify-content-center">Not Uploaded</span>
                        <% } %>
                  </div>
                </div>
                <!-- GST -->
                <div class="col-md-4">
                  <div
                    style="background:var(--bg);border:1px solid var(--border);border-radius:14px;padding:1.5rem;text-align:center;transition:var(--transition);"
                    onmouseover="this.style.borderColor='rgba(6,182,212,0.4)';this.style.transform='translateY(-2px)'"
                    onmouseout="this.style.borderColor='var(--border)';this.style.transform='none'">
                    <div
                      style="width:56px;height:56px;background:rgba(6,182,212,0.1);border-radius:14px;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;font-size:1.4rem;color:#06b6d4;">
                      <i class="fas fa-receipt"></i>
                    </div>
                    <div class="fw-bold mb-1" style="font-size:0.875rem;">GST / Tax</div>
                    <div style="font-size:0.78rem;color:var(--gray);margin-bottom:1rem;">ID: <%= recruiter.gst_number
                        || 'N/A' %>
                    </div>
                    <% if (recruiter.gst_number) { %>
                      <a href="/api/recruiter/document/gst_doc/<%= recruiter.user_id %>" target="_blank"
                        class="btn btn-sm fw-bold w-100"
                        style="background:rgba(6,182,212,0.1);color:#0891b2;border:1px solid rgba(6,182,212,0.2);border-radius:8px;">
                        <i class="fas fa-eye me-1"></i>View Document
                      </a>
                      <% } else { %>
                        <span class="pill pill-secondary w-100 justify-content-center">Optional / Not Set</span>
                        <% } %>
                  </div>
                </div>
                <!-- PAN -->
                <div class="col-md-4">
                  <div
                    style="background:var(--bg);border:1px solid var(--border);border-radius:14px;padding:1.5rem;text-align:center;transition:var(--transition);"
                    onmouseover="this.style.borderColor='rgba(16,185,129,0.4)';this.style.transform='translateY(-2px)'"
                    onmouseout="this.style.borderColor='var(--border)';this.style.transform='none'">
                    <div
                      style="width:56px;height:56px;background:rgba(16,185,129,0.1);border-radius:14px;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;font-size:1.4rem;color:#10b981;">
                      <i class="fas fa-id-card"></i>
                    </div>
                    <div class="fw-bold mb-1" style="font-size:0.875rem;">PAN Card</div>
                    <div style="font-size:0.78rem;color:var(--gray);margin-bottom:1rem;">ID: <%= recruiter.pan_number
                        || 'N/A' %>
                    </div>
                    <% if (recruiter.pan_number) { %>
                      <a href="/api/recruiter/document/pan_doc/<%= recruiter.user_id %>" target="_blank"
                        class="btn btn-sm fw-bold w-100"
                        style="background:rgba(16,185,129,0.1);color:#059669;border:1px solid rgba(16,185,129,0.2);border-radius:8px;">
                        <i class="fas fa-eye me-1"></i>View Document
                      </a>
                      <% } else { %>
                        <span class="pill pill-danger w-100 justify-content-center">Not Uploaded</span>
                        <% } %>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Right Column -->
        <div class="col-lg-4">
          <!-- Address -->
          <div class="sidebar-card mb-4">
            <div class="sidebar-header">
              <div
                style="color:rgba(255,255,255,0.6);font-size:0.75rem;text-transform:uppercase;letter-spacing:0.08em;margin-bottom:0.75rem;font-weight:700;">
                <i class="fas fa-map-marker-alt me-1"></i> Address
              </div>
              <div style="color:#fff;font-size:1rem;font-weight:700;">
                <%= recruiter.address_line %>
              </div>
              <div style="color:rgba(255,255,255,0.65);font-size:0.875rem;margin-top:0.35rem;">
                <%= recruiter.city %>, <%= recruiter.state %>
              </div>
              <div style="color:rgba(255,255,255,0.5);font-size:0.83rem;margin-top:0.2rem;">
                <%= recruiter.country %> — <%= recruiter.pincode %>
              </div>
            </div>
            <div class="sidebar-body">
              <div class="sidebar-info-item">
                <div class="sidebar-info-icon icon-cyan"><i class="fas fa-phone-alt"></i></div>
                <div>
                  <div
                    style="font-size:0.72rem;color:var(--gray);text-transform:uppercase;letter-spacing:0.05em;font-weight:700;margin-bottom:0.15rem;">
                    Contact</div>
                  <div style="font-size:0.875rem;font-weight:600;color:var(--dark);">
                    <%= recruiter.contact_number %>
                  </div>
                </div>
              </div>
              <div class="sidebar-info-item mt-2">
                <div class="sidebar-info-icon icon-purple"><i class="fas fa-id-badge"></i></div>
                <div>
                  <div
                    style="font-size:0.72rem;color:var(--gray);text-transform:uppercase;letter-spacing:0.05em;font-weight:700;margin-bottom:0.15rem;">
                    Designation</div>
                  <div style="font-size:0.875rem;font-weight:600;color:var(--dark);">
                    <%= recruiter.designation %>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Decision Card -->
          <% if (recruiter.status==='pending' ) { %>
            <div
              style="background:var(--dark);border-radius:var(--radius-lg);padding:1.75rem;box-shadow:var(--shadow-lg);">
              <div
                style="color:rgba(255,255,255,0.5);font-size:0.75rem;text-transform:uppercase;letter-spacing:0.08em;text-align:center;font-weight:700;margin-bottom:1.25rem;">
                <i class="fas fa-gavel me-1"></i> Admin Decision
              </div>
              <div class="d-grid gap-3">
                <form action="/api/admin/approve" method="POST"
                  onsubmit="return confirm('APPROVE this recruiter? They will gain full access to post jobs.');">
                  <input type="hidden" name="userId" value="<%= recruiter.user_id %>">
                  <button type="submit" class="btn w-100 fw-bold py-3"
                    style="background:linear-gradient(135deg,#10b981,#059669);color:#fff;border:none;border-radius:12px;font-family:var(--font);font-size:0.95rem;box-shadow:0 4px 15px rgba(16,185,129,0.3);transition:var(--transition);"
                    onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='none'">
                    <i class="fas fa-check-circle me-2"></i>Approve Recruiter
                  </button>
                </form>
                <form action="/api/admin/reject" method="POST"
                  onsubmit="return confirm('REJECT this recruiter? They will be denied access.');">
                  <input type="hidden" name="userId" value="<%= recruiter.user_id %>">
                  <button type="submit" class="btn w-100 fw-bold py-3"
                    style="background:transparent;color:#f87171;border:2px solid rgba(239,68,68,0.4);border-radius:12px;font-family:var(--font);font-size:0.95rem;transition:var(--transition);"
                    onmouseover="this.style.background='rgba(239,68,68,0.1)'"
                    onmouseout="this.style.background='transparent'">
                    <i class="fas fa-times-circle me-2"></i>Reject Request
                  </button>
                </form>
              </div>
              <p
                style="color:rgba(255,255,255,0.3);font-size:0.75rem;text-align:center;margin-top:1rem;margin-bottom:0;">
                This decision will notify the recruiter via email.
              </p>
            </div>
            <% } else { %>
              <div
                style="background:var(--white);border:1px solid var(--border);border-radius:var(--radius-lg);padding:2rem;text-align:center;box-shadow:var(--shadow);">
                <div
                  style="width:64px;height:64px;background:rgba(79,70,229,0.1);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;font-size:1.75rem;color:var(--primary);">
                  <i class="fas fa-info-circle"></i>
                </div>
                <h6 class="fw-bold mb-2">Decision Completed</h6>
                <p style="color:var(--gray);font-size:0.85rem;margin-bottom:1.5rem;">This recruiter's profile has
                  already been processed.</p>
                <a href="/admin" class="btn btn-primary fw-bold w-100 py-3" style="border-radius:12px;">
                  <i class="fas fa-arrow-left me-2"></i>Back to Panel
                </a>
              </div>
              <% } %>
        </div>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/apiService.js"></script>
</body>

</html>