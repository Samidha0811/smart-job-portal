<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Smart Job Portal</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f8fafc; }
        .card { border: none; border-radius: 1rem; }
        .section-header { position: relative; padding-left: 1.5rem; }
        .section-header::before { content: ''; position: absolute; left: 0; top: 0.25rem; bottom: 0.25rem; width: 4px; border-radius: 2px; }
        .section-header-primary::before { background-color: #0d6efd; }
        .section-header-success::before { background-color: #198754; }
        .doc-card { transition: transform 0.2s, box-shadow 0.2s; cursor: pointer; border-radius: 0.75rem; border: 1px solid #e2e8f0; }
        .doc-card:hover { transform: translateY(-3px); box-shadow: 0 10px 20px rgba(0,0,0,0.05); border-color: #0d6efd; }
        .info-label { color: #64748b; font-size: 0.875rem; font-weight: 500; margin-bottom: 0.25rem; }
        .info-value { color: #1e293b; font-weight: 600; margin-bottom: 1.25rem; }
        .status-badge-lg { padding: 0.5rem 1.25rem; border-radius: 50rem; font-weight: 600; font-size: 0.9rem; }
        .btn-action { padding: 0.75rem 2.5rem; border-radius: 0.75rem; font-weight: 700; transition: all 0.2s; }
        .btn-action:hover { transform: scale(1.02); }
    </style>
</head>
<body class="bg-light">
    <%- include('partials/admin-navbar') %>

    <div class="container py-5 mt-5">
        <div class="row justify-content-center">
            <div class="col-lg-11">
                <!-- Header Card -->
                <div class="card shadow-sm border-0 mb-4 overflow-hidden">
                    <div class="card-body p-4 bg-white">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <nav aria-label="breadcrumb">
                                    <ol class="breadcrumb mb-2 small">
                                        <li class="breadcrumb-item"><a href="/admin" class="text-decoration-none">Recruiters</a></li>
                                        <li class="breadcrumb-item active" aria-current="page">Verification</li>
                                    </ol>
                                </nav>
                                <h3 class="fw-bold mb-0 text-slate-800">
                                    <i class="fas fa-user-shield text-primary me-2"></i>Review Recruiter Profile
                                </h3>
                            </div>
                            <div>
                                <% if (recruiter.status === 'pending') { %>
                                    <span class="status-badge-lg bg-warning text-dark"><i class="fas fa-clock shadow-sm me-2"></i>Pending Verification</span>
                                <% } else if (recruiter.status === 'approved' || recruiter.status === 'active') { %>
                                    <span class="status-badge-lg bg-success text-white"><i class="fas fa-check-circle shadow-sm me-2"></i>Verified Partner</span>
                                <% } else { %>
                                    <span class="status-badge-lg bg-danger text-white"><i class="fas fa-times-circle shadow-sm me-2"></i>Registration Rejected</span>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <!-- Main Info Column -->
                    <div class="col-md-8">
                        <!-- Company Card -->
                        <div class="card shadow-sm border-0 mb-4">
                            <div class="card-body p-4">
                                <h5 class="fw-bold section-header section-header-primary mb-4 text-primary">COMPANY OVERVIEW</h5>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="info-label">REGISTRATION NAME</div>
                                        <div class="info-value"><%= recruiter.company_name %></div>
                                        
                                        <div class="info-label">INDUSTRY TYPE</div>
                                        <div class="info-value"><span class="badge bg-light text-primary border"><%= recruiter.industry %></span></div>

                                        <div class="info-label">WEBSITE</div>
                                        <div class="info-value"><a href="<%= recruiter.company_website %>" target="_blank" class="text-decoration-none text-primary"><%= recruiter.company_website %> <i class="fas fa-external-link-alt small"></i></a></div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="info-label">OFFICIAL EMAIL</div>
                                        <div class="info-value font-monospace"><%= recruiter.company_email %></div>

                                        <div class="info-label">OPERATIONAL SIZE</div>
                                        <div class="info-value"><%= recruiter.company_size %> Employees</div>

                                        <div class="info-label">LINKEDIN PROFILE</div>
                                        <div class="info-value"><a href="<%= recruiter.linkedin_profile %>" target="_blank" class="text-decoration-none text-primary">Company LinkedIn <i class="fas fa-external-link-alt small"></i></a></div>
                                    </div>
                                    <div class="col-12 mt-2">
                                        <div class="info-label">COMPANY DESCRIPTION</div>
                                        <div class="info-value p-3 bg-light rounded-3 shadow-none fw-normal"><%= recruiter.company_description %></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Documents Section -->
                        <div class="card shadow-sm border-0 mb-4">
                            <div class="card-body p-4">
                                <h5 class="fw-bold section-header section-header-success mb-4 text-success">TRUST & VERIFICATION</h5>
                                <div class="row g-4">
                                    <div class="col-md-4">
                                        <div class="card h-100 doc-card p-3">
                                            <div class="text-center">
                                                <div class="mb-3 p-3 bg-warning bg-opacity-10 rounded-circle d-inline-block">
                                                    <i class="fas fa-certificate fa-2x text-warning"></i>
                                                </div>
                                                <h6 class="fw-bold mb-1">Company Registration</h6>
                                                <p class="small text-muted mb-3">ID: <%= recruiter.registration_cert_no %></p>
                                                <% if (recruiter.registration_cert_url) { %>
                                                    <a href="<%= recruiter.registration_cert_url %>" class="btn btn-sm btn-primary w-100 rounded-pill" target="_blank">View Docs</a>
                                                <% } else { %>
                                                    <span class="badge bg-danger rounded-pill w-100 py-2">Not Uploaded</span>
                                                <% } %>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="card h-100 doc-card p-3">
                                            <div class="text-center">
                                                <div class="mb-3 p-3 bg-info bg-opacity-10 rounded-circle d-inline-block">
                                                    <i class="fas fa-file-invoice fa-2x text-info"></i>
                                                </div>
                                                <h6 class="fw-bold mb-1">GST/Tax Details</h6>
                                                <p class="small text-muted mb-3">ID: <%= recruiter.gst_number || 'N/A' %></p>
                                                <% if (recruiter.gst_doc_url) { %>
                                                    <a href="<%= recruiter.gst_doc_url %>" class="btn btn-sm btn-primary w-100 rounded-pill" target="_blank">View Docs</a>
                                                <% } else { %>
                                                    <span class="badge bg-secondary rounded-pill w-100 py-2">Not Required</span>
                                                <% } %>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="card h-100 doc-card p-3">
                                            <div class="text-center">
                                                <div class="mb-3 p-3 bg-success bg-opacity-10 rounded-circle d-inline-block">
                                                    <i class="fas fa-id-card fa-2x text-success"></i>
                                                </div>
                                                <h6 class="fw-bold mb-1">PAN Verification</h6>
                                                <p class="small text-muted mb-3">ID: <%= recruiter.pan_number %></p>
                                                <% if (recruiter.pan_doc_url) { %>
                                                    <a href="<%= recruiter.pan_doc_url %>" class="btn btn-sm btn-primary w-100 rounded-pill" target="_blank">View Docs</a>
                                                <% } else { %>
                                                    <span class="badge bg-danger rounded-pill w-100 py-2">Not Uploaded</span>
                                                <% } %>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Side Column -->
                    <div class="col-md-4">
                        <!-- Contact Card -->
                        <div class="card shadow-sm border-0 mb-4">
                            <div class="card-body p-4">
                                <h5 class="fw-bold section-header section-header-primary mb-4 text-primary text-uppercase small ls-wide">REPRESENTATIVE</h5>
                                <div class="text-center mb-4">
                                    <div class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3 shadow-sm" style="width: 80px; height: 80px; font-size: 2rem;">
                                        <%= recruiter.fullname.charAt(0) %>
                                    </div>
                                    <h5 class="fw-bold mb-1"><%= recruiter.fullname %></h5>
                                    <p class="text-muted small"><%= recruiter.designation %></p>
                                </div>
                                <hr>
                                <div class="mb-3">
                                    <div class="info-label text-uppercase x-small">Official Contact</div>
                                    <div class="info-value mb-0"><i class="fas fa-phone-alt me-2 text-primary"></i><%= recruiter.contact_number %></div>
                                </div>
                            </div>
                        </div>

                        <!-- Address Card -->
                        <div class="card shadow-sm border-0 mb-4">
                            <div class="card-body p-4">
                                <h5 class="fw-bold section-header section-header-primary mb-4 text-primary text-uppercase small ls-wide">LOCATION</h5>
                                <div class="d-flex align-items-start">
                                    <i class="fas fa-map-marker-alt text-danger me-3 mt-1 fs-4"></i>
                                    <div>
                                        <div class="fw-bold mb-1"><%= recruiter.address_line %></div>
                                        <div class="text-muted small"><%= recruiter.city %>, <%= recruiter.state %></div>
                                        <div class="text-muted small"><%= recruiter.country %> - <%= recruiter.pincode %></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Actions Sidebar -->
                        <% if (recruiter.status === 'pending') { %>
                        <div class="card shadow-sm border-0 bg-dark text-white">
                            <div class="card-body p-4">
                                <h6 class="fw-bold mb-3 text-uppercase small text-center text-white-50">FINAL DECISION</h6>
                                <div class="d-grid gap-3">
                                    <form action="/api/admin/approve" method="POST" onsubmit="return confirm('APPROVE this recruiter? This will grant them access to post jobs.');">
                                        <input type="hidden" name="userId" value="<%= recruiter.user_id %>">
                                        <button type="submit" class="btn btn-success x-btn-action w-100 py-3 fw-bold shadow-sm">
                                            <i class="fas fa-check-circle me-2"></i>APPROVE ACCESS
                                        </button>
                                    </form>
                                    <form action="/api/admin/reject" method="POST" onsubmit="return confirm('REJECT this recruiter? They will be informed and denied access.');">
                                        <input type="hidden" name="userId" value="<%= recruiter.user_id %>">
                                        <button type="submit" class="btn btn-outline-danger x-btn-action w-100 py-3 fw-bold border-2">
                                            <i class="fas fa-times-circle me-2"></i>REJECT REQUEST
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                        <% } else { %>
                        <div class="card shadow-sm border-0 bg-primary bg-opacity-10">
                            <div class="card-body p-4 text-center">
                                <div class="mb-3 text-primary">
                                    <i class="fas fa-info-circle fa-3x"></i>
                                </div>
                                <h6 class="fw-bold">Decision Completed</h6>
                                <p class="small text-muted mb-4">This profile has already been processed and finalized.</p>
                                <a href="/admin" class="btn btn-primary w-100 py-3 fw-bold shadow-sm">
                                    <i class="fas fa-arrow-left me-2"></i>Back to Panel
                                </a>
                            </div>
                        </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Bootstrap JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <!-- apiService JS -->
    <script src="/js/apiService.js"></script>
</body>
</html>
